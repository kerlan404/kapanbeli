<!--
  Admin Sidebar Component
  Direct HTML - No includes
  Theme-aware sidebar - follows selected theme
-->

<div class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <i class="fas fa-shopping-cart"></i>
            <span>Kapan Beli Admin</span>
        </div>
    </div>

    <div class="sidebar-menu">
        <div class="menu-label">Main Menu</div>

        <a href="/admin" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'active' : '' %>">
            <i class="fas fa-home"></i>
            <span>Dashboard</span>
        </a>

        <a href="/admin/users" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'users' ? 'active' : '' %>">
            <i class="fas fa-users"></i>
            <span>Manajemen Pengguna</span>
        </a>

        <a href="/admin/products" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'products' ? 'active' : '' %>">
            <i class="fas fa-box"></i>
            <span>Semua Produk</span>
        </a>

        <a href="/admin/shopping-suggestions" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'shopping-suggestions' ? 'active' : '' %>">
            <i class="fas fa-shopping-cart"></i>
            <span>Saran Pembelian</span>
        </a>

        <div class="menu-label">Content</div>

        <a href="/admin/notes" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'notes' ? 'active' : '' %>">
            <i class="fas fa-sticky-note"></i>
            <span>Catatan User</span>
        </a>

        <a href="/admin/activity-logs" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'activity-logs' ? 'active' : '' %>">
            <i class="fas fa-history"></i>
            <span>Log Aktivitas</span>
        </a>

        <div class="menu-label">Analytics & System</div>

        <a href="/admin/analytics" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'analytics' ? 'active' : '' %>">
            <i class="fas fa-chart-line"></i>
            <span>Analitik</span>
        </a>

        <a href="/admin/settings" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'settings' ? 'active' : '' %>">
            <i class="fas fa-cog"></i>
            <span>Pengaturan</span>
        </a>
    </div>

    <div class="sidebar-footer">
        <div class="user-mini-profile">
            <div class="user-avatar">
                <%= typeof user !== 'undefined' && user && user.name ? user.name[0].toUpperCase() : 'A' %>
            </div>
            <div class="user-info" style="flex: 1; min-width: 0;">
                <h4 style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= typeof user !== 'undefined' && user && user.name ? user.name : 'Admin' %></h4>
                <p style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= typeof user !== 'undefined' && user && user.email ? user.email : 'admin@kapanbeli.com' %></p>
            </div>
            <form action="/auth/logout" method="POST" style="display: inline;">
                <button type="submit" class="logout-btn" title="Logout">
                    <i class="fas fa-sign-out-alt"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    // Sidebar theme handler - follows selected theme
    (function() {
        const sidebar = document.getElementById('sidebar');
        if (!sidebar) return;

        function applyTheme() {
            const isDark = localStorage.getItem('theme') === 'dark' ||
                (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches);

            if (isDark) {
                // Dark theme - keep original dark sidebar
                sidebar.style.setProperty('--bg-sidebar', '#1a1d23');
                sidebar.style.setProperty('--text-light', '#ecf0f1');
                sidebar.classList.remove('light-theme');
            } else {
                // Light theme - change sidebar to light color
                sidebar.style.setProperty('--bg-sidebar', '#ffffff');
                sidebar.style.setProperty('--text-light', '#2C3E50');
                sidebar.classList.add('light-theme');
            }
        }

        // Apply on load
        applyTheme();

        // Listen for theme changes via storage event
        window.addEventListener('storage', (e) => {
            if (e.key === 'theme') {
                applyTheme();
            }
        });
    })();
</script>

<style>
    /* Light theme sidebar styles */
    .sidebar.light-theme {
        background-color: var(--bg-sidebar, #ffffff) !important;
        border-right: 1px solid rgba(0,0,0,0.1);
    }

    .sidebar.light-theme .sidebar-header {
        border-bottom-color: rgba(0,0,0,0.1) !important;
    }

    .sidebar.light-theme .nav-item {
        color: rgba(44, 62, 80, 0.7) !important;
    }

    .sidebar.light-theme .nav-item:hover {
        background-color: rgba(46, 134, 222, 0.08) !important;
        color: #2C3E50 !important;
    }

    .sidebar.light-theme .nav-item.active {
        background-color: rgba(46, 134, 222, 0.12) !important;
        color: var(--primary-blue) !important;
        border-left-color: var(--primary-blue) !important;
    }

    .sidebar.light-theme .menu-label {
        color: rgba(44, 62, 80, 0.5) !important;
    }

    .sidebar.light-theme .user-info h4 {
        color: #2C3E50 !important;
    }

    .sidebar.light-theme .user-info p {
        color: rgba(44, 62, 80, 0.6) !important;
    }

    .sidebar.light-theme .logout-btn {
        background: rgba(255, 107, 107, 0.1) !important;
        border-color: rgba(255, 107, 107, 0.2) !important;
    }

    .sidebar.light-theme .logout-btn:hover {
        background: var(--accent-red) !important;
        color: white !important;
    }
</style>
