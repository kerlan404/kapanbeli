<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saran Pembelian - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-dark: #1D4ED8;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-sidebar-hover: #f1f5f9;
            --bg-sidebar-active: #e2e8f0;
            --text-sidebar: #475569;
            --text-sidebar-active: #000000;
            --text-sidebar-heading: #000000;
            --sidebar-border: #000000;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #000000;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
            --radius: 0px;
            --sidebar-width: 260px;
            --header-height: 70px;
            --content-padding: 40px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1A1D23;
            --bg-body: #0F1115;
            --bg-card: #1A1D23;
            --text-main: #FFFFFF;
            --text-muted: #9CA3AF;
            --border-color: #FFFFFF;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            transition: background 0.3s;
        }

        /* Sidebar Overlay */
        .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
        .sidebar-overlay.active { display: block; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width); flex: 1; padding: var(--content-padding); transition: margin-left 0.3s ease;
        }

        .top-bar {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 40px; gap: 20px; flex-wrap: wrap;
        }
        .page-title { font-size: 2.2rem; font-weight: 900; letter-spacing: -1.5px; text-transform: uppercase; }
        .page-subtitle { font-size: 1.1rem; color: var(--text-muted); margin-top: 5px; font-weight: 500; }
        
        .top-actions { display: flex; gap: 15px; align-items: center; }

        /* Buttons */
        .btn {
            padding: 14px 28px; border: 4px solid var(--border-color); border-radius: var(--radius);
            font-weight: 800; font-size: 1rem; cursor: pointer;
            display: inline-flex; align-items: center; gap: 12px;
            transition: all 0.2s; font-family: inherit;
            text-transform: uppercase; letter-spacing: 0.5px;
            box-shadow: var(--shadow-brutal-sm);
        }
        .btn:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0px var(--border-color); }
        .btn:active { transform: translate(0, 0); box-shadow: 2px 2px 0px var(--border-color); }

        .btn-primary { background: var(--primary-blue); color: white; }
        .btn-outline { background: var(--bg-card); color: var(--text-main); }
        .btn-sm { padding: 8px 16px; font-size: 0.85rem; border-width: 3px; }
        
        .theme-toggle { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }

        /* Stats Grid */
        .stats-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 25px; margin-bottom: 40px;
        }
        .stat-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 30px; box-shadow: var(--shadow-brutal);
            transition: all 0.2s;
        }
        .stat-card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }
        .stat-card h3 { font-size: 2.8rem; font-weight: 900; margin-bottom: 5px; line-height: 1; }
        .stat-card p { font-size: 0.95rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

        /* Panel Card */
        .panel-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 35px; box-shadow: var(--shadow-brutal);
            margin-bottom: 40px;
        }
        .panel-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
            flex-wrap: wrap; gap: 20px;
        }
        .panel-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; }

        /* Search & Filters */
        .filters-container {
            display: flex; gap: 20px; width: 100%; flex-wrap: wrap;
        }
        .filter-group { flex: 1; min-width: 200px; }
        .filter-label { display: block; font-weight: 900; margin-bottom: 10px; text-transform: uppercase; font-size: 0.85rem; }
        
        .form-control {
            width: 100%; padding: 15px 20px;
            border: 3px solid var(--border-color); border-radius: var(--radius);
            background: var(--bg-card); color: var(--text-main);
            font-size: 1rem; font-weight: 700; box-shadow: var(--shadow-brutal-sm);
            transition: all 0.2s; outline: none;
        }
        .form-control:focus { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); border-color: var(--primary-blue); }

        /* Table */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th {
            text-align: left; padding: 20px; font-weight: 900;
            color: var(--text-main); font-size: 0.9rem; text-transform: uppercase;
            letter-spacing: 1px; border-bottom: 4px solid var(--border-color);
            background: rgba(0,0,0,0.05);
        }
        body.dark-mode-active th { background: rgba(255,255,255,0.05); }
        td { padding: 20px; border-bottom: 3px solid var(--border-color); font-weight: 700; font-size: 1rem; }
        tr:hover { background: rgba(0,0,0,0.02); }
        body.dark-mode-active tr:hover { background: rgba(255,255,255,0.02); }

        .product-info { display: flex; align-items: center; gap: 15px; }
        .product-img {
            width: 50px; height: 50px; border: 3px solid var(--border-color);
            object-fit: cover; box-shadow: 3px 3px 0px var(--border-color);
        }

        .badge {
            display: inline-block; padding: 6px 14px; border: 3px solid var(--border-color);
            font-size: 0.8rem; font-weight: 900; text-transform: uppercase;
            box-shadow: 3px 3px 0px var(--border-color);
        }
        .badge-success { background: var(--accent-green); color: white; }
        .badge-warning { background: var(--primary-orange); color: white; }
        .badge-danger { background: var(--accent-red); color: white; }
        .badge-info { background: var(--primary-blue); color: white; }

        /* Priority Badge Custom */
        .priority-high { background: var(--accent-red); color: white; }
        .priority-medium { background: var(--primary-orange); color: white; }
        .priority-low { background: #6c5ce7; color: white; }

        /* Pagination */
        .pagination-container { display: flex; justify-content: space-between; align-items: center; margin-top: 30px; padding-top: 20px; border-top: 4px solid var(--border-color); flex-wrap: wrap; gap: 20px; }
        .pagination-info { font-weight: 800; color: var(--text-muted); font-size: 0.95rem; }
        .pagination { display: flex; gap: 10px; list-style: none; }
        .pagination button {
            min-width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;
            border: 3px solid var(--border-color); background: var(--bg-card); font-weight: 900;
            cursor: pointer; transition: all 0.2s; box-shadow: 4px 4px 0px var(--border-color);
            padding: 0 15px; font-family: inherit; text-transform: uppercase;
        }
        .pagination button:hover:not(:disabled) { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .pagination button.active { background: var(--primary-blue); color: white; }
        .pagination button:disabled { opacity: 0.4; cursor: not-allowed; }

        /* Action Buttons */
        .btn-icon {
            width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;
            border: 3px solid var(--border-color); background: var(--bg-card);
            color: var(--text-main); font-size: 1.1rem; transition: all 0.2s;
            box-shadow: 4px 4px 0px var(--border-color);
            cursor: pointer;
        }
        .btn-icon:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .btn-icon.edit:hover { color: var(--primary-blue); border-color: var(--primary-blue); box-shadow: 6px 6px 0px var(--primary-blue); }

        /* Modal */
        .modal {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center; padding: 20px;
            opacity: 0; transition: all 0.2s;
        }
        .modal.active { display: flex; opacity: 1; }
        .modal-content {
            background: var(--bg-card); border: 6px solid var(--border-color);
            width: 100%; max-width: 800px; max-height: 90vh; overflow-y: auto;
            position: relative; box-shadow: 20px 20px 0px rgba(0,0,0,0.5);
            padding: 40px; transform: scale(0.95); transition: all 0.2s;
        }
        .modal.active .modal-content { transform: scale(1); }
        .modal-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 35px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
        }
        .modal-title { font-size: 1.8rem; font-weight: 900; text-transform: uppercase; display: flex; align-items: center; gap: 15px; }
        .modal-close { font-size: 2.5rem; cursor: pointer; color: var(--text-main); line-height: 1; transition: color 0.2s; background: none; border: none; }
        .modal-close:hover { color: var(--accent-red); }

        .form-group { margin-bottom: 25px; }
        .form-group label { display: block; font-weight: 900; margin-bottom: 12px; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 0.5px; }

        /* Loading */
        .loading-state { text-align: center; padding: 60px; }
        .loading-state i { font-size: 3rem; color: var(--primary-blue); margin-bottom: 20px; }

        /* Responsive */
        .menu-toggle { display: none; font-size: 1.5rem; cursor: pointer; color: var(--text-main); }
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 25px; }
            .menu-toggle { display: block; }
        }
    </style>
</head>
<body>
    <%- include('./partials/admin-sidebar', { currentPage: 'shopping-suggestions', user: typeof user !== 'undefined' ? user : null }) %>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <div>
                    <h1 class="page-title">🛒 Saran Pembelian</h1>
                    <p class="page-subtitle">Saran stok berdasarkan ambang batas dan tanggal kadaluarsa</p>
                </div>
            </div>
            <div class="top-actions">
                <button class="btn btn-outline theme-toggle" onclick="toggleTheme()" id="themeToggleBtn">
                    <i class="fas fa-moon"></i>
                </button>
                <button class="btn btn-primary" onclick="loadSuggestions()">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Statistics -->
        <div class="stats-grid" id="statsGrid">
            <div class="stat-card">
                <h3 id="statOutOfStock">0</h3>
                <p>Habis Stok</p>
            </div>
            <div class="stat-card">
                <h3 id="statLowStock">0</h3>
                <p>Stok Rendah</p>
            </div>
            <div class="stat-card">
                <h3 id="statExpiringSoon">0</h3>
                <p>Segera Kadaluarsa</p>
            </div>
            <div class="stat-card">
                <h3 id="statExpired">0</h3>
                <p>Kadaluarsa</p>
            </div>
        </div>

        <!-- Suggestions Table -->
        <div class="panel-card">
            <div class="panel-header">
                <h3 class="panel-title">Produk yang Perlu Dibeli</h3>
                <div class="filters-container">
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-search"></i> Cari</label>
                        <input type="text" id="searchInput" class="form-control" placeholder="Nama produk..." onkeyup="debounceSearch()">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-filter"></i> Status</label>
                        <select id="statusFilter" class="form-control" onchange="loadSuggestions()">
                            <option value="">Semua Status</option>
                            <option value="out_of_stock">Habis Stok</option>
                            <option value="low_stock">Stok Rendah</option>
                            <option value="expiring">Segera Kadaluarsa</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-user"></i> Pengguna</label>
                        <select id="userFilter" class="form-control" onchange="loadSuggestions()">
                            <option value="">Semua Pengguna</option>
                        </select>
                    </div>
                    <div style="display: flex; gap: 10px; align-items: flex-end;">
                        <button class="btn btn-outline" onclick="resetFilters()">
                            <i class="fas fa-redo"></i> Reset
                        </button>
                    </div>
                </div>
            </div>

            <!-- Loading -->
            <div id="tableLoading" class="loading-state" style="display: none;">
                <i class="fas fa-circle-notch fa-spin"></i>
                <p style="font-weight: 800; text-transform: uppercase;">Memuat data saran...</p>
            </div>

            <!-- Table -->
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Produk</th>
                            <th>Pemilik</th>
                            <th>Stok</th>
                            <th>Kadaluarsa</th>
                            <th>Status</th>
                            <th>Prioritas</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="suggestionsTableBody">
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" id="paginationContainer" style="display: none;">
                <div class="pagination-info" id="paginationInfo"></div>
                <div class="pagination" id="paginationButtons"></div>
            </div>

            <!-- Empty State -->
            <div id="emptyState" style="text-align: center; padding: 60px 20px; display: none;">
                <i class="fas fa-check-circle" style="font-size: 3rem; color: var(--accent-green); margin-bottom: 15px;"></i>
                <p style="font-weight: 800;">Stok aman. Tidak ada produk yang perlu dibeli saat ini.</p>
            </div>
        </div>
    </main>

    <!-- Update Stock Modal -->
    <div class="modal" id="updateStockModal">
        <div class="modal-content" style="max-width: 500px;">
            <div class="modal-header">
                <h2 class="modal-title"><i class="fas fa-box"></i> Edit Stok Produk</h2>
                <button class="modal-close" onclick="closeUpdateStockModal()">&times;</button>
            </div>
            
            <div class="form-group">
                <label for="updateStockName">Nama Produk</label>
                <input type="text" id="updateStockName" class="form-control" disabled style="background: rgba(0,0,0,0.05);">
            </div>
            
            <div class="form-group">
                <label for="updateStockQuantity" style="font-weight: 900; font-size: 0.85rem; letter-spacing: 0.5px;">STOK SAAT INI <span style="color:var(--accent-red)">*</span></label>
                <input type="number" id="updateStockQuantity" class="form-control" required min="0" step="0.01">
            </div>
            
            <input type="hidden" id="updateStockId">
            
            <div style="display: flex; gap: 15px; margin-top: 35px;">
                <button class="btn btn-outline" onclick="closeUpdateStockModal()" style="flex: 1;">Batal</button>
                <button class="btn btn-primary" onclick="submitUpdateStock()" style="flex: 1;">Simpan</button>
            </div>
        </div>
    </div>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        let currentPage = 1;
        let currentLimit = 20;
        let searchTimer = null;

        // Theme Toggle Bridge
        function toggleTheme() {
            if (window.toggleAppTheme) {
                window.toggleAppTheme();
            }
        }

        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        });

        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }

        function showToast(message, type = 'success') {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                customClass: { popup: 'nb-popup' },
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            Toast.fire({
                icon: type,
                title: message
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            
            loadUsersForFilter();
            loadSuggestions();
            loadStatistics();
        });

        async function loadStatistics() {
            try {
                const response = await fetch('/api/admin/shopping-suggestions/statistics', { credentials: 'same-origin' });
                const result = await response.json();
                if (result.success) {
                    document.getElementById('statOutOfStock').textContent = result.data.out_of_stock;
                    document.getElementById('statLowStock').textContent = result.data.low_stock;
                    document.getElementById('statExpiringSoon').textContent = result.data.expiring_soon;
                    document.getElementById('statExpired').textContent = result.data.expired;
                }
            } catch (error) { console.error('Error stats:', error); }
        }

        async function loadUsersForFilter() {
            try {
                const response = await fetch('/api/users?limit=100', { credentials: 'same-origin' });
                const result = await response.json();
                if (result.success) {
                    const select = document.getElementById('userFilter');
                    result.data.forEach(user => {
                        const option = document.createElement('option');
                        option.value = user.id;
                        option.textContent = user.name;
                        select.appendChild(option);
                    });
                }
            } catch (error) { console.error('Error users:', error); }
        }

        async function loadSuggestions() {
            const search = document.getElementById('searchInput').value;
            const status = document.getElementById('statusFilter').value;
            const userId = document.getElementById('userFilter').value;
            
            const params = new URLSearchParams({
                page: currentPage,
                limit: currentLimit,
                ...(search && { search }),
                ...(status && { status }),
                ...(userId && { userId })
            });

            const loading = document.getElementById('tableLoading');
            const tbody = document.getElementById('suggestionsTableBody');
            
            loading.style.display = 'block';
            tbody.style.opacity = '0.5';

            try {
                const response = await fetch(`/api/admin/shopping-suggestions?${params}`, { credentials: 'same-origin' });
                const result = await response.json();
                loading.style.display = 'none';
                tbody.style.opacity = '1';

                if (result.success) {
                    renderSuggestionsTable(result.data);
                    renderPagination(result.pagination);
                }
            } catch (error) {
                console.error('Error suggestions:', error);
                loading.innerHTML = '<i class="fas fa-exclamation-triangle" style="color: var(--accent-red);"></i><p>Gagal memuat data</p>';
            }
        }

        function renderSuggestionsTable(products) {
            const tbody = document.getElementById('suggestionsTableBody');
            const emptyState = document.getElementById('emptyState');
            const paginationContainer = document.getElementById('paginationContainer');

            if (!products || products.length === 0) {
                tbody.innerHTML = '';
                emptyState.style.display = 'block';
                paginationContainer.style.display = 'none';
                return;
            }

            emptyState.style.display = 'none';
            paginationContainer.style.display = 'flex';

            tbody.innerHTML = products.map(p => {
                const img = p.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(p.name)}&background=3B82F6&color=fff`;
                return `
                    <tr>
                        <td>
                            <div class="product-info">
                                <img src="${img}" class="product-img">
                                <div>
                                    <div style="font-weight: 800;">${p.name}</div>
                                    <div style="font-size: 0.8rem; color: var(--text-muted);">${p.category_name || 'Lainnya'}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div style="font-weight: 800;">${p.user_name || 'Unknown'}</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">${p.user_email || ''}</div>
                        </td>
                        <td>
                            <div style="font-weight: 900;">${p.stock_quantity} ${p.unit || ''}</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">Min: ${p.min_stock_level}</div>
                        </td>
                        <td style="font-weight: 700;">${p.expiry_date ? new Date(p.expiry_date).toLocaleDateString('id-ID') : '-'}</td>
                        <td>
                            <div style="display: flex; flex-direction: column; gap: 8px;">
                                ${getStatusBadge(p.stock_status)}
                                ${getExpiryBadge(p.expiry_status)}
                            </div>
                        </td>
                        <td>${getPriorityBadge(p.priority)}</td>
                        <td>
                            ${p.user_role === 'admin' ? `
                                <button class="btn-icon edit" onclick="openUpdateStockModal(${p.id}, '${p.name.replace(/'/g, "\\'")}', ${p.stock_quantity})" title="Update Stok" style="width: 32px; height: 32px; font-size: 0.9rem;">
                                    <i class="fas fa-edit"></i>
                                </button>
                            ` : '-'}
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function getStatusBadge(s) {
            if (s === 'out_of_stock') return '<span class="badge badge-danger">Habis</span>';
            if (s === 'low_stock') return '<span class="badge badge-warning">Rendah</span>';
            return '<span class="badge badge-success">Aman</span>';
        }

        function getExpiryBadge(s) {
            if (s === 'expired') return '<span class="badge badge-danger">Expired</span>';
            if (s === 'expiring_very_soon') return '<span class="badge badge-warning">Segera</span>';
            return '';
        }

        function getPriorityBadge(p) {
            if (p === 1) return '<span class="badge priority-high">Tinggi</span>';
            if (p === 2) return '<span class="badge priority-medium">Sedang</span>';
            return '<span class="badge priority-low">Rendah</span>';
        }

        function renderPagination(p) {
            const info = document.getElementById('paginationInfo');
            const buttons = document.getElementById('paginationButtons');

            info.innerHTML = `Menampilkan <b>${((p.currentPage - 1) * p.limit) + 1} - ${Math.min(p.currentPage * p.limit, p.totalItems)}</b> dari <b>${p.totalItems}</b> data`;

            let html = `<button onclick="goToPage(${p.currentPage - 1})" ${p.currentPage === 1 ? 'disabled' : ''}>Prev</button>`;
            for (let i = 1; i <= p.totalPages; i++) {
                if (i === 1 || i === p.totalPages || (i >= p.currentPage - 2 && i <= p.currentPage + 2)) {
                    html += `<button class="${i === p.currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                } else if (i === p.currentPage - 3 || i === p.currentPage + 3) {
                    html += `<button disabled>...</button>`;
                }
            }
            html += `<button onclick="goToPage(${p.currentPage + 1})" ${p.currentPage === p.totalPages ? 'disabled' : ''}>Next</button>`;
            buttons.innerHTML = html;
        }

        function goToPage(page) { currentPage = page; loadSuggestions(); }
        function debounceSearch() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => { currentPage = 1; loadSuggestions(); }, 500);
        }
        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('statusFilter').value = '';
            document.getElementById('userFilter').value = '';
            currentPage = 1;
            loadSuggestions();
        }

        // Update Stock Modal Logic
        function openUpdateStockModal(id, name, currentStock) {
            document.getElementById('updateStockId').value = id;
            document.getElementById('updateStockName').value = name;
            document.getElementById('updateStockQuantity').value = currentStock;
            document.getElementById('updateStockModal').classList.add('active');
        }

        function closeUpdateStockModal() {
            document.getElementById('updateStockModal').classList.remove('active');
        }

        async function submitUpdateStock() {
            const id = document.getElementById('updateStockId').value;
            const stock = parseFloat(document.getElementById('updateStockQuantity').value);
            
            if (isNaN(stock) || stock < 0) {
                showToast('Jumlah stok tidak valid', 'error');
                return;
            }

            document.getElementById('tableLoading').style.display = 'block';
            document.getElementById('suggestionsTableBody').style.opacity = '0.5';
            closeUpdateStockModal();

            try {
                // Menggunakan PUT /api/admin/products/:id untuk update stok
                const res = await fetch(`/api/admin/products/${id}`, {
                    method: 'PUT',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ stock_quantity: stock })
                });
                const data = await res.json();
                
                if (data.success) {
                    showToast('Stok berhasil diupdate', 'success');
                    loadSuggestions();
                    loadStatistics();
                } else {
                    showToast(data.message || 'Gagal update stok', 'error');
                    document.getElementById('tableLoading').style.display = 'none';
                    document.getElementById('suggestionsTableBody').style.opacity = '1';
                }
            } catch (error) {
                console.error('Error update stock:', error);
                showToast('Terjadi kesalahan sistem', 'error');
                document.getElementById('tableLoading').style.display = 'none';
                document.getElementById('suggestionsTableBody').style.opacity = '1';
            }
        }
    </script>
</body>
</html>
