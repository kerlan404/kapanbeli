<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pengaturan - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-dark: #1D4ED8;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-sidebar-hover: #f1f5f9;
            --bg-sidebar-active: #e2e8f0;
            --text-sidebar: #475569;
            --text-sidebar-active: #000000;
            --text-sidebar-heading: #000000;
            --sidebar-border: #000000;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #000000;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
            --radius: 0px;
            --sidebar-width: 260px;
            --header-height: 70px;
            --content-padding: 40px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1A1D23;
            --bg-body: #0F1115;
            --bg-card: #1A1D23;
            --text-main: #FFFFFF;
            --text-muted: #9CA3AF;
            --border-color: #FFFFFF;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            transition: background 0.3s;
        }

        /* Sidebar Overlay */
        .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
        .sidebar-overlay.active { display: block; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width); flex: 1; padding: var(--content-padding); transition: margin-left 0.3s ease;
        }

        .top-bar {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 40px; gap: 20px; flex-wrap: wrap;
        }
        .page-title { font-size: 2.2rem; font-weight: 900; letter-spacing: -1.5px; text-transform: uppercase; }
        .page-subtitle { font-size: 1.1rem; color: var(--text-muted); margin-top: 5px; font-weight: 500; }
        
        .top-actions { display: flex; gap: 15px; align-items: center; }

        /* Buttons */
        .btn {
            padding: 14px 28px; border: 4px solid var(--border-color); border-radius: var(--radius);
            font-weight: 800; font-size: 1rem; cursor: pointer;
            display: inline-flex; align-items: center; gap: 12px;
            transition: all 0.2s; font-family: inherit;
            text-transform: uppercase; letter-spacing: 0.5px;
            box-shadow: var(--shadow-brutal-sm);
        }
        .btn:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0px var(--border-color); }
        .btn:active { transform: translate(0, 0); box-shadow: 2px 2px 0px var(--border-color); }

        .btn-primary { background: var(--primary-blue); color: white; }
        .btn-outline { background: var(--bg-card); color: var(--text-main); }
        .btn-warning { background: var(--primary-orange); color: white; }
        .btn-danger { background: var(--accent-red); color: white; }
        
        .theme-toggle { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }

        /* Settings Grid */
        .settings-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 32px;
        }

        /* Panel Card */
        .panel-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 35px; box-shadow: var(--shadow-brutal);
            margin-bottom: 40px;
        }
        .panel-header {
            display: flex; align-items: center; gap: 20px;
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
        }
        .header-icon {
            width: 56px; height: 56px; border: 3px solid var(--border-color);
            background: var(--primary-blue); color: white;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; box-shadow: 4px 4px 0px var(--border-color);
        }
        .panel-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; }

        /* Profile Section */
        .profile-photo-container {
            display: flex; flex-direction: column; align-items: center; margin-bottom: 35px;
        }
        .avatar-wrapper {
            width: 150px; height: 150px; border: 5px solid var(--border-color);
            background: var(--bg-body); border-radius: 0; position: relative;
            cursor: pointer; transition: all 0.2s; box-shadow: var(--shadow-brutal);
            overflow: hidden; display: flex; align-items: center; justify-content: center;
        }
        .avatar-wrapper:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }
        .avatar-wrapper img { width: 100%; height: 100%; object-fit: cover; }
        .avatar-wrapper span { font-size: 4rem; font-weight: 900; color: var(--primary-blue); }
        
        .upload-badge {
            position: absolute; bottom: 0; right: 0; width: 40px; height: 40px;
            background: var(--primary-orange); color: white; border: 3px solid var(--border-color);
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
        }

        /* Form Controls */
        .form-group { margin-bottom: 25px; }
        .form-label { display: block; font-weight: 900; margin-bottom: 12px; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 0.5px; }
        
        .form-control {
            width: 100%; padding: 15px 20px;
            border: 3px solid var(--border-color); border-radius: var(--radius);
            background: var(--bg-card); color: var(--text-main);
            font-size: 1rem; font-weight: 700; box-shadow: var(--shadow-brutal-sm);
            transition: all 0.2s; outline: none;
        }
        .form-control:focus { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); border-color: var(--primary-blue); }

        /* Info List */
        .info-list { display: flex; flex-direction: column; gap: 15px; }
        .info-item {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 20px; border: 3px solid var(--border-color);
            background: rgba(0,0,0,0.02); font-weight: 800;
        }
        body.dark-mode-active .info-item { background: rgba(255,255,255,0.02); }
        .info-label { color: var(--text-muted); text-transform: uppercase; font-size: 0.85rem; }
        .info-value { color: var(--primary-blue); }

        /* Toast */
        .toast-container { position: fixed; top: 20px; right: 20px; z-index: 3000; }
        .toast {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 15px 25px; margin-bottom: 10px; display: flex; align-items: center; gap: 12px;
            box-shadow: var(--shadow-brutal-sm); animation: slideIn 0.3s ease;
        }
        @keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }

        /* Responsive */
        .menu-toggle { display: none; font-size: 1.5rem; cursor: pointer; color: var(--text-main); }
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 25px; }
            .menu-toggle { display: block; }
        }
    </style>
</head>
<body>
    <%- include('./partials/admin-sidebar', { currentPage: 'settings', user: typeof user !== 'undefined' ? user : null }) %>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <div>
                    <h1 class="page-title">⚙️ Pengaturan</h1>
                    <p class="page-subtitle">Kelola profil admin dan keamanan sistem</p>
                </div>
            </div>
            <div class="top-actions">
                <button class="btn btn-outline theme-toggle" onclick="toggleTheme()" id="themeToggleBtn">
                    <i class="fas fa-moon"></i>
                </button>
            </div>
        </div>

        <div class="settings-grid">
            <!-- Profile Panel -->
            <div class="panel-card">
                <div class="panel-header">
                    <div class="header-icon"><i class="fas fa-user-cog"></i></div>
                    <h3 class="panel-title">Profil Admin</h3>
                </div>

                <div class="profile-photo-container">
                    <div class="avatar-wrapper" onclick="document.getElementById('profilePhotoInput').click()">
                        <% if (user && (user.profile_photo || user.profile_image)) { %>
                            <img src="<%= user.profile_photo || user.profile_image %>" alt="Profile" id="previewImg">
                        <% } else { %>
                            <span id="previewInitial"><%= user && user.name ? user.name[0].toUpperCase() : 'A' %></span>
                            <img src="" alt="Profile" id="previewImg" style="display: none;">
                        <% } %>
                        <div class="upload-badge"><i class="fas fa-camera"></i></div>
                    </div>
                    <input type="file" id="profilePhotoInput" style="display: none;" accept="image/*" onchange="handlePhotoChange(event)">
                    <p style="margin-top: 15px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; font-size: 0.8rem;">Klik untuk ganti foto</p>
                </div>

                <form id="profileForm">
                    <div class="form-group">
                        <label class="form-label">Nama Lengkap</label>
                        <input type="text" name="name" class="form-control" value="<%= user ? user.name : '' %>" required placeholder="Nama Anda">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input type="email" name="email" class="form-control" value="<%= user ? user.email : '' %>" required placeholder="email@kapanbeli.com">
                    </div>
                    <button type="submit" class="btn btn-primary" id="saveProfileBtn">
                        <i class="fas fa-save"></i> Simpan Perubahan
                    </button>
                </form>
            </div>

            <!-- Security Panel -->
            <div class="panel-card">
                <div class="panel-header">
                    <div class="header-icon" style="background: var(--primary-orange);"><i class="fas fa-shield-alt"></i></div>
                    <h3 class="panel-title">Keamanan</h3>
                </div>

                <form id="passwordForm">
                    <div class="form-group">
                        <label class="form-label">Password Baru</label>
                        <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="Minimal 6 karakter" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Konfirmasi Password</label>
                        <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="Ulangi password baru" required>
                    </div>
                    <button type="submit" class="btn btn-warning" id="savePasswordBtn">
                        <i class="fas fa-key"></i> Ganti Password
                    </button>
                </form>

                <div style="margin-top: 40px; padding-top: 30px; border-top: 4px solid var(--border-color);">
                    <div class="panel-header" style="border: none; margin-bottom: 20px;">
                        <div class="header-icon" style="background: var(--text-muted);"><i class="fas fa-info-circle"></i></div>
                        <h3 class="panel-title" style="font-size: 1.2rem;">Info Sistem</h3>
                    </div>
                    <div class="info-list">
                        <div class="info-item">
                            <span class="info-label">Versi App</span>
                            <span class="info-value">1.1.0-BRUTAL</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Engine</span>
                            <span class="info-value">Node.js v20</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Status</span>
                            <span class="info-value" style="color: var(--accent-green);">Stabil</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // Theme Toggle Bridge
        function toggleTheme() {
            if (window.toggleAppTheme) {
                window.toggleAppTheme();
            }
        }

        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        });

        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast`;
            toast.style.borderColor = type === 'success' ? 'var(--accent-green)' : 'var(--accent-red)';
            const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
            toast.innerHTML = `<i class="fas ${icon}" style="color: ${type === 'success' ? 'var(--accent-green)' : 'var(--accent-red)'}"></i><span style="font-weight: 800; text-transform: uppercase; font-size: 0.9rem;">${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        });

        // Profile Form
        document.getElementById('profileForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('saveProfileBtn');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Menyimpan...';

            try {
                const response = await fetch('/api/profile', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name: this.name.value, email: this.email.value })
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire({
                        title: 'Berhasil!',
                        text: 'Profil admin telah diperbarui.',
                        icon: 'success',
                        confirmButtonColor: '#3B82F6',
                        confirmButtonText: 'OKE'
                    }).then(() => window.location.reload());
                } else {
                    showToast(result.message || 'Gagal memperbarui profil', 'error');
                }
            } catch (error) { showToast('Kesalahan koneksi', 'error'); }
            finally { btn.disabled = false; btn.innerHTML = originalText; }
        });

        // Password Form
        document.getElementById('passwordForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('savePasswordBtn');
            const newPwd = document.getElementById('newPassword').value;
            const confirmPwd = document.getElementById('confirmPassword').value;

            if (newPwd !== confirmPwd) return showToast('Password tidak cocok!', 'error');

            btn.disabled = true;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Memproses...';

            try {
                const response = await fetch('/api/profile/password', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newPassword: newPwd, confirmPassword: confirmPwd })
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire({ title: 'Berhasil', text: 'Password berhasil diganti.', icon: 'success', confirmButtonColor: '#FF9F43' });
                    this.reset();
                } else { showToast(result.message || 'Gagal ganti password', 'error'); }
            } catch (error) { showToast('Kesalahan sistem', 'error'); }
            finally { btn.disabled = false; btn.innerHTML = originalText; }
        });

        // Photo Change
        async function handlePhotoChange(event) {
            const file = event.target.files[0];
            if (!file) return;

            const confirm = await Swal.fire({
                title: 'Ganti Foto Profil?',
                text: 'Foto profil admin akan diperbarui secara global.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, Ganti',
                confirmButtonColor: '#3B82F6'
            });

            if (confirm.isConfirmed) {
                const formData = new FormData();
                formData.append('profile_photo', file);
                try {
                    Swal.fire({ title: 'Mengunggah...', didOpen: () => Swal.showLoading(), allowOutsideClick: false });
                    const response = await fetch('/api/profile/photo', { method: 'POST', body: formData });
                    const result = await response.json();
                    if (result.success) {
                        Swal.fire({ icon: 'success', title: 'Berhasil', timer: 1500, showConfirmButton: false }).then(() => window.location.reload());
                    } else { showToast(result.message || 'Gagal upload', 'error'); }
                } catch (error) { showToast('Gagal terhubung ke server', 'error'); }
            } else { event.target.value = ''; }
        }
    </script>
</body>
</html>
