<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pengaturan - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        /* --- PREMIUM DESIGN SYSTEM --- */
        :root {
            --primary: #3B82F6;
            --primary-glow: rgba(59, 130, 246, 0.5);
            --accent: #2563EB; /* Unified to Blue */
            --accent-glow: rgba(37, 99, 235, 0.4);
            --bg-light: #F1F5F9;
            --bg-dark: #0F172A;
            --card-glass: #FFFFFF;
            --card-glass-dark: #1E293B;
            --text-main: #1E293B;
            --text-muted: #64748B;
            --border-glass: rgba(0, 0, 0, 0.05);
            --border-glass-dark: rgba(255, 255, 255, 0.05);
            --shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04);
            --shadow-lg: 0 20px 50px -10px rgba(0, 0, 0, 0.08);
            --radius-xl: 32px;
            --radius-lg: 24px;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --sidebar-width: 260px;
        }

        body.dark-mode-active {
            --bg-light: var(--bg-dark);
            --card-glass: var(--card-glass-dark);
            --text-main: #F8FAFC;
            --text-muted: #94A3B8;
            --border-glass: var(--border-glass-dark);
            --shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.6);
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box;
            font-family: 'Plus Jakarta Sans', 'Outfit', sans-serif;
        }

        body {
            background-color: var(--bg-light);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            transition: var(--transition);
        }

        /* Mesh Gradient Background */
        .mesh-bg {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1;
            background: var(--bg-light);
            overflow: hidden;
        }

        /* Simplified mesh - only subtle blue glow */
        .mesh-bg::after {
            content: '';
            position: absolute;
            width: 800px; height: 800px;
            border-radius: 50%;
            filter: blur(150px);
            opacity: 0.1;
            background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
            bottom: -20%; right: -10%;
        }

        /* Main Content Area */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 40px;
            position: relative;
            z-index: 1;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 48px;
            animation: fadeInDown 0.8s ease-out;
        }

        .page-title h1 {
            font-size: 2.8rem;
            font-weight: 800;
            letter-spacing: -1.5px;
            margin-bottom: 8px;
            color: var(--text-main);
        }

        .page-title p {
            color: var(--text-muted);
            font-size: 1.1rem;
            font-weight: 500;
        }

        .top-actions {
            display: flex;
            gap: 16px;
        }

        /* Glass Cards */
        .settings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 32px;
            animation: fadeInUp 0.8s ease-out;
        }

        .glass-card {
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius-lg);
            padding: 40px;
            box-shadow: var(--shadow);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .glass-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary);
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 32px;
        }

        .header-icon {
            width: 56px;
            height: 56px;
            background: rgba(59, 130, 246, 0.1);
            color: var(--primary);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            box-shadow: inset 0 0 0 1px rgba(59, 130, 246, 0.2);
        }

        .card-header h3 {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        /* Profile Photo Container */
        .profile-photo-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-bottom: 40px;
            position: relative;
        }

        .avatar-wrapper {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            padding: 6px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            position: relative;
            cursor: pointer;
            transition: var(--transition);
        }

        .avatar-wrapper:hover {
            transform: scale(1.05) rotate(5deg);
        }

        .avatar-inner {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: var(--bg-light);
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 4px solid var(--card-glass);
        }

        .avatar-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .avatar-inner span {
            font-size: 3rem;
            font-weight: 800;
            color: var(--primary);
        }

        .upload-badge {
            position: absolute;
            bottom: 5px;
            right: 5px;
            width: 40px;
            height: 40px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 4px solid var(--card-glass);
            box-shadow: var(--shadow);
            transition: var(--transition);
        }

        /* Forms */
        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            display: block;
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text-muted);
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-wrapper i {
            position: absolute;
            left: 20px;
            color: var(--text-muted);
            transition: var(--transition);
        }

        .form-control {
            width: 100%;
            padding: 16px 20px 16px 52px;
            background: rgba(var(--primary-glow), 0.05);
            border: 2px solid transparent;
            border-radius: 16px;
            color: var(--text-main);
            font-size: 1rem;
            font-weight: 600;
            transition: var(--transition);
            outline: none;
        }

        .form-control:focus {
            background: var(--card-glass);
            border-color: var(--primary);
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.15);
        }

        .form-control:focus + i {
            color: var(--primary);
            transform: scale(1.1);
        }

        /* Buttons */
        .btn {
            padding: 16px 32px;
            border-radius: 16px;
            font-weight: 700;
            font-size: 1rem;
            text-decoration: none;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            cursor: pointer;
            border: none;
            width: 100%;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), #2563EB);
            color: white;
            box-shadow: 0 10px 20px -5px var(--primary-glow);
        }

        .btn-primary:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px var(--primary-glow);
        }

        .btn-accent {
            background: linear-gradient(135deg, var(--accent), #F59E0B);
            color: white;
            box-shadow: 0 10px 20px -5px var(--accent-glow);
        }

        .btn-accent:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px var(--accent-glow);
        }

        .btn-outline {
            background: var(--card-glass);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-glass);
            color: var(--text-main);
        }

        .btn-outline:hover {
            background: var(--bg-light);
            border-color: var(--primary);
            transform: translateY(-3px);
        }

        /* System Info */
        .info-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            background: rgba(var(--primary-glow), 0.05);
            border-radius: 16px;
            transition: var(--transition);
        }

        .info-item:hover {
            background: rgba(var(--primary-glow), 0.1);
            transform: translateX(8px);
        }

        .info-label {
            color: var(--text-muted);
            font-weight: 700;
            font-size: 0.9rem;
        }

        .info-value {
            font-weight: 800;
            color: var(--primary);
        }

        /* Animations */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Toast Container */
        .toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 9999;
        }

        /* Dark Mode Button */
        .theme-toggle {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-main);
            cursor: pointer;
            transition: var(--transition);
        }

        .theme-toggle:hover {
            transform: rotate(15deg);
            border-color: var(--primary);
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .main-content { margin-left: 0; padding: 24px; }
            .settings-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body class="<%= (typeof user !== 'undefined' && user && user.theme === 'dark') ? 'dark-mode-active' : '' %>">
    
    <%- include('./partials/admin-sidebar', { currentPage: 'settings', user: typeof user !== 'undefined' ? user : null }) %>

    <!-- MESH BACKGROUND -->
    <div class="mesh-bg"></div>

    <main class="main-content">
        <!-- TOP BAR -->
        <div class="top-bar">
            <div class="page-title">
                <h1>Pengaturan & Profil</h1>
                <p>Kelola data akun admin dan konfigurasi keamanan</p>
            </div>
            <div class="top-actions">
                <div class="theme-toggle" onclick="toggleTheme()" title="Ganti Tema">
                    <i class="fas fa-moon" id="themeIcon"></i>
                </div>
            </div>
        </div>

        <div class="settings-grid">
            <!-- PROFILE SECTION -->
            <div class="glass-card">
                <div class="card-header">
                    <div class="header-icon">
                        <i class="fas fa-user-shield"></i>
                    </div>
                    <h3>Profil Admin</h3>
                </div>

                <div class="profile-photo-section">
                    <div class="avatar-wrapper" onclick="document.getElementById('profilePhotoInput').click()">
                        <div class="avatar-inner">
                            <% if (user && (user.profile_photo || user.profile_image)) { %>
                                <img src="<%= user.profile_photo || user.profile_image %>" alt="Profile" id="previewImg">
                            <% } else { %>
                                <span id="previewInitial"><%= user && user.name ? user.name[0].toUpperCase() : 'A' %></span>
                                <img src="" alt="Profile" id="previewImg" style="display: none;">
                            <% } %>
                        </div>
                        <div class="upload-badge">
                            <i class="fas fa-camera"></i>
                        </div>
                    </div>
                    <input type="file" id="profilePhotoInput" style="display: none;" accept="image/*" onchange="handlePhotoChange(event)">
                    <p style="margin-top: 16px; font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">Pilih foto untuk mengubah</p>
                </div>

                <form id="profileForm">
                    <div class="form-group">
                        <label class="form-label">Nama Lengkap</label>
                        <div class="input-wrapper">
                            <input type="text" name="name" class="form-control" value="<%= user ? user.name : '' %>" required>
                            <i class="fas fa-user"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Alamat Email</label>
                        <div class="input-wrapper">
                            <input type="email" name="email" class="form-control" value="<%= user ? user.email : '' %>" required>
                            <i class="fas fa-envelope"></i>
                        </div>
                    </div>

                    <div style="margin-top: 40px;">
                        <button type="submit" class="btn btn-primary" id="saveProfileBtn">
                            <i class="fas fa-save"></i> Perbarui Profil
                        </button>
                    </div>
                </form>
            </div>

            <!-- SECURITY SECTION -->
            <div class="glass-card">
                <div class="card-header">
                    <div class="header-icon" style="background: rgba(255, 159, 67, 0.1); color: var(--accent); box-shadow: inset 0 0 0 1px rgba(255, 159, 67, 0.2);">
                        <i class="fas fa-key"></i>
                    </div>
                    <h3>Keamanan Akun</h3>
                </div>

                <form id="passwordForm">
                    <div class="form-group">
                        <label class="form-label">Password Baru</label>
                        <div class="input-wrapper">
                            <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="Minimal 6 karakter" required>
                            <i class="fas fa-lock"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Konfirmasi Password</label>
                        <div class="input-wrapper">
                            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control" placeholder="Ulangi password baru" required>
                            <i class="fas fa-check-circle"></i>
                        </div>
                    </div>

                    <div style="margin-top: 40px;">
                        <button type="submit" class="btn btn-accent" id="savePasswordBtn">
                            <i class="fas fa-shield-alt"></i> Ganti Password
                        </button>
                    </div>
                </form>

                <div style="margin-top: 48px; padding-top: 32px; border-top: 1px solid var(--border-glass);">
                    <div class="card-header" style="margin-bottom: 24px;">
                        <div class="header-icon" style="background: rgba(59, 130, 246, 0.1); color: var(--primary);">
                            <i class="fas fa-microchip"></i>
                        </div>
                        <h3 style="font-size: 1.2rem;">Info Sistem</h3>
                    </div>
                    <div class="info-list">
                        <div class="info-item">
                            <span class="info-label">Versi App</span>
                            <span class="info-value">1.0.4-PREMIUM</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Engine</span>
                            <span class="info-value">Node.js v20</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Status Server</span>
                            <span class="info-value" style="color: #10B981;">Online</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div class="toast-container" id="toastContainer"></div>

    <script>
        // Theme Management
        function initTheme() {
            // Check localStorage first for immediate sync
            const localTheme = localStorage.getItem('theme');
            if (localTheme) {
                if (localTheme === 'dark') {
                    document.body.classList.add('dark-mode-active');
                } else {
                    document.body.classList.remove('dark-mode-active');
                }
            }
            
            const isDark = document.body.classList.contains('dark-mode-active');
            updateThemeIcon(isDark);
        }

        function toggleTheme() {
            document.body.classList.toggle('dark-mode-active');
            const isDark = document.body.classList.contains('dark-mode-active');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateThemeIcon(isDark);
            
            // Optional: Send theme update to server
            fetch('/api/profile', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ theme: isDark ? 'dark' : 'light' })
            }).catch(err => console.error('Failed to sync theme:', err));
        }

        function updateThemeIcon(isDark) {
            const icon = document.getElementById('themeIcon');
            icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        }

        // Profile Update
        document.getElementById('profileForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('saveProfileBtn');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Memproses...';

            try {
                const response = await fetch('/api/profile', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: this.name.value,
                        email: this.email.value
                    })
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Berhasil!',
                        text: 'Profil admin telah diperbarui.',
                        background: document.body.classList.contains('dark-mode-active') ? '#0F172A' : '#FFFFFF',
                        color: document.body.classList.contains('dark-mode-active') ? '#F8FAFC' : '#1E293B',
                        confirmButtonColor: '#3B82F6'
                    }).then(() => window.location.reload());
                } else {
                    showToast(result.message || 'Gagal memperbarui profil', 'error');
                }
            } catch (error) {
                showToast('Kesalahan koneksi ke server', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });

        // Password Change
        document.getElementById('passwordForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('savePasswordBtn');
            const newPwd = document.getElementById('newPassword').value;
            const confirmPwd = document.getElementById('confirmPassword').value;

            if (newPwd !== confirmPwd) {
                return showToast('Konfirmasi password tidak cocok!', 'error');
            }

            btn.disabled = true;
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Mengamankan...';

            try {
                const response = await fetch('/api/profile/password', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newPassword: newPwd, confirmPassword: confirmPwd })
                });

                const result = await response.json();

                if (result.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Keamanan Diperbarui',
                        text: 'Password Anda berhasil diganti.',
                        confirmButtonColor: '#FF9F43'
                    });
                    this.reset();
                } else {
                    showToast(result.message || 'Gagal mengganti password', 'error');
                }
            } catch (error) {
                showToast('Kesalahan sistem', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });

        // Photo Upload Handler
        async function handlePhotoChange(event) {
            const file = event.target.files[0];
            if (!file) return;

            // Preview
            const reader = new FileReader();
            reader.onload = (e) => {
                const previewImg = document.getElementById('previewImg');
                const previewInitial = document.getElementById('previewInitial');
                if (previewImg) {
                    previewImg.src = e.target.result;
                    previewImg.style.display = 'block';
                }
                if (previewInitial) previewInitial.style.display = 'none';
            };
            reader.readAsDataURL(file);

            const confirm = await Swal.fire({
                title: 'Ganti Foto Profil?',
                text: 'Foto profil admin akan diperbarui secara global.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, Ganti',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#3B82F6',
                background: document.body.classList.contains('dark-mode-active') ? '#0F172A' : '#FFFFFF',
                color: document.body.classList.contains('dark-mode-active') ? '#F8FAFC' : '#1E293B'
            });

            if (confirm.isConfirmed) {
                const formData = new FormData();
                formData.append('profile_photo', file);

                try {
                    Swal.fire({
                        title: 'Mengunggah...',
                        didOpen: () => Swal.showLoading(),
                        allowOutsideClick: false
                    });

                    const response = await fetch('/api/profile/photo', {
                        method: 'POST',
                        body: formData
                    });

                    const result = await response.json();

                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Foto Terunggah',
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => window.location.reload());
                    } else {
                        showToast(result.message || 'Gagal upload foto', 'error');
                    }
                } catch (error) {
                    showToast('Gagal terhubung ke server', 'error');
                }
            } else {
                window.location.reload();
            }
        }

        // Custom Toast
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.style.cssText = `
                padding: 16px 24px;
                background: ${type === 'success' ? 'var(--primary)' : '#EF4444'};
                color: white;
                border-radius: 14px;
                margin-bottom: 12px;
                font-weight: 700;
                box-shadow: 0 10px 20px rgba(0,0,0,0.2);
                display: flex;
                align-items: center;
                gap: 12px;
                animation: slideInRight 0.4s ease;
            `;
            toast.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'}"></i>
                <span>${message}</span>
            `;
            document.getElementById('toastContainer').appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100px)';
                toast.style.transition = '0.4s ease';
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        }

        // Animation Style
        const style = document.createElement('style');
        style.innerHTML = `
            @keyframes slideInRight {
                from { transform: translateX(100%); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
        `;
        document.head.appendChild(style);

        document.addEventListener('DOMContentLoaded', initTheme);
    </script>
</body>
</html>
