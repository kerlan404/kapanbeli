<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Catatan - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-dark: #1D4ED8;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-sidebar-hover: #f1f5f9;
            --bg-sidebar-active: #e2e8f0;
            --text-sidebar: #475569;
            --text-sidebar-active: #000000;
            --text-sidebar-heading: #000000;
            --sidebar-border: #000000;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #000000;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
            --radius: 0px;
            --sidebar-width: 260px;
            --header-height: 70px;
            --content-padding: 40px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1A1D23;
            --bg-body: #0F1115;
            --bg-card: #1A1D23;
            --text-main: #FFFFFF;
            --text-muted: #9CA3AF;
            --border-color: #FFFFFF;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            transition: background 0.3s;
        }

        /* Sidebar Overlay */
        .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
        .sidebar-overlay.active { display: block; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width); flex: 1; padding: var(--content-padding); transition: margin-left 0.3s ease;
        }

        .top-bar {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 40px; gap: 20px; flex-wrap: wrap;
        }
        .page-title { font-size: 2.2rem; font-weight: 900; letter-spacing: -1.5px; text-transform: uppercase; }
        .page-subtitle { font-size: 1.1rem; color: var(--text-muted); margin-top: 5px; font-weight: 500; }
        
        .top-actions { display: flex; gap: 15px; align-items: center; }

        /* Buttons */
        .btn {
            padding: 14px 28px; border: 4px solid var(--border-color); border-radius: var(--radius);
            font-weight: 800; font-size: 1rem; cursor: pointer;
            display: inline-flex; align-items: center; gap: 12px;
            transition: all 0.2s; font-family: inherit;
            text-transform: uppercase; letter-spacing: 0.5px;
            box-shadow: var(--shadow-brutal-sm);
        }
        .btn:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0px var(--border-color); }
        .btn:active { transform: translate(0, 0); box-shadow: 2px 2px 0px var(--border-color); }

        .btn-primary { background: var(--primary-blue); color: white; }
        .btn-outline { background: var(--bg-card); color: var(--text-main); }
        .btn-success { background: var(--accent-green); color: white; }
        .btn-warning { background: var(--primary-orange); color: white; }
        .btn-danger { background: var(--accent-red); color: white; }
        .btn-sm { padding: 8px 16px; font-size: 0.85rem; border-width: 3px; }
        
        .theme-toggle { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }

        /* Stats Grid */
        .stats-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 25px; margin-bottom: 40px;
        }
        .stat-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 30px; box-shadow: var(--shadow-brutal);
            transition: all 0.2s;
        }
        .stat-card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }
        .stat-card h3 { font-size: 2.8rem; font-weight: 900; margin-bottom: 5px; line-height: 1; }
        .stat-card p { font-size: 0.95rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

        /* Panel Card */
        .panel-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 35px; box-shadow: var(--shadow-brutal);
            margin-bottom: 40px;
        }
        .panel-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
            flex-wrap: wrap; gap: 20px;
        }
        .panel-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; }

        /* Search & Filters */
        .filters-container {
            display: flex; gap: 20px; width: 100%; flex-wrap: wrap;
        }
        .filter-group { flex: 1; min-width: 200px; }
        .filter-label { display: block; font-weight: 900; margin-bottom: 10px; text-transform: uppercase; font-size: 0.85rem; }
        
        .form-control {
            width: 100%; padding: 15px 20px;
            border: 3px solid var(--border-color); border-radius: var(--radius);
            background: var(--bg-card); color: var(--text-main);
            font-size: 1rem; font-weight: 700; box-shadow: var(--shadow-brutal-sm);
            transition: all 0.2s; outline: none;
        }
        .form-control:focus { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); border-color: var(--primary-blue); }

        /* Table */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th {
            text-align: left; padding: 20px; font-weight: 900;
            color: var(--text-main); font-size: 0.9rem; text-transform: uppercase;
            letter-spacing: 1px; border-bottom: 4px solid var(--border-color);
            background: rgba(0,0,0,0.05);
        }
        body.dark-mode-active th { background: rgba(255,255,255,0.05); }
        td { padding: 20px; border-bottom: 3px solid var(--border-color); font-weight: 700; font-size: 1rem; }
        tr:hover { background: rgba(0,0,0,0.02); }
        body.dark-mode-active tr:hover { background: rgba(255,255,255,0.02); }

        .badge {
            display: inline-block; padding: 6px 14px; border: 3px solid var(--border-color);
            font-size: 0.8rem; font-weight: 900; text-transform: uppercase;
            box-shadow: 3px 3px 0px var(--border-color);
        }
        .badge-success { background: var(--accent-green); color: white; }
        .badge-warning { background: var(--primary-orange); color: white; }
        .badge-danger { background: var(--accent-red); color: white; }
        .badge-info { background: var(--primary-blue); color: white; }

        /* Action Buttons */
        .btn-icon {
            width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;
            border: 3px solid var(--border-color); background: var(--bg-card);
            color: var(--text-main); font-size: 1.1rem; transition: all 0.2s;
            box-shadow: 4px 4px 0px var(--border-color);
            cursor: pointer;
        }
        .btn-icon:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); color: var(--primary-blue); border-color: var(--primary-blue); }

        /* Modal */
        .modal {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center; padding: 20px;
            opacity: 0; transition: all 0.2s;
        }
        .modal.active { display: flex; opacity: 1; }
        .modal-content {
            background: var(--bg-card); border: 6px solid var(--border-color);
            width: 100%; max-width: 800px; max-height: 90vh; overflow-y: auto;
            position: relative; box-shadow: 20px 20px 0px rgba(0,0,0,0.5);
            padding: 40px; transform: scale(0.95); transition: all 0.2s;
        }
        .modal.active .modal-content { transform: scale(1); }
        .modal-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 35px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
        }
        .modal-title { font-size: 1.8rem; font-weight: 900; text-transform: uppercase; display: flex; align-items: center; gap: 15px; }
        .modal-close { font-size: 2.5rem; cursor: pointer; color: var(--text-main); line-height: 1; transition: transform 0.2s; background: none; border: none; }
        .modal-close:hover { transform: rotate(90deg); color: var(--accent-red); }

        .note-detail-card {
            background: rgba(0,0,0,0.02); border: 4px solid var(--border-color);
            padding: 30px; margin-bottom: 30px;
        }
        body.dark-mode-active .note-detail-card { background: rgba(255,255,255,0.02); }
        .detail-label { font-size: 0.85rem; font-weight: 900; color: var(--text-muted); text-transform: uppercase; margin-bottom: 8px; }
        .detail-value { font-size: 1.2rem; font-weight: 800; color: var(--text-main); margin-bottom: 25px; }
        .note-body { font-size: 1.1rem; line-height: 1.8; color: var(--text-main); white-space: pre-wrap; font-weight: 500; }

        /* Pagination */
        .pagination-container { display: flex; justify-content: space-between; align-items: center; margin-top: 30px; padding-top: 20px; border-top: 4px solid var(--border-color); flex-wrap: wrap; gap: 20px; }
        .pagination-info { font-weight: 800; color: var(--text-muted); font-size: 0.95rem; }
        .pagination { display: flex; gap: 10px; list-style: none; }
        .pagination button {
            min-width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;
            border: 3px solid var(--border-color); background: var(--bg-card); font-weight: 900;
            cursor: pointer; transition: all 0.2s; box-shadow: 4px 4px 0px var(--border-color);
            padding: 0 15px; font-family: inherit; text-transform: uppercase;
        }
        .pagination button:hover:not(:disabled) { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .pagination button.active { background: var(--primary-blue); color: white; }
        .pagination button:disabled { opacity: 0.4; cursor: not-allowed; }

        /* Loading */
        .loading-state { text-align: center; padding: 60px; }
        .loading-state i { font-size: 3rem; color: var(--primary-blue); margin-bottom: 20px; }

        /* Responsive */
        .menu-toggle { display: none; font-size: 1.5rem; cursor: pointer; color: var(--text-main); }
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 25px; }
            .menu-toggle { display: block; }
        }
    </style>
</head>
<body>
    <%- include('./partials/admin-sidebar', { currentPage: 'notes', user: typeof user !== 'undefined' ? user : null }) %>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <div>
                    <h1 class="page-title">📝 Monitoring Catatan</h1>
                    <p class="page-subtitle">Monitoring catatan pengguna untuk efisiensi stok</p>
                </div>
            </div>
            <div class="top-actions">
                <button class="btn btn-outline theme-toggle" onclick="toggleTheme()" id="themeToggleBtn">
                    <i class="fas fa-moon"></i>
                </button>
                <button class="btn btn-primary" onclick="loadNotes(true)">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <h3 id="statTotal">0</h3>
                <p>Total Catatan</p>
            </div>
            <div class="stat-card">
                <h3 id="statCompleted" style="color: var(--accent-green);">0</h3>
                <p>Selesai</p>
            </div>
            <div class="stat-card">
                <h3 id="statPending" style="color: var(--primary-orange);">0</h3>
                <p>Pending</p>
            </div>
            <div class="stat-card">
                <h3 id="statBelumSelesai" style="color: var(--accent-red);">0</h3>
                <p>Belum Selesai</p>
            </div>
        </div>

        <!-- Panel Card -->
        <div class="panel-card">
            <div class="panel-header">
                <h3 class="panel-title">Daftar Catatan Pengguna</h3>
                <div class="filters-container">
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-search"></i> Cari</label>
                        <input type="text" id="searchInput" class="form-control" placeholder="Cari judul, isi, atau nama user..." onkeyup="handleSearch(event)">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-check-circle"></i> Status</label>
                        <select id="statusFilter" class="form-control" onchange="loadNotes()">
                            <option value="">Semua Status</option>
                            <option value="Selesai">Selesai</option>
                            <option value="Pending">Pending</option>
                            <option value="Belum Selesai">Belum Selesai</option>
                        </select>
                    </div>
                    <div style="display: flex; gap: 10px; align-items: flex-end;">
                        <button class="btn btn-outline" onclick="resetFilters()">
                            <i class="fas fa-redo"></i> Reset
                        </button>
                    </div>
                </div>
            </div>

            <!-- Loading State -->
            <div id="loadingState" class="loading-state">
                <i class="fas fa-circle-notch fa-spin"></i>
                <p style="font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Memuat data catatan...</p>
            </div>

            <!-- Table -->
            <div class="table-responsive">
                <table id="notesTable" style="display: none;">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Judul</th>
                            <th>User</th>
                            <th>Status</th>
                            <th>Dibuat</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="notesTableBody">
                    </tbody>
                </table>
            </div>

            <!-- Empty State -->
            <div id="emptyState" style="text-align: center; padding: 60px 20px; display: none;">
                <i class="fas fa-sticky-note" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 15px;"></i>
                <p style="font-weight: 800;">Belum ada catatan dari pengguna</p>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" id="pagination" style="display: none;">
                <div class="pagination-info" id="paginationInfo"></div>
                <div class="pagination" id="paginationButtons"></div>
            </div>
        </div>
    </main>

    <!-- Detail Modal -->
    <div id="noteModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">
                    <i class="fas fa-file-alt" style="color: var(--primary-blue);"></i>
                    <span>Detail Catatan</span>
                </h3>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <div class="note-detail-card">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div>
                            <div class="detail-label">Pengguna</div>
                            <div class="detail-value" id="noteUserName">-</div>
                        </div>
                        <div>
                            <div class="detail-label">Status</div>
                            <div id="noteViewStatus">-</div>
                        </div>
                    </div>
                    
                    <div class="detail-label">Judul Catatan</div>
                    <div class="detail-value" id="noteViewTitle" style="font-size: 1.5rem;">-</div>

                    <div class="detail-label">Isi Catatan</div>
                    <div class="note-body" id="noteViewContent">-</div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <div class="detail-label">Dibuat Pada</div>
                        <div id="noteViewCreated" style="font-weight: 700;">-</div>
                    </div>
                    <div>
                        <div class="detail-label">Pembaruan Terakhir</div>
                        <div id="noteViewUpdated" style="font-weight: 700;">-</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="display: flex; justify-content: flex-end; margin-top: 30px;">
                <button class="btn btn-outline" onclick="closeModal()">Tutup</button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        let currentPage = 1;
        let currentSearch = '';
        let currentStatus = '';
        let searchTimer = null;

        // Theme Toggle Bridge
        function toggleTheme() {
            if (window.toggleAppTheme) {
                window.toggleAppTheme();
            }
        }

        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        });

        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            
            loadNotes();
            loadNoteStatistics();
        });

        async function loadNoteStatistics() {
            try {
                const response = await fetch('/api/admin/notes/statistics', { credentials: 'same-origin' });
                const data = await response.json();
                if (data.success) {
                    updateStats(data.data);
                }
            } catch (error) { console.error('Error stats:', error); }
        }

        async function loadNotes(forceRefresh = false) {
            const loadingState = document.getElementById('loadingState');
            const notesTable = document.getElementById('notesTable');
            const emptyState = document.getElementById('emptyState');
            const pagination = document.getElementById('pagination');

            loadingState.style.display = 'block';
            notesTable.style.display = 'none';
            emptyState.style.display = 'none';
            pagination.style.display = 'none';

            try {
                const search = document.getElementById('searchInput').value;
                const status = document.getElementById('statusFilter').value;
                const url = `/api/admin/notes?page=${currentPage}&search=${encodeURIComponent(search)}&status=${status}`;
                
                const response = await fetch(url, { credentials: 'same-origin' });
                const data = await response.json();

                loadingState.style.display = 'none';

                if (data.success) {
                    if (!data.data || data.data.length === 0) {
                        emptyState.style.display = 'block';
                    } else {
                        notesTable.style.display = 'table';
                        renderNotesTable(data.data);
                        renderPagination(data.pagination);
                    }
                }
            } catch (error) {
                console.error('Error loading notes:', error);
                loadingState.innerHTML = '<i class="fas fa-exclamation-triangle" style="color: var(--accent-red);"></i><p>Gagal memuat data</p>';
            }
        }

        function updateStats(stats) {
            document.getElementById('statTotal').textContent = stats.total || 0;
            document.getElementById('statCompleted').textContent = stats.selesai || 0;
            document.getElementById('statPending').textContent = stats.pending || 0;
            document.getElementById('statBelumSelesai').textContent = stats.belumSelesai || 0;
        }

        function renderNotesTable(notes) {
            const tbody = document.getElementById('notesTableBody');
            tbody.innerHTML = notes.map(note => `
                <tr>
                    <td>#${note.id}</td>
                    <td><div style="font-weight: 800; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${note.title}</div></td>
                    <td>
                        <div style="font-weight: 800;">${note.user_name}</div>
                        <div style="font-size: 0.8rem; color: var(--text-muted);">${note.user_email}</div>
                    </td>
                    <td>
                        <span class="badge ${getStatusClass(note.status)}">${note.status}</span>
                    </td>
                    <td style="font-size: 0.9rem;">${new Date(note.created_at).toLocaleDateString('id-ID')}</td>
                    <td>
                        <button class="btn-icon" onclick="viewNoteDetail(${JSON.stringify(note).replace(/"/g, '&quot;')})" title="Lihat Detail">
                            <i class="fas fa-eye"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function getStatusClass(status) {
            switch(status) {
                case 'Selesai': return 'badge-success';
                case 'Pending': return 'badge-warning';
                default: return 'badge-danger';
            }
        }

        function renderPagination(p) {
            const container = document.getElementById('pagination');
            const info = document.getElementById('paginationInfo');
            const buttons = document.getElementById('paginationButtons');

            if (p.total_pages <= 1) {
                container.style.display = 'none';
                return;
            }

            container.style.display = 'flex';
            info.textContent = `Menampilkan ${((p.current_page - 1) * p.limit) + 1} - ${Math.min(p.current_page * p.limit, p.total_items)} dari ${p.total_items} data`;

            let html = `<button onclick="goToPage(${p.current_page - 1})" ${p.current_page === 1 ? 'disabled' : ''}>Prev</button>`;
            
            for (let i = 1; i <= p.total_pages; i++) {
                if (i === 1 || i === p.total_pages || (i >= p.current_page - 2 && i <= p.current_page + 2)) {
                    html += `<button class="${i === p.current_page ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                } else if (i === p.current_page - 3 || i === p.current_page + 3) {
                    html += `<button disabled>...</button>`;
                }
            }

            html += `<button onclick="goToPage(${p.current_page + 1})" ${p.current_page === p.total_pages ? 'disabled' : ''}>Next</button>`;
            buttons.innerHTML = html;
        }

        function goToPage(page) {
            currentPage = page;
            loadNotes();
        }

        function handleSearch() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => {
                currentPage = 1;
                loadNotes();
            }, 500);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('statusFilter').value = '';
            currentPage = 1;
            loadNotes();
        }

        function viewNoteDetail(note) {
            document.getElementById('noteUserName').textContent = note.user_name;
            document.getElementById('noteViewStatus').innerHTML = `<span class="badge ${getStatusClass(note.status)}">${note.status}</span>`;
            document.getElementById('noteViewTitle').textContent = note.title;
            document.getElementById('noteViewContent').textContent = note.content;
            document.getElementById('noteViewCreated').textContent = new Date(note.created_at).toLocaleString('id-ID');
            document.getElementById('noteViewUpdated').textContent = new Date(note.updated_at).toLocaleString('id-ID');
            
            document.getElementById('noteModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('noteModal').classList.remove('active');
        }
    </script>
</body>
</html>
