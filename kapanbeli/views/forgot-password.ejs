<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lupa Password - Kapan Beli</title>
    
    <!-- Google Fonts: Poppins & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #3B82F6;
            --accent: #FF9F43;
            --text-main: #FFFFFF;
            --text-muted: #94A3B8;
            --glass-bg: rgba(15, 23, 42, 0.6);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-panel: rgba(255, 255, 255, 0.03);
            --input-bg: rgba(0, 0, 0, 0.2);
        }

        body.light-mode {
            --text-main: #1E293B;
            --text-muted: #64748B;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(255, 255, 255, 0.5);
            --glass-panel: rgba(255, 255, 255, 0.4);
            --input-bg: rgba(255, 255, 255, 0.6);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            height: 100vh;
            overflow: hidden;
            background: url('/images/bahan%20dapur.jpg') no-repeat center center fixed;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(2, 6, 23, 0.8), rgba(2, 6, 23, 0.4));
            z-index: 1;
            transition: 0.5s ease;
        }
        body.light-mode::before {
            background: linear-gradient(135deg, rgba(248, 250, 252, 0.85), rgba(248, 250, 252, 0.5));
        }

        .auth-wrapper {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 1000px;
            height: 600px;
            margin: 20px;
            display: flex;
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
            animation: slideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            overflow: hidden;
            transition: 0.5s ease;
        }

        @keyframes slideIn {
            0% { transform: translateY(40px) scale(0.95); opacity: 0; }
            100% { transform: translateY(0) scale(1); opacity: 1; }
        }

        @keyframes slideOut {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            100% { transform: translateY(-40px) scale(0.95); opacity: 0; }
        }

        .slide-out {
            animation: slideOut 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards !important;
        }

        /* LEFT PANEL (Branding) */
        .brand-panel {
            flex: 1;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
            color: var(--text-main);
        }

        .brand-panel::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(255, 159, 67, 0.15) 0%, transparent 60%);
            animation: spin 20s linear infinite;
            z-index: -1;
        }

        @keyframes spin { 100% { transform: rotate(360deg); } }

        .brand-panel i.main-icon {
            font-size: 3.5rem;
            background: linear-gradient(135deg, var(--accent), #FF7675);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 24px;
            filter: drop-shadow(0 10px 15px rgba(255, 159, 67, 0.3));
        }

        .brand-panel h1 { font-family: 'Outfit', sans-serif; font-size: 3.2rem; font-weight: 800; line-height: 1.1; margin-bottom: 16px; letter-spacing: -1px; }
        .brand-panel p { font-size: 1.05rem; color: var(--text-muted); line-height: 1.6; max-width: 90%; }

        /* RIGHT PANEL (Form) */
        .form-panel {
            flex: 1.1;
            background: var(--glass-panel);
            padding: 50px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-left: 1px solid var(--glass-border);
            position: relative;
            transition: 0.5s ease;
        }

        .form-header { margin-bottom: 35px; }
        .form-header h2 { font-size: 2.2rem; font-family: 'Outfit', sans-serif; font-weight: 700; color: var(--text-main); letter-spacing: -0.5px; }
        .form-header p { color: var(--text-muted); margin-top: 5px; font-size: 0.95rem; }

        .input-group { margin-bottom: 20px; }
        .input-wrapper { position: relative; }
        .input-wrapper i.icon-left { position: absolute; left: 20px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 1.1rem; }
        .input-wrapper input {
            width: 100%;
            padding: 18px 50px;
            background: var(--input-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            color: var(--text-main);
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
        }
        body.light-mode .input-wrapper input { color: #1E293B; border-color: rgba(0,0,0,0.1); }
        
        .input-wrapper input:focus {
            border-color: var(--primary);
            background: rgba(59, 130, 246, 0.1);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

        .btn-submit {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, var(--accent), #FF7675);
            color: white;
            border: none;
            border-radius: 16px;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(255, 159, 67, 0.3);
            transition: all 0.3s ease;
            margin-top: 10px;
        }
        .btn-submit:hover { transform: translateY(-3px); box-shadow: 0 15px 25px rgba(255, 159, 67, 0.4); }

        .form-links { text-align: center; margin-top: 30px; color: var(--text-muted); font-size: 0.95rem; }
        .form-links a { color: var(--primary); text-decoration: none; font-weight: 700; transition: 0.3s; }
        .form-links a:hover { text-shadow: 0 0 10px rgba(59, 130, 246, 0.5); }

        .theme-toggle {
            position: absolute; top: 30px; right: 30px;
            background: var(--input-bg); border: 1px solid var(--glass-border);
            width: 44px; height: 44px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            color: var(--text-main); cursor: pointer; transition: 0.3s; z-index: 10;
        }
        .theme-toggle:hover { color: var(--accent); border-color: var(--accent); transform: rotate(15deg); }

        /* ALERT */
        .alert-box { padding: 14px 20px; border-radius: 14px; margin-bottom: 20px; font-size: 0.9rem; font-weight: 600; display: none; align-items: center; gap: 12px; }
        .alert-box.show { display: flex; animation: slideDown 0.3s ease; }
        .alert-error { background: rgba(239, 68, 68, 0.15); color: #FCA5A5; border: 1px solid rgba(239, 68, 68, 0.3); }
        body.light-mode .alert-error { color: #EF4444; }
        .alert-success { background: rgba(34, 197, 94, 0.15); color: #86EFAC; border: 1px solid rgba(34, 197, 94, 0.3); }
        body.light-mode .alert-success { color: #22C55E; }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        /* SUCCESS MESSAGE (Inside Form) */
        .success-message { text-align: center; display: none; flex-direction: column; align-items: center; justify-content: center; height: 100%; }
        .success-message i { font-size: 4rem; color: var(--accent); margin-bottom: 20px; filter: drop-shadow(0 10px 15px rgba(255, 159, 67, 0.3)); }
        .success-message h3 { font-size: 1.8rem; font-family: 'Outfit', sans-serif; color: var(--text-main); margin-bottom: 10px; }
        .success-message p { color: var(--text-muted); line-height: 1.6; margin-bottom: 30px; }

        @media (max-width: 900px) {
            .auth-wrapper { flex-direction: column; height: auto; max-height: 95vh; max-width: 500px; overflow-y: auto; }
            .brand-panel { padding: 40px; text-align: center; flex: none; border-bottom: 1px solid var(--glass-border); }
            .form-panel { padding: 40px; border-left: none; }
        }
    </style>
</head>
<body>

    <div class="auth-wrapper">
        <button class="theme-toggle" title="Ganti Mode" onclick="toggleTheme()">
            <i class="fas fa-sun" id="themeIcon"></i>
        </button>

        <!-- Kiri: Branding -->
        <div class="brand-panel">
            <i class="fas fa-key main-icon"></i>
            <h1>Lupa<br>Password?</h1>
            <p>Tenang saja. Kami akan membantu Anda memulihkan akses ke ruang kendali Kapan Beli Anda dengan cepat dan aman.</p>
        </div>

        <!-- Kanan: Form -->
        <div class="form-panel">
            <div id="authAlert" class="alert-box"></div>

            <div id="forgotFormContainer">
                <div class="form-header">
                    <h2>Reset Password</h2>
                    <p>Masukkan email Anda untuk menerima tautan pemulihan.</p>
                </div>

                <form onsubmit="handleForgotPassword(event)">
                    <div class="input-group">
                        <div class="input-wrapper">
                            <i class="fas fa-envelope icon-left"></i>
                            <input type="email" id="forgotEmail" placeholder="Alamat Email" required>
                        </div>
                    </div>

                    <button type="submit" class="btn-submit">Kirim Tautan Reset</button>
                </form>

                <div class="form-links">
                    Ingat password Anda? <a href="/auth" onclick="navigateSmooth(event, '/auth')">Kembali ke Login</a>
                </div>
            </div>

            <!-- Pesan Sukses (Tersembunyi Awalnya) -->
            <div id="successMessage" class="success-message">
                <i class="fas fa-paper-plane"></i>
                <h3>Tautan Terkirim!</h3>
                <p>Kami telah mengirimkan tautan untuk mengatur ulang kata sandi Anda ke kotak masuk email Anda. Tautan tersebut akan kedaluwarsa dalam 1 jam.</p>
                <a href="/auth" class="btn-submit" style="text-align: center; text-decoration: none; display: inline-block;" onclick="navigateSmooth(event, '/auth')">Kembali ke Login</a>
            </div>
        </div>
    </div>

    <script>
        // --- THEME LOGIC ---
        const body = document.body;
        const themeIcon = document.getElementById('themeIcon');
        
        function initTheme() {
            if (localStorage.getItem('theme') === 'light') {
                body.classList.add('light-mode');
                themeIcon.className = 'fas fa-moon';
            } else {
                body.classList.remove('light-mode');
                themeIcon.className = 'fas fa-sun';
            }
        }
        initTheme();

        function toggleTheme() {
            if (body.classList.contains('light-mode')) {
                body.classList.remove('light-mode');
                localStorage.setItem('theme', 'dark');
                themeIcon.className = 'fas fa-sun';
            } else {
                body.classList.add('light-mode');
                localStorage.setItem('theme', 'light');
                themeIcon.className = 'fas fa-moon';
            }
        }

        // --- ALERT ---
        function showAlert(msg, type = 'error') {
            const alertBox = document.getElementById('authAlert');
            alertBox.className = `alert-box show ${type === 'error' ? 'alert-error' : 'alert-success'}`;
            alertBox.innerHTML = `<i class="fas ${type === 'error' ? 'fa-exclamation-triangle' : 'fa-check-circle'}"></i> <span>${msg}</span>`;
        }
        function hideAlert() { document.getElementById('authAlert').classList.remove('show'); }

        // --- SMOOTH NAVIGATION ---
        function navigateSmooth(e, url) {
            e.preventDefault();
            const wrapper = document.querySelector('.auth-wrapper');
            wrapper.classList.add('slide-out');
            setTimeout(() => {
                window.location.href = url;
            }, 400);
        }

        // --- FORGOT PASSWORD HANDLER ---
        async function handleForgotPassword(e) {
            e.preventDefault();
            hideAlert();

            const email = document.getElementById('forgotEmail').value.trim();

            if (!email) return showAlert('Mohon masukkan email Anda.');

            const btn = document.querySelector('.btn-submit');
            const originalText = btn.innerText;
            btn.innerText = 'Mengirim...';
            btn.disabled = true;

            try {
                const response = await fetch('/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });

                const data = await response.json();

                if (data.success) {
                    // Sembunyikan form dan tampilkan pesan sukses
                    document.getElementById('forgotFormContainer').style.display = 'none';
                    document.getElementById('successMessage').style.display = 'flex';
                } else {
                    showAlert(data.message, 'error');
                    btn.innerText = originalText;
                    btn.disabled = false;
                }
            } catch (error) {
                showAlert('Gagal terhubung ke server. Silakan coba lagi.');
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>