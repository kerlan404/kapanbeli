<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Broadcast Pengumuman - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-dark: #1D4ED8;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-sidebar-hover: #f1f5f9;
            --bg-sidebar-active: #e2e8f0;
            --text-sidebar: #475569;
            --text-sidebar-active: #000000;
            --text-sidebar-heading: #000000;
            --sidebar-border: #000000;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #000000;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
            --sidebar-width: 260px;
            --header-height: 70px;
            --content-padding: 40px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1a1d23;
            --bg-body: #0F1115;
            --bg-card: #1a1d23;
            --text-main: #FFFFFF;
            --text-muted: #9CA3AF;
            --border-color: #FFFFFF;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }
        body { background: var(--bg-body); color: var(--text-main); transition: background 0.3s; }

        /* Sidebar */
        .sidebar {
            position: fixed; left: 0; top: 0; bottom: 0;
            width: var(--sidebar-width); background: var(--bg-sidebar);
            border-right: 4px solid var(--border-color);
            z-index: 1000; overflow-y: auto; transition: all 0.3s ease;
        }
        .sidebar-header {
            padding: 24px; border-bottom: 4px solid var(--border-color);
            display: flex; align-items: center; gap: 12px;
            font-size: 1.4rem; font-weight: 800; color: var(--text-sidebar-heading);
            letter-spacing: -1px;
        }
        .sidebar-header i { color: var(--primary-orange); font-size: 1.8rem; }
        
        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width); min-height: 100vh;
            transition: margin-left 0.3s ease;
        }

        /* Top Bar */
        .top-bar {
            height: var(--header-height); background: var(--bg-card);
            border-bottom: 4px solid var(--border-color);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 40px; position: sticky; top: 0; z-index: 100;
        }
        .menu-toggle { display: none; background: none; border: none; font-size: 1.5rem; color: var(--text-main); cursor: pointer; }
        .top-bar-title { font-size: 1.3rem; font-weight: 800; color: var(--text-main); text-transform: uppercase; letter-spacing: -0.5px; }
        .top-bar-actions { display: flex; align-items: center; gap: 15px; }

        /* Content Container */
        .content-container { padding: var(--content-padding); }

        /* Cards */
        .card {
            background: var(--bg-card); 
            padding: 40px; 
            margin-bottom: 30px;
            box-shadow: var(--shadow-brutal); border: 4px solid var(--border-color);
            transition: all 0.2s;
        }
        .card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }

        .card-header {
            margin-bottom: 30px; padding-bottom: 20px;
            border-bottom: 4px solid var(--border-color);
        }
        .card-title {
            font-size: 1.6rem; font-weight: 800; color: var(--text-main);
            display: flex; align-items: center; gap: 12px;
            text-transform: uppercase; letter-spacing: -0.5px;
        }
        .card-title i { color: var(--primary-orange); }
        .card-subtitle {
            font-size: 1rem; color: var(--text-muted); margin-top: 8px; font-weight: 500;
        }

        /* Form */
        .form-group { margin-bottom: 30px; }
        .form-label {
            display: block; font-weight: 800; margin-bottom: 12px;
            color: var(--text-main); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.5px;
        }
        .form-label i { margin-right: 8px; color: var(--primary-blue); }
        
        .form-input, .form-textarea, .form-select {
            width: 100%; padding: 16px 20px; border: 3px solid var(--border-color);
            border-radius: 0; font-family: inherit; font-size: 1rem;
            background: var(--bg-card); color: var(--text-main);
            transition: all 0.2s;
            box-shadow: var(--shadow-brutal-sm);
            font-weight: 600;
        }
        .form-input:focus, .form-textarea:focus, .form-select:focus {
            outline: none; transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--border-color);
        }
        .form-textarea { min-height: 180px; resize: vertical; }

        /* Radio Group */
        .radio-group { display: flex; gap: 20px; flex-wrap: wrap; }
        .radio-option {
            display: flex; align-items: center; gap: 10px;
            padding: 16px 24px; border: 3px solid var(--border-color);
            border-radius: 0; cursor: pointer; transition: all 0.2s;
            background: var(--bg-card);
            box-shadow: var(--shadow-brutal-sm);
            font-weight: 800;
            text-transform: uppercase;
        }
        .radio-option:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .radio-option input[type="radio"] { cursor: pointer; width: 20px; height: 20px; }
        .radio-option:has(input:checked) {
            background: var(--primary-blue);
            color: white;
            transform: translate(-4px, -4px);
            box-shadow: 8px 8px 0px var(--border-color);
        }
        .radio-option:has(input:checked) i { color: white !important; }

        /* Buttons */
        .btn {
            padding: 16px 32px; border: 3px solid var(--border-color); border-radius: 0;
            font-weight: 800; font-size: 1rem; cursor: pointer;
            display: inline-flex; align-items: center; gap: 12px;
            transition: all 0.2s; font-family: inherit;
            text-transform: uppercase; letter-spacing: 0.5px;
            box-shadow: var(--shadow-brutal-sm);
        }
        .btn:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0px var(--border-color); }
        .btn:active { transform: translate(0, 0); box-shadow: 2px 2px 0px var(--border-color); }

        .btn-primary { background: var(--primary-blue); color: white; }
        .btn-outline { background: var(--bg-card); color: var(--text-main); }
        .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }

        /* Stats Cards */
        .analytics-stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .analytics-stat-card {
            background: var(--bg-card);
            border: 4px solid var(--border-color);
            padding: 30px;
            box-shadow: var(--shadow-brutal);
            position: relative;
            transition: all 0.2s;
        }
        .analytics-stat-card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }

        .analytics-stat-card.info { border-color: var(--primary-blue); box-shadow: 8px 8px 0px var(--primary-blue); }
        .analytics-stat-card.info:hover { box-shadow: 12px 12px 0px var(--primary-blue); }
        .analytics-stat-card.success { border-color: var(--accent-green); box-shadow: 8px 8px 0px var(--accent-green); }
        .analytics-stat-card.success:hover { box-shadow: 12px 12px 0px var(--accent-green); }
        .analytics-stat-card.warning { border-color: var(--primary-orange); box-shadow: 8px 8px 0px var(--primary-orange); }
        .analytics-stat-card.warning:hover { box-shadow: 12px 12px 0px var(--primary-orange); }

        .analytics-stat-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }

        .analytics-stat-icon {
            width: 60px; height: 60px;
            border: 3px solid var(--border-color);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.8rem;
            background: var(--bg-card);
            box-shadow: 4px 4px 0px var(--border-color);
        }

        .analytics-stat-label {
            font-size: 1rem;
            color: var(--text-muted);
            margin-bottom: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .analytics-stat-value {
            font-size: 2.5rem;
            font-weight: 900;
            color: var(--text-main);
            letter-spacing: -1px;
            line-height: 1;
        }

        /* Toast Container */
        .toast-container {
            position: fixed; top: 30px; right: 30px;
            z-index: 9999; display: flex; flex-direction: column; gap: 15px;
        }
        .toast {
            padding: 20px 30px; border: 3px solid var(--border-color);
            background: var(--bg-card);
            display: flex; align-items: center; gap: 15px;
            box-shadow: 8px 8px 0px var(--border-color);
            min-width: 350px;
            font-weight: 800;
            animation: slideIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-transform: uppercase;
        }
        .toast.success { border-left: 12px solid var(--accent-green); }
        .toast.error { border-left: 12px solid var(--accent-red); }
        .toast.info { border-left: 12px solid var(--primary-blue); }

        @keyframes slideIn { from { transform: translateX(120%); } to { transform: translateX(0); } }

        /* Responsive */
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .menu-toggle { display: block; }
            .top-bar { padding: 0 20px; }
            .content-container { padding: 25px; }
        }

        /* SweetAlert2 Neubrutalism Custom Styles */
        .nb-popup {
            border: 4px solid var(--border-color) !important;
            border-radius: 0px !important;
            box-shadow: 8px 8px 0px var(--border-color) !important;
            background: var(--bg-card) !important;
            color: var(--text-main) !important;
            font-family: 'Plus Jakarta Sans', sans-serif !important;
            padding: 30px !important;
        }
        .nb-popup .swal2-title {
            color: var(--text-main) !important;
            font-weight: 900 !important;
            text-transform: uppercase !important;
            letter-spacing: -1px !important;
            font-size: 1.8rem !important;
            border-bottom: 4px solid var(--border-color) !important;
            padding-bottom: 15px !important;
            margin-bottom: 20px !important;
        }
        .nb-popup .swal2-html-container {
            color: var(--text-main) !important;
            font-family: inherit !important;
            font-size: 1.05rem !important;
            font-weight: 700 !important;
            margin: 0 !important;
            padding: 0 !important;
            text-align: left !important;
        }
        .nb-popup .swal2-actions {
            gap: 15px !important;
            margin-top: 25px !important;
            width: 100% !important;
            justify-content: flex-end !important;
        }
        .nb-popup .swal2-loader {
            border-color: var(--primary-blue) transparent var(--primary-blue) transparent !important;
        }
        
        /* SweetAlert2 Buttons standard override */
        .nb-popup .swal2-styled {
            margin: 0 !important;
        }
        .nb-btn {
            padding: 14px 28px !important;
            border: 3px solid var(--border-color) !important;
            border-radius: 0px !important;
            font-weight: 800 !important;
            text-transform: uppercase !important;
            letter-spacing: 0.5px !important;
            box-shadow: 4px 4px 0px var(--border-color) !important;
            transition: all 0.1s ease !important;
            font-family: inherit !important;
            font-size: 0.95rem !important;
            cursor: pointer !important;
            display: inline-flex !important;
            align-items: center !important;
            gap: 10px !important;
        }
        .nb-btn:hover {
            transform: translate(-2px, -2px) !important;
            box-shadow: 6px 6px 0px var(--border-color) !important;
        }
        .nb-btn:active {
            transform: translate(2px, 2px) !important;
            box-shadow: 0px 0px 0px var(--border-color) !important;
        }
        .nb-btn-primary {
            background: var(--primary-blue) !important;
            color: white !important;
        }
        .nb-btn-success {
            background: var(--accent-green) !important;
            color: white !important;
        }
        .nb-btn-danger {
            background: var(--accent-red) !important;
            color: white !important;
        }
        .nb-btn-secondary {
            background: var(--bg-card) !important;
            color: var(--text-main) !important;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <%- include('./partials/admin-sidebar', { currentPage: 'broadcast', user: typeof user !== 'undefined' ? user : null }) %>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <div class="top-bar-title">
                    <i class="fas fa-bullhorn" style="color: var(--primary-orange); margin-right: 8px;"></i>
                    Broadcast Pengumuman
                </div>
            </div>
            <div class="top-bar-actions">
                <button class="btn btn-outline" onclick="toggleTheme()" id="themeToggleBtn">
                    <i class="fas fa-moon"></i>
                </button>
                <button class="btn btn-outline" onclick="refreshData()">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Content -->
        <div class="content-container">
            <!-- Stats -->
            <div class="analytics-stats-grid">
                <div class="analytics-stat-card info">
                    <div class="analytics-stat-header">
                        <div class="analytics-stat-icon blue">
                            <i class="fas fa-users"></i>
                        </div>
                    </div>
                    <div>
                        <div class="analytics-stat-label">Total User</div>
                        <div class="analytics-stat-value" id="statTotalUsers">-</div>
                    </div>
                </div>

                <div class="analytics-stat-card success">
                    <div class="analytics-stat-header">
                        <div class="analytics-stat-icon green">
                            <i class="fas fa-user-check"></i>
                        </div>
                    </div>
                    <div>
                        <div class="analytics-stat-label">User Aktif</div>
                        <div class="analytics-stat-value" id="statActiveUsers">-</div>
                    </div>
                </div>

                <div class="analytics-stat-card warning">
                    <div class="analytics-stat-header">
                        <div class="analytics-stat-icon orange">
                            <i class="fas fa-paper-plane"></i>
                        </div>
                    </div>
                    <div>
                        <div class="analytics-stat-label">Total Terkirim</div>
                        <div class="analytics-stat-value" id="statTotalSent">-</div>
                    </div>
                </div>
            </div>

            <!-- Broadcast Form -->
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-bullhorn"></i>
                        Kirim Pengumuman Baru
                    </h2>
                    <p class="card-subtitle">Kirim pengumuman ke semua user atau user aktif saja</p>
                </div>

                <form id="broadcastForm" onsubmit="return false;">
                    <!-- Title -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-heading"></i> Judul Pengumuman
                        </label>
                        <input type="text" id="announcementTitle" class="form-input" 
                            placeholder="Contoh: Pemeliharaan Sistem" required minlength="3">
                    </div>

                    <!-- Message -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-comment-dots"></i> Isi Pesan
                        </label>
                        <textarea id="announcementMessage" class="form-textarea" 
                            placeholder="Tulis isi pengumuman di sini..." required></textarea>
                    </div>

                    <!-- Type -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-tag"></i> Tipe Pengumuman
                        </label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="announcementType" value="info" checked>
                                <span><i class="fas fa-info-circle" style="color: var(--primary-blue);"></i> Info</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="announcementType" value="warning">
                                <span><i class="fas fa-exclamation-triangle" style="color: var(--primary-orange);"></i> Warning</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="announcementType" value="error">
                                <span><i class="fas fa-times-circle" style="color: var(--accent-red);"></i> Error</span>
                            </label>
                        </div>
                    </div>

                    <!-- Target Audience -->
                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-users"></i> Target Pengiriman
                        </label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="targetAudience" value="all" checked>
                                <span>Semua User</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="targetAudience" value="active">
                                <span>User Aktif Saja</span>
                            </label>
                        </div>
                    </div>

                    <!-- Preview -->
                    <div class="form-group" style="margin-top: 30px;">
                        <label class="form-label">
                            <i class="fas fa-eye"></i> Preview Pengumuman
                        </label>
                        <div id="previewBox" style="background: var(--bg-body); border: 2px solid var(--border-color); border-radius: 12px; padding: 20px;">
                            <div style="font-weight: 600; margin-bottom: 10px; color: var(--primary-blue);">
                                <i class="fas fa-info-circle"></i> <span id="previewTitle">Judul akan muncul di sini</span>
                            </div>
                            <div style="color: var(--text-muted); line-height: 1.6;" id="previewMessage">
                                Isi pesan akan muncul di sini...
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div style="display: flex; gap: 15px; margin-top: 30px;">
                        <button type="button" class="btn btn-primary" onclick="sendAnnouncement()">
                            <i class="fas fa-paper-plane"></i> Kirim Pengumuman
                        </button>
                        <button type="button" class="btn btn-outline" onclick="resetForm()">
                            <i class="fas fa-redo"></i> Reset
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        // ============================================
        // GLOBAL VARIABLES
        // ============================================
        let totalUsers = 0;
        let activeUsers = 0;
        let totalSent = 0;

        // Theme Toggle Bridge
        function toggleTheme() {
            if (window.toggleAppTheme) {
                window.toggleAppTheme();
            }
        }

        // Listen for global theme changes to update UI
        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
        });

        // Sidebar
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            if (sidebar) sidebar.classList.toggle('active');
        }

        // INIT
        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
            loadStatistics();
            setupPreview();
        });

        // ============================================
        // STATISTICS
        // ============================================
        async function loadStatistics() {
            try {
                // Load total users
                const usersRes = await fetch('/api/admin/users?page=1&limit=1', {
                    credentials: 'same-origin'
                });
                const usersData = await usersRes.json();
                if (usersData.success) {
                    totalUsers = usersData.pagination?.total || 0;
                    document.getElementById('statTotalUsers').textContent = totalUsers;
                }

                // Load active users
                const activeRes = await fetch('/api/admin/users?page=1&limit=1&status=active', {
                    credentials: 'same-origin'
                });
                const activeData = await activeRes.json();
                if (activeData.success) {
                    activeUsers = activeData.pagination?.total || 0;
                    document.getElementById('statActiveUsers').textContent = activeUsers;
                }

                // Load broadcast history
                const historyRes = await fetch('/api/admin/broadcast/history', {
                    credentials: 'same-origin'
                });
                const historyData = await historyRes.json();
                if (historyData.success) {
                    totalSent = historyData.total_sent || 0;
                    document.getElementById('statTotalSent').textContent = totalSent;
                }
            } catch (error) {
                console.error('Error loading statistics:', error);
            }
        }

        // ============================================
        // PREVIEW
        // ============================================
        function setupPreview() {
            const titleInput = document.getElementById('announcementTitle');
            const messageInput = document.getElementById('announcementMessage');
            const previewTitle = document.getElementById('previewTitle');
            const previewMessage = document.getElementById('previewMessage');

            titleInput.addEventListener('input', (e) => {
                previewTitle.textContent = e.target.value || 'Judul akan muncul di sini';
            });

            messageInput.addEventListener('input', (e) => {
                previewMessage.textContent = e.target.value || 'Isi pesan akan muncul di sini...';
            });
        }

        // ============================================
        // SEND ANNOUNCEMENT
        // ============================================
        async function sendAnnouncement() {
            const title = document.getElementById('announcementTitle').value.trim();
            const message = document.getElementById('announcementMessage').value.trim();
            const type = document.querySelector('input[name="announcementType"]:checked').value;
            const sendTo = document.querySelector('input[name="targetAudience"]:checked').value;

            // Validation
            if (!title || title.length < 3) {
                showToast('Judul minimal 3 karakter', 'error');
                return;
            }

            if (!message || message.length === 0) {
                showToast('Pesan tidak boleh kosong', 'error');
                return;
            }

            // Confirm before sending
            const result = await Swal.fire({
                title: 'Kirim Pengumuman?',
                html: `
                    <div style="text-align: left; margin: 10px 0;">
                        <p style="margin-bottom: 15px; font-weight: 700; color: var(--text-muted);">Apakah Anda yakin ingin mempublikasikan pengumuman ini ke seluruh penerima?</p>
                        <div style="border: 3px solid var(--border-color); padding: 15px; background: rgba(0,0,0,0.03); box-shadow: 4px 4px 0px var(--border-color);">
                            <div style="margin-bottom: 10px; font-size: 1rem;"><i class="fas fa-heading" style="color: var(--primary-blue); margin-right: 8px;"></i><strong>Judul:</strong> <span style="font-weight: 800;">${title}</span></div>
                            <div style="margin-bottom: 10px; font-size: 1rem;"><i class="fas fa-tag" style="color: var(--primary-orange); margin-right: 8px;"></i><strong>Tipe:</strong> <span class="badge" style="background: ${type === 'info' ? 'var(--primary-blue)' : type === 'warning' ? 'var(--primary-orange)' : 'var(--accent-red)'}; color: white; padding: 2px 8px; border: 2px solid var(--border-color); font-size: 0.8rem; box-shadow: 2px 2px 0px var(--border-color); font-weight: 900; text-transform: uppercase;">${type}</span></div>
                            <div style="margin-bottom: 10px; font-size: 1rem;"><i class="fas fa-users" style="color: var(--accent-green); margin-right: 8px;"></i><strong>Target:</strong> <span style="font-weight: 800;">${sendTo === 'all' ? 'Semua Pengguna' : 'Pengguna Aktif Saja'}</span></div>
                            <div style="font-size: 1rem;"><i class="fas fa-paper-plane" style="color: var(--primary-blue); margin-right: 8px;"></i><strong>Penerima:</strong> <span style="font-weight: 800; color: var(--primary-blue);">${sendTo === 'all' ? totalUsers : activeUsers} Pengguna</span></div>
                        </div>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '<i class="fas fa-paper-plane"></i> Ya, Kirim!',
                cancelButtonText: 'Batal',
                reverseButtons: true,
                customClass: {
                    popup: 'nb-popup',
                    confirmButton: 'nb-btn nb-btn-primary',
                    cancelButton: 'nb-btn nb-btn-secondary'
                },
                buttonsStyling: false
            });

            if (!result.isConfirmed) {
                return;
            }

            // Show loading
            Swal.fire({
                title: 'Mengirim Pengumuman...',
                html: `
                    <div style="text-align: center; margin: 20px 0;">
                        <i class="fas fa-circle-notch fa-spin" style="font-size: 3rem; color: var(--primary-blue); margin-bottom: 15px;"></i>
                        <p style="font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px;">Sedang memproses pengiriman broadcast...</p>
                    </div>
                `,
                allowOutsideClick: false,
                showConfirmButton: false,
                customClass: {
                    popup: 'nb-popup'
                }
            });

            try {
                const response = await fetch('/api/admin/broadcast', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        title: title,
                        message: message,
                        type: type,
                        sendTo: sendTo
                    })
                });

                const data = await response.json();

                if (data.success) {
                    // SUCCESS - Show SweetAlert
                    await Swal.fire({
                        title: 'Pengumuman Berhasil Dikirim! 🎉',
                        html: `
                            <div style="text-align: center; margin: 15px 0;">
                                <div style="display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; border: 4px solid var(--border-color); background: var(--accent-green); box-shadow: 4px 4px 0px var(--border-color); margin-bottom: 20px;">
                                    <i class="fas fa-bullhorn" style="color: white; font-size: 2.2rem;"></i>
                                </div>
                                <h3 style="font-size: 1.4rem; font-weight: 900; color: var(--text-main); text-transform: uppercase; margin-bottom: 12px; letter-spacing: -0.5px;">
                                    Pesan Terkirim!
                                </h3>
                                <div style="border: 3px solid var(--border-color); padding: 15px; background: rgba(16, 185, 129, 0.08); box-shadow: 4px 4px 0px var(--border-color); margin-bottom: 10px; text-align: left;">
                                    <div style="margin-bottom: 6px; font-weight: 800; font-size: 0.95rem;">
                                        <i class="fas fa-check" style="color: var(--accent-green); margin-right: 8px;"></i>
                                        Status: <span style="color: var(--accent-green);">SUKSES</span>
                                    </div>
                                    <div style="margin-bottom: 6px; font-weight: 800; font-size: 0.95rem;">
                                        <i class="fas fa-paper-plane" style="color: var(--primary-blue); margin-right: 8px;"></i>
                                        Metode: Broadcast Real-time
                                    </div>
                                    <div style="font-weight: 800; font-size: 0.95rem;">
                                        <i class="fas fa-users" style="color: var(--primary-orange); margin-right: 8px;"></i>
                                        Penerima: <span style="color: var(--primary-blue); font-size: 1.1rem; font-weight: 900;">${data.sent_count}</span> Pengguna
                                    </div>
                                </div>
                                <p style="color: var(--text-muted); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; margin-top: 15px;">
                                    * Pengumuman telah diterbitkan ke dashboard penerima
                                </p>
                            </div>
                        `,
                        customClass: {
                            popup: 'nb-popup',
                            confirmButton: 'nb-btn nb-btn-success'
                        },
                        buttonsStyling: false,
                        confirmButtonText: 'OK'
                    });

                    // Reset form
                    resetForm();
                    
                    // Refresh statistics
                    loadStatistics();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Gagal!',
                        text: data.message || 'Gagal mengirim pengumuman',
                        customClass: {
                            popup: 'nb-popup',
                            confirmButton: 'nb-btn nb-btn-danger'
                        },
                        buttonsStyling: false
                    });
                }
            } catch (error) {
                console.error('Error sending announcement:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error!',
                    text: 'Terjadi kesalahan saat mengirim pengumuman',
                    customClass: {
                        popup: 'nb-popup',
                        confirmButton: 'nb-btn nb-btn-danger'
                    },
                    buttonsStyling: false
                });
            }
        }

        // ============================================
        // RESET FORM
        // ============================================
        function resetForm() {
            document.getElementById('broadcastForm').reset();
            document.getElementById('previewTitle').textContent = 'Judul akan muncul di sini';
            document.getElementById('previewMessage').textContent = 'Isi pesan akan muncul di sini...';
        }

        // ============================================
        // REFRESH DATA
        // ============================================
        function refreshData() {
            loadStatistics();
            showToast('Data berhasil disegarkan', 'success');
        }

        // ============================================
        // TOAST
        // ============================================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;

            const icon = type === 'success' ? 'fa-check-circle' :
                        type === 'error' ? 'fa-exclamation-circle' :
                        'fa-info-circle';

            toast.innerHTML = `
                <i class="fas ${icon}"></i>
                <span>${message}</span>
            `;

            container.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
    </script>
</body>
</html>
