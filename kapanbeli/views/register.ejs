<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar - Kapan Beli</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #3B82F6;
            --accent: #FF9F43;
            --text-main: #FFFFFF;
            --text-muted: #94A3B8;
            --glass-bg: rgba(15, 23, 42, 0.6);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-panel: rgba(255, 255, 255, 0.03);
            --input-bg: rgba(0, 0, 0, 0.2);
        }

        body.light-mode {
            --text-main: #1E293B;
            --text-muted: #64748B;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(255, 255, 255, 0.5);
            --glass-panel: rgba(255, 255, 255, 0.4);
            --input-bg: rgba(255, 255, 255, 0.6);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            height: 100vh;
            overflow: hidden;
            background: url('/images/bahan%20dapur.jpg') no-repeat center center fixed;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(2, 6, 23, 0.8), rgba(2, 6, 23, 0.4));
            z-index: 1;
            transition: 0.5s ease;
        }
        body.light-mode::before {
            background: linear-gradient(135deg, rgba(248, 250, 252, 0.85), rgba(248, 250, 252, 0.5));
        }

        .auth-wrapper {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 1000px;
            height: 600px;
            margin: 20px;
            display: flex;
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
            animation: slideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            overflow: hidden;
            transition: 0.5s ease;
        }

        @keyframes slideIn {
            0% { transform: translateY(40px) scale(0.95); opacity: 0; }
            100% { transform: translateY(0) scale(1); opacity: 1; }
        }

        @keyframes slideOut {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            100% { transform: translateY(-40px) scale(0.95); opacity: 0; }
        }

        .slide-out {
            animation: slideOut 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards !important;
        }

        /* LEFT PANEL (Branding) */
        .brand-panel {
            flex: 1;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
            color: var(--text-main);
        }

        .brand-panel::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 60%);
            animation: spin 20s linear infinite;
            z-index: -1;
        }

        @keyframes spin { 100% { transform: rotate(360deg); } }

        .brand-panel i.main-icon {
            font-size: 3.5rem;
            background: linear-gradient(135deg, var(--accent), #FF7675);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 24px;
            filter: drop-shadow(0 10px 15px rgba(255, 159, 67, 0.3));
        }

        .brand-panel h1 { font-family: 'Outfit', sans-serif; font-size: 3.2rem; font-weight: 800; line-height: 1.1; margin-bottom: 16px; letter-spacing: -1px; }
        .brand-panel p { font-size: 1.05rem; color: var(--text-muted); line-height: 1.6; max-width: 90%; }

        /* RIGHT PANEL (Form) */
        .form-panel {
            flex: 1.1;
            background: var(--glass-panel);
            padding: 40px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-left: 1px solid var(--glass-border);
            position: relative;
            transition: 0.5s ease;
        }

        .form-header { margin-bottom: 24px; }
        .form-header h2 { font-size: 2rem; font-family: 'Outfit', sans-serif; font-weight: 700; color: var(--text-main); letter-spacing: -0.5px; }
        .form-header p { color: var(--text-muted); margin-top: 5px; font-size: 0.95rem; }

        .input-group { margin-bottom: 16px; }
        .input-wrapper { position: relative; }
        .input-wrapper i.icon-left { position: absolute; left: 20px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 1.1rem; }
        .input-wrapper input {
            width: 100%;
            padding: 16px 50px;
            background: var(--input-bg);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            color: var(--text-main);
            font-size: 0.95rem;
            outline: none;
            transition: all 0.3s ease;
        }
        body.light-mode .input-wrapper input { color: #1E293B; border-color: rgba(0,0,0,0.1); }
        
        .input-wrapper input:focus {
            border-color: var(--primary);
            background: rgba(59, 130, 246, 0.1);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }
        .input-wrapper i.icon-eye { position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: var(--text-muted); cursor: pointer; transition: 0.3s; }
        .input-wrapper i.icon-eye:hover { color: var(--accent); }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--primary), #2563EB);
            color: white;
            border: none;
            border-radius: 16px;
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            cursor: pointer;
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
            margin-top: 10px;
            transition: all 0.3s ease;
        }
        .btn-submit:hover { transform: translateY(-3px); box-shadow: 0 15px 25px rgba(59, 130, 246, 0.4); }

        .form-links { text-align: center; margin-top: 20px; color: var(--text-muted); font-size: 0.95rem; }
        .form-links a { color: var(--accent); text-decoration: none; font-weight: 700; transition: 0.3s; }
        .form-links a:hover { text-shadow: 0 0 10px rgba(255, 159, 67, 0.5); }

        .theme-toggle {
            position: absolute; top: 30px; right: 30px;
            background: var(--input-bg); border: 1px solid var(--glass-border);
            width: 44px; height: 44px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            color: var(--text-main); cursor: pointer; transition: 0.3s; z-index: 10;
        }
        .theme-toggle:hover { color: var(--accent); border-color: var(--accent); transform: rotate(15deg); }

        /* LOADING OVERLAY */
        .loading-overlay {
            position: fixed; inset: 0;
            background: rgba(2, 6, 23, 0.9);
            backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
            z-index: 9999; display: flex; flex-direction: column; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity 0.5s ease;
        }
        body.light-mode .loading-overlay { background: rgba(248, 250, 252, 0.9); }
        .loading-overlay.active { opacity: 1; pointer-events: all; }
        .loading-icon {
            font-size: 5rem; color: var(--accent);
            animation: floatBook 2s ease-in-out infinite;
            margin-bottom: 24px;
            filter: drop-shadow(0 0 30px rgba(255, 159, 67, 0.4));
        }
        .loading-text {
            color: white; font-size: 1.4rem; font-family: 'Outfit', sans-serif; font-weight: 700;
        }
        body.light-mode .loading-text { color: #1E293B; }
        .dots::after { content: ''; animation: dots 1.5s infinite steps(4, end); }
        @keyframes floatBook { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
        @keyframes dots { 0% { content: ''; } 25% { content: '.'; } 50% { content: '..'; } 75% { content: '...'; } 100% { content: ''; } }

        /* ALERT */
        .alert-box { padding: 12px 20px; border-radius: 14px; margin-bottom: 16px; font-size: 0.9rem; font-weight: 600; display: none; align-items: center; gap: 12px; }
        .alert-box.show { display: flex; animation: slideDown 0.3s ease; }
        .alert-error { background: rgba(239, 68, 68, 0.15); color: #FCA5A5; border: 1px solid rgba(239, 68, 68, 0.3); }
        body.light-mode .alert-error { color: #EF4444; }
        .alert-success { background: rgba(34, 197, 94, 0.15); color: #86EFAC; border: 1px solid rgba(34, 197, 94, 0.3); }
        body.light-mode .alert-success { color: #22C55E; }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

        @media (max-width: 900px) {
            .auth-wrapper { flex-direction: column; height: auto; max-height: 95vh; max-width: 500px; overflow-y: auto; }
            .brand-panel { padding: 30px; text-align: center; flex: none; border-bottom: 1px solid var(--glass-border); }
            .form-panel { padding: 30px; border-left: none; }
        }
    </style>
</head>
<body>

    <!-- Loading Modal -->
    <div class="loading-overlay" id="loadingModal">
        <i class="fas fa-book-open loading-icon"></i>
        <div class="loading-text">Membangun Dapur Anda<span class="dots"></span></div>
    </div>

    <div class="auth-wrapper">
        <button class="theme-toggle" title="Ganti Mode" onclick="toggleTheme()">
            <i class="fas fa-sun" id="themeIcon"></i>
        </button>

        <!-- Kiri: Branding -->
        <div class="brand-panel">
            <i class="fas fa-kitchen-set main-icon"></i>
            <h1>Join The<br>Ecosystem.</h1>
            <p>Mulailah perjalanan Anda menuju manajemen dapur tingkat lanjut. Buat akun Kapan Beli Anda sekarang dan optimalkan efisiensi.</p>
        </div>

        <!-- Kanan: Form -->
        <div class="form-panel">
            <div id="authAlert" class="alert-box"></div>

            <div class="form-header">
                <h2>Buat Akun Baru</h2>
                <p>Isi formulir di bawah untuk mendaftar.</p>
            </div>

            <form id="registerForm">
                <div class="input-group">
                    <div class="input-wrapper">
                        <i class="fas fa-user icon-left"></i>
                        <input type="text" id="regName" placeholder="Nama Lengkap" required>
                    </div>
                </div>

                <div class="input-group">
                    <div class="input-wrapper">
                        <i class="fas fa-envelope icon-left"></i>
                        <input type="email" id="regEmail" placeholder="Alamat Email" required>
                    </div>
                </div>

                <div class="input-group">
                    <div class="input-wrapper">
                        <i class="fas fa-lock icon-left"></i>
                        <input type="password" id="regPassword" placeholder="Kata Sandi" required>
                        <i class="fas fa-eye icon-eye" onclick="togglePassword('regPassword', this)"></i>
                    </div>
                </div>

                <div class="input-group">
                    <div class="input-wrapper">
                        <i class="fas fa-lock icon-left"></i>
                        <input type="password" id="regConfirmPassword" placeholder="Konfirmasi Kata Sandi" required>
                        <i class="fas fa-eye icon-eye" onclick="togglePassword('regConfirmPassword', this)"></i>
                    </div>
                </div>

                <button type="submit" class="btn-submit">Daftar Sekarang</button>
            </form>

            <div class="form-links">
                Sudah punya akun? <a href="/auth" onclick="navigateSmooth(event, '/auth')">Masuk di sini</a>
            </div>
        </div>
    </div>

    <script>
        // --- THEME LOGIC ---
        const body = document.body;
        const themeIcon = document.getElementById('themeIcon');
        
        function initTheme() {
            if (localStorage.getItem('theme') === 'light') {
                body.classList.add('light-mode');
                themeIcon.className = 'fas fa-moon';
            } else {
                body.classList.remove('light-mode');
                themeIcon.className = 'fas fa-sun';
            }
        }
        initTheme();

        function toggleTheme() {
            if (body.classList.contains('light-mode')) {
                body.classList.remove('light-mode');
                localStorage.setItem('theme', 'dark');
                themeIcon.className = 'fas fa-sun';
            } else {
                body.classList.add('light-mode');
                localStorage.setItem('theme', 'light');
                themeIcon.className = 'fas fa-moon';
            }
        }

        // --- PASSWORD TOGGLE ---
        function togglePassword(id, icon) {
            const input = document.getElementById(id);
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'fas fa-eye-slash icon-eye';
            } else {
                input.type = 'password';
                icon.className = 'fas fa-eye icon-eye';
            }
        }

        // --- ALERT ---
        function showAlert(msg, type = 'error') {
            const alertBox = document.getElementById('authAlert');
            alertBox.className = `alert-box show ${type === 'error' ? 'alert-error' : 'alert-success'}`;
            alertBox.innerHTML = `<i class="fas ${type === 'error' ? 'fa-exclamation-triangle' : 'fa-check-circle'}"></i> <span>${msg}</span>`;
        }
        function hideAlert() { document.getElementById('authAlert').classList.remove('show'); }

        // --- SMOOTH NAVIGATION ---
        function navigateSmooth(e, url) {
            e.preventDefault();
            const wrapper = document.querySelector('.auth-wrapper');
            wrapper.classList.add('slide-out');
            setTimeout(() => {
                window.location.href = url;
            }, 400);
        }

        // --- REGISTER HANDLER ---
        document.getElementById('registerForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            hideAlert();

            const name = document.getElementById('regName').value.trim();
            const email = document.getElementById('regEmail').value.trim();
            const password = document.getElementById('regPassword').value;
            const confirmPassword = document.getElementById('regConfirmPassword').value;

            if (!name || !email || !password || !confirmPassword) return showAlert('Mohon lengkapi semua kolom.');
            if (password !== confirmPassword) return showAlert('Konfirmasi password tidak cocok!');

            const btn = document.querySelector('.btn-submit');
            const originalText = btn.innerText;
            btn.innerText = 'Mendaftar...';
            btn.disabled = true;

            try {
                const response = await fetch('/auth/signup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, email, password, confirmPassword })
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('loadingModal').classList.add('active');
                    setTimeout(() => window.location.href = data.redirect || '/', 2000);
                } else {
                    showAlert(data.message, 'error');
                    btn.innerText = originalText;
                    btn.disabled = false;
                }
            } catch (error) {
                showAlert('Gagal terhubung ke server. Silakan coba lagi.');
                btn.innerText = originalText;
                btn.disabled = false;
            }
        });
    </script>
</body>
</html>