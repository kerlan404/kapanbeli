<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Produk - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-dark: #1D4ED8;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-sidebar-hover: #f1f5f9;
            --bg-sidebar-active: #e2e8f0;
            --text-sidebar: #475569;
            --text-sidebar-active: #000000;
            --text-sidebar-heading: #000000;
            --sidebar-border: #000000;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #000000;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
            --radius: 0px;
            --sidebar-width: 260px;
            --header-height: 70px;
            --content-padding: 40px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1A1D23;
            --bg-body: #0F1115;
            --bg-card: #1A1D23;
            --text-main: #FFFFFF;
            --text-muted: #9CA3AF;
            --border-color: #FFFFFF;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            transition: background 0.3s;
        }

        /* Sidebar Overlay */
        .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
        .sidebar-overlay.active { display: block; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width); flex: 1; padding: var(--content-padding); transition: margin-left 0.3s ease;
        }

        .top-bar {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 40px; gap: 20px; flex-wrap: wrap;
        }
        .page-title { font-size: 2.2rem; font-weight: 900; letter-spacing: -1.5px; text-transform: uppercase; }
        .page-subtitle { font-size: 1.1rem; color: var(--text-muted); margin-top: 5px; font-weight: 500; }
        
        .top-actions { display: flex; gap: 15px; align-items: center; }

        /* Buttons */
        .btn {
            padding: 14px 28px; border: 4px solid var(--border-color); border-radius: var(--radius);
            font-weight: 800; font-size: 1rem; cursor: pointer;
            display: inline-flex; align-items: center; gap: 12px;
            transition: all 0.2s; font-family: inherit;
            text-transform: uppercase; letter-spacing: 0.5px;
            box-shadow: var(--shadow-brutal-sm);
        }
        .btn:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0px var(--border-color); }
        .btn:active { transform: translate(0, 0); box-shadow: 2px 2px 0px var(--border-color); }

        .btn-primary { background: var(--primary-blue); color: white; }
        .btn-outline { background: var(--bg-card); color: var(--text-main); }
        .btn-success { background: var(--accent-green); color: white; }
        .btn-warning { background: var(--primary-orange); color: white; }
        .btn-danger { background: var(--accent-red); color: white; }
        .btn-sm { padding: 8px 16px; font-size: 0.85rem; border-width: 3px; }
        
        .theme-toggle { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }

        /* Stats Grid */
        .stats-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 25px; margin-bottom: 40px;
        }
        .stat-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 30px; box-shadow: var(--shadow-brutal);
            transition: all 0.2s;
        }
        .stat-card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }
        .stat-card h3 { font-size: 2.8rem; font-weight: 900; margin-bottom: 5px; line-height: 1; }
        .stat-card p { font-size: 0.95rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

        /* Panel Card */
        .panel-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 35px; box-shadow: var(--shadow-brutal);
            margin-bottom: 40px;
        }
        .panel-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
            flex-wrap: wrap; gap: 20px;
        }
        .panel-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; }

        /* Search & Filters */
        .filters-container {
            display: flex; gap: 20px; width: 100%; flex-wrap: wrap;
        }
        .filter-group { flex: 1; min-width: 200px; }
        .filter-label { display: block; font-weight: 900; margin-bottom: 10px; text-transform: uppercase; font-size: 0.85rem; }
        
        .form-control {
            width: 100%; padding: 15px 20px;
            border: 3px solid var(--border-color); border-radius: var(--radius);
            background: var(--bg-card); color: var(--text-main);
            font-size: 1rem; font-weight: 700; box-shadow: var(--shadow-brutal-sm);
            transition: all 0.2s; outline: none;
        }
        .form-control:focus { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); border-color: var(--primary-blue); }

        /* Table */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th {
            text-align: left; padding: 20px; font-weight: 900;
            color: var(--text-main); font-size: 0.9rem; text-transform: uppercase;
            letter-spacing: 1px; border-bottom: 4px solid var(--border-color);
            background: rgba(0,0,0,0.05);
        }
        body.dark-mode-active th { background: rgba(255,255,255,0.05); }
        td { padding: 20px; border-bottom: 3px solid var(--border-color); font-weight: 700; font-size: 1rem; }
        tr:hover { background: rgba(0,0,0,0.02); }
        body.dark-mode-active tr:hover { background: rgba(255,255,255,0.02); }
        tr.deactivated-row { background: rgba(239, 68, 68, 0.05); }

        .product-info { display: flex; align-items: center; gap: 20px; }
        .product-img {
            width: 70px; height: 70px; border: 3px solid var(--border-color);
            object-fit: cover; box-shadow: var(--shadow-brutal-sm); background: #eee;
        }
        .product-name { font-size: 1.1rem; font-weight: 800; }
        .product-meta { font-size: 0.85rem; color: var(--text-muted); margin-top: 4px; }

        .badge {
            display: inline-block; padding: 6px 14px; border: 3px solid var(--border-color);
            font-size: 0.8rem; font-weight: 900; text-transform: uppercase;
            box-shadow: 3px 3px 0px var(--border-color);
        }
        .badge-info { background: var(--primary-blue); color: white; }
        .badge-success { background: var(--accent-green); color: white; }
        .badge-warning { background: var(--primary-orange); color: white; }
        .badge-danger { background: var(--accent-red); color: white; }

        /* Action Buttons Group */
        .action-group { display: flex; gap: 10px; }
        .btn-icon {
            width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;
            border: 3px solid var(--border-color); background: var(--bg-card);
            color: var(--text-main); font-size: 1.1rem; transition: all 0.2s;
            box-shadow: 4px 4px 0px var(--border-color);
            cursor: pointer;
        }
        .btn-icon:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .btn-icon.edit:hover { color: var(--primary-blue); border-color: var(--primary-blue); box-shadow: 6px 6px 0px var(--primary-blue); }
        .btn-icon.delete:hover { color: var(--accent-red); border-color: var(--accent-red); box-shadow: 6px 6px 0px var(--accent-red); }

        /* Modal */
        .modal {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); z-index: 2000; align-items: center; justify-content: center; padding: 20px;
            opacity: 0; transition: all 0.2s;
        }
        .modal.active { display: flex; opacity: 1; }
        .modal-content {
            background: var(--bg-card); border: 6px solid var(--border-color);
            width: 100%; max-width: 800px; max-height: 90vh; overflow-y: auto;
            position: relative; box-shadow: 20px 20px 0px rgba(0,0,0,0.5);
            padding: 40px; transform: scale(0.95); transition: all 0.2s;
        }
        .modal.active .modal-content { transform: scale(1); }
        .modal-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 35px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
        }
        .modal-title { font-size: 1.8rem; font-weight: 900; text-transform: uppercase; display: flex; align-items: center; gap: 15px; }
        .modal-close { font-size: 2.5rem; cursor: pointer; color: var(--text-main); line-height: 1; transition: color 0.2s; background: none; border: none; }
        .modal-close:hover { color: var(--accent-red); }

        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; }
        .full-width { grid-column: span 2; }
        .form-group { margin-bottom: 25px; }
        .form-group label { display: block; font-weight: 900; margin-bottom: 12px; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 0.5px; }
        .form-group .form-control { padding: 15px 20px; }

        /* Custom Checkbox */
        .checkbox-group {
            display: flex; align-items: center; gap: 15px; cursor: pointer; padding: 20px;
            background: rgba(0,0,0,0.02); border: 3px solid var(--border-color);
            transition: all 0.2s; font-weight: 800; text-transform: uppercase;
        }
        .checkbox-group:hover { background: rgba(0,0,0,0.05); transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .checkbox-group input[type="checkbox"] { width: 22px; height: 22px; cursor: pointer; }

        /* Pagination */
        .pagination-container { display: flex; justify-content: space-between; align-items: center; margin-top: 30px; padding-top: 20px; border-top: 4px solid var(--border-color); flex-wrap: wrap; gap: 20px; }
        .pagination-info { font-weight: 800; color: var(--text-muted); font-size: 0.95rem; }
        .pagination { display: flex; gap: 10px; list-style: none; }
        .pagination button {
            min-width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;
            border: 3px solid var(--border-color); background: var(--bg-card); font-weight: 900;
            cursor: pointer; transition: all 0.2s; box-shadow: 4px 4px 0px var(--border-color);
            padding: 0 15px; font-family: inherit; text-transform: uppercase;
        }
        .pagination button:hover:not(:disabled) { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .pagination button.active { background: var(--primary-blue); color: white; }
        .pagination button:disabled { opacity: 0.4; cursor: not-allowed; }

        /* Loading */
        .loading-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); display: flex; align-items: center; justify-content: center; z-index: 9999; }
        .loading-spinner { width: 60px; height: 60px; border: 6px solid rgba(255,255,255,0.2); border-top-color: var(--primary-blue); border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* Responsive */
        .menu-toggle { display: none; font-size: 1.5rem; cursor: pointer; color: var(--text-main); }
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 25px; }
            .menu-toggle { display: block; }
        }
    </style>
</head>
<body>
    <%- include('./partials/admin-sidebar', { currentPage: 'products', user: typeof user !== 'undefined' ? user : null }) %>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <div>
                    <h1 class="page-title">📦 Manajemen Produk</h1>
                    <p class="page-subtitle">Kelola inventaris produk dan kategori bahan makanan</p>
                </div>
            </div>
            <div class="top-actions">
                <button class="btn btn-outline theme-toggle" onclick="toggleTheme()" id="themeToggleBtn">
                    <i class="fas fa-moon"></i>
                </button>
                <button class="btn btn-primary" onclick="openAddModal()">
                    <i class="fas fa-plus"></i> Tambah Produk
                </button>
            </div>
        </div>

        <!-- Statistics -->
        <div class="stats-grid" id="productStatsGrid">
            <div class="stat-card">
                <h3 id="statTotalProducts">0</h3>
                <p>Total Produk</p>
            </div>
            <div class="stat-card">
                <h3 id="statActiveProducts">0</h3>
                <p>Produk Aktif</p>
            </div>
            <div class="stat-card">
                <h3 id="statLowStock">0</h3>
                <p>Stok Rendah</p>
            </div>
            <div class="stat-card">
                <h3 id="statOutOfStock">0</h3>
                <p>Habis Stok</p>
            </div>
        </div>

        <!-- Products Table -->
        <div class="panel-card">
            <div class="panel-header">
                <h3 class="panel-title">Daftar Produk</h3>
                <div class="filters-container">
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-search"></i> Cari</label>
                        <input type="text" id="searchInput" class="form-control" placeholder="Nama produk atau kategori..." onkeyup="debounceSearch()">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-tags"></i> Kategori</label>
                        <select id="categoryFilter" class="form-control" onchange="loadProducts()">
                            <option value="">Semua Kategori</option>
                            <option value="Bumbu Dapur">Bumbu Dapur</option>
                            <option value="Sayuran">Sayuran</option>
                            <option value="Buah-buahan">Buah-buahan</option>
                            <option value="Protein">Protein</option>
                            <option value="Bahan Kering">Bahan Kering</option>
                            <option value="Lainnya">Lainnya</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-filter"></i> Status Stok</label>
                        <select id="stockStatusFilter" class="form-control" onchange="loadProducts()">
                            <option value="">Semua Status</option>
                            <option value="good">Aman</option>
                            <option value="low">Rendah</option>
                            <option value="out">Habis</option>
                        </select>
                    </div>
                    <div style="display: flex; gap: 10px; align-items: flex-end;">
                        <button class="btn btn-outline" onclick="resetFilters()">
                            <i class="fas fa-redo"></i> Reset
                        </button>
                        <button class="btn btn-primary" onclick="refreshData()">
                            <i class="fas fa-sync-alt"></i> Refresh
                        </button>
                    </div>
                </div>
            </div>

            <!-- Loading -->
            <div id="tableLoading" style="text-align: center; padding: 40px; display: none;">
                <i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--primary-blue);"></i>
                <p style="margin-top: 15px; font-weight: 800;">Memuat data...</p>
            </div>

            <!-- Table -->
            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>Produk</th>
                            <th>Kategori</th>
                            <th>Stok</th>
                            <th>Kadaluarsa</th>
                            <th>Status</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="productsTableBody">
                        <!-- Data will be loaded here -->
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" id="paginationContainer" style="display: none;">
                <div class="pagination-info">
                    Menampilkan <span id="showingFrom">0</span> - <span id="showingTo">0</span> dari <span id="totalItems">0</span> data
                </div>
                <div class="pagination" id="paginationButtons">
                    <!-- Pagination buttons will be inserted here -->
                </div>
            </div>

            <!-- Empty State -->
            <div id="emptyState" style="text-align: center; padding: 60px 20px; display: none;">
                <i class="fas fa-box-open" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 15px;"></i>
                <p style="font-weight: 800;">Belum ada data produk</p>
            </div>
        </div>
    </main>

    <!-- Product Edit/Add Modal -->
    <div class="modal" id="productModal">
        <div class="modal-content" style="border: 4px solid #000; box-shadow: 10px 10px 0px #000; padding: 30px; max-width: 600px;">
            <div class="modal-header" style="border-bottom: 4px solid #000; margin-bottom: 25px; padding-bottom: 15px;">
                <h3 class="modal-title" id="modalTitle" style="font-size: 1.6rem; letter-spacing: -0.5px;">
                    <i class="fas fa-box-open" style="color: var(--primary-blue); margin-right: 10px;"></i>
                    <span>Tambah Produk Baru</span>
                </h3>
                <button class="modal-close" onclick="closeModal()" style="font-size: 2.2rem;">&times;</button>
            </div>
            <div class="modal-body">
                <form id="productForm">
                    <input type="hidden" id="editProductId">

                    <div class="form-group" style="margin-bottom: 20px;">
                        <label for="productName" style="font-weight: 900; font-size: 0.85rem; letter-spacing: 0.5px;">NAMA PRODUK <span style="color:var(--accent-red)">*</span></label>
                        <input type="text" id="productName" class="form-control" style="border: 3px solid #000; box-shadow: 4px 4px 0px #000; border-radius: 4px;" required minlength="3" placeholder="Contoh: Bawang Merah Super">
                    </div>

                    <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="productCategory" style="font-weight: 900; font-size: 0.85rem; letter-spacing: 0.5px;">KATEGORI</label>
                            <select id="productCategory" class="form-control" style="border: 3px solid #000; box-shadow: 4px 4px 0px #000; border-radius: 4px; cursor: pointer;">
                                <option value="Bumbu Dapur">Bumbu Dapur</option>
                                <option value="Sayuran">Sayuran</option>
                                <option value="Buah-buahan">Buah-buahan</option>
                                <option value="Protein">Protein</option>
                                <option value="Bahan Kering">Bahan Kering</option>
                                <option value="Lainnya">Lainnya</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="productUnit" style="font-weight: 900; font-size: 0.85rem; letter-spacing: 0.5px;">SATUAN</label>
                            <select id="productUnit" class="form-control" style="border: 3px solid #000; box-shadow: 4px 4px 0px #000; border-radius: 4px; cursor: pointer;">
                                <option value="kg">Kilogram (kg)</option>
                                <option value="gram">Gram (gr)</option>
                                <option value="pcs">Buah/Pcs</option>
                                <option value="liter">Liter (Volume)</option>
                                <option value="bungkus">Bungkus (pcs)</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="productStock" style="font-weight: 900; font-size: 0.85rem; letter-spacing: 0.5px;">STOK SAAT INI <span style="color:var(--accent-red)">*</span></label>
                            <input type="number" id="productStock" class="form-control" style="border: 3px solid #000; box-shadow: 4px 4px 0px #000; border-radius: 4px;" required min="0" step="0.01" placeholder="0">
                        </div>
                        <div class="form-group" style="margin-bottom: 0;">
                            <label for="productMinStock" style="font-weight: 900; font-size: 0.85rem; letter-spacing: 0.5px;">STOK MINIMAL <span style="color:var(--accent-red)">*</span></label>
                            <input type="number" id="productMinStock" class="form-control" style="border: 3px solid #000; box-shadow: 4px 4px 0px #000; border-radius: 4px;" required min="0" step="0.01" placeholder="0">
                        </div>
                    </div>

                    <div class="form-group" style="margin-bottom: 25px;">
                        <label for="productExpiryDate" style="font-weight: 900; font-size: 0.85rem; letter-spacing: 0.5px;">TANGGAL KADALUARSA</label>
                        <input type="text" id="productExpiryDate" class="form-control" style="border: 3px solid #000; box-shadow: 4px 4px 0px #000; border-radius: 4px;" placeholder="Pilih tanggal...">
                        
                        <label class="checkbox-group" style="margin-top: 15px; background: rgba(0,0,0,0.02); border: 3px solid #000; box-shadow: 4px 4px 0px #000; padding: 10px 15px; display: flex; align-items: center; gap: 10px; cursor: pointer; border-radius: 4px;">
                            <input type="checkbox" id="productNoExpiry" onchange="toggleExpiryDate()" style="width: 20px; height: 20px; cursor: pointer; accent-color: var(--primary-blue);">
                            <span style="font-weight: 800; font-size: 0.85rem; color: #000; text-transform: uppercase;">Tidak pakai tanggal kadaluarsa</span>
                        </label>
                    </div>

                    <div class="form-group">
                        <label class="checkbox-group" style="background: #f8f9fa; border: 3px solid #000; box-shadow: 4px 4px 0px #000; padding: 15px; display: flex; align-items: center; gap: 15px; cursor: pointer; border-radius: 4px;">
                            <input type="checkbox" id="productIsActive" checked style="width: 24px; height: 24px; cursor: pointer; accent-color: var(--primary-blue);">
                            <span style="font-weight: 900; font-size: 0.95rem; color: #000; flex: 1;">AKTIFKAN PRODUK <small style="display:block; font-weight:700; color:var(--text-muted); text-transform:none;">Dapat dilihat oleh pengguna</small></span>
                        </label>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="display: flex; gap: 15px; margin-top: 30px;">
                <button class="btn btn-outline" onclick="closeModal()" style="flex: 1; border: 3px solid #000; box-shadow: 4px 4px 0px #000; font-weight: 900; background: #fff;">BATAL</button>
                <button class="btn btn-primary" onclick="handleFormSubmit()" id="btnSubmit" style="flex: 1; border: 3px solid #000; box-shadow: 4px 4px 0px #000; font-weight: 900; background: var(--primary-blue);">SIMPAN PRODUK</button>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal" id="deleteModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Konfirmasi Hapus</h3>
                <button class="modal-close" onclick="closeDeleteModal()">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-weight: 800;">Apakah Anda yakin ingin menghapus produk ini?</p>
                <div style="background: rgba(239, 68, 68, 0.1); border-left: 6px solid var(--accent-red); padding: 15px; margin-top: 20px;">
                    <p style="color: var(--accent-red); font-weight: 900; text-transform: uppercase; font-size: 0.85rem;">
                        <i class="fas fa-exclamation-triangle"></i> Tindakan ini tidak dapat dibatalkan.
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeDeleteModal()">Batal</button>
                <button class="btn btn-danger" onclick="confirmDelete()">Hapus</button>
            </div>
        </div>
    </div>

    <!-- Deactivate Product Modal -->
    <div class="modal" id="deactivateModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Nonaktifkan Produk</h3>
                <button class="modal-close" onclick="closeDeactivateModal()">&times;</button>
            </div>
            <div class="modal-body">
                <p style="font-weight: 800;">Anda akan menonaktifkan produk:</p>
                <p style="font-weight: 900; font-size: 1.3rem; margin: 15px 0; color: var(--primary-blue); text-transform: uppercase;">
                    <i class="fas fa-box"></i> <span id="deactivateProductName"></span>
                </p>
                <div style="background: rgba(239, 68, 68, 0.1); border-left: 6px solid var(--accent-red); padding: 20px; margin: 20px 0;">
                    <p style="color: var(--accent-red); font-weight: 900; text-transform: uppercase; font-size: 0.85rem;">
                        <i class="fas fa-exclamation-triangle"></i> Perhatian:
                    </p>
                    <p style="color: var(--text-main); font-weight: 700; margin-top: 5px;">
                        Produk yang dinonaktifkan tidak dapat diedit atau dihapus oleh user sampai diaktifkan kembali.
                    </p>
                </div>
                <div class="form-group">
                    <label style="font-weight: 900;"><i class="fas fa-comment"></i> Alasan Nonaktifkan:</label>
                    <textarea id="deactivateReason" class="form-control" rows="4" placeholder="Jelaskan alasan menonaktifkan produk ini..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="closeDeactivateModal()">Batal</button>
                <button class="btn btn-danger" onclick="confirmDeactivate()">
                    <i class="fas fa-ban"></i> Nonaktifkan
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay" style="display: none;">
        <div class="loading-spinner"></div>
    </div>

    <script>
        let currentPage = 1;
        let currentLimit = 20;
        let deleteProductTargetId = null;
        let deactivateProductTargetId = null;
        let searchTimer = null;

        // Theme Toggle Bridge
        function toggleTheme() {
            if (window.toggleAppTheme) {
                window.toggleAppTheme();
            }
        }

        // Listen for global theme changes to update UI
        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
        });

        // Sidebar
        function toggleSidebar() {
            const sidebar = document.querySelector('.sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            if (sidebar) sidebar.classList.toggle('active');
            if (overlay) overlay.classList.toggle('active');
        }

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
            
            loadProducts();
            loadProductStatistics();

            flatpickr("#productExpiryDate", {
                dateFormat: "Y-m-d",
                allowInput: true,
                minDate: "today",
                theme: "material_blue",
                altInput: true,
                altFormat: "d/m/Y"
            });
        });

        function showToast(message, type = 'success') {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                customClass: { popup: 'nb-popup' },
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer)
                    toast.addEventListener('mouseleave', Swal.resumeTimer)
                }
            });

            Toast.fire({
                icon: type,
                title: message
            });
        }

        async function loadProductStatistics() {
            try {
                const res = await fetch('/api/admin/products/statistics', { credentials: 'same-origin' });
                const data = await res.json();
                if (data.success) {
                    const stats = data.data;
                    document.getElementById('statTotalProducts').textContent = stats.total_products || 0;
                    document.getElementById('statActiveProducts').textContent = stats.active_products || 0;
                    document.getElementById('statLowStock').textContent = stats.low_stock || 0;
                    document.getElementById('statOutOfStock').textContent = stats.out_of_stock || 0;
                }
            } catch (error) { console.error('Error stats:', error); }
        }

        async function loadProducts(page = 1) {
            currentPage = page;
            const search = document.getElementById('searchInput').value;
            const category = document.getElementById('categoryFilter').value;
            const stockStatus = document.getElementById('stockStatusFilter').value;
            
            document.getElementById('tableLoading').style.display = 'block';
            document.getElementById('productsTableBody').style.opacity = '0.5';

            try {
                const url = `/api/admin/products?page=${page}&limit=${currentLimit}&search=${encodeURIComponent(search)}&category=${encodeURIComponent(category)}&stockStatus=${stockStatus}`;
                const res = await fetch(url, { credentials: 'same-origin' });
                const data = await res.json();
                
                document.getElementById('tableLoading').style.display = 'none';
                document.getElementById('productsTableBody').style.opacity = '1';

                if (data.success) {
                    renderProducts(data.data);
                    renderPagination(data.pagination);
                    updatePaginationInfo(data.pagination);
                }
            } catch (error) {
                console.error('Error products:', error);
                document.getElementById('tableLoading').style.display = 'none';
            }
        }

        function renderProducts(products) {
            const tbody = document.getElementById('productsTableBody');
            const emptyState = document.getElementById('emptyState');
            
            if (!products || products.length === 0) {
                tbody.innerHTML = '';
                emptyState.style.display = 'block';
                return;
            }

            emptyState.style.display = 'none';
            tbody.innerHTML = products.map(p => {
                const sq = parseFloat(p.stock_quantity) || 0;
                const ms = parseFloat(p.min_stock_level) || 0;
                const isLow = sq <= ms && sq > 0;
                const isOut = sq <= 0;
                const stockBadge = isOut ? 'badge-danger' : (isLow ? 'badge-warning' : 'badge-success');
                const stockText = isOut ? 'Habis' : (isLow ? 'Rendah' : 'Aman');
                const initials = p.name ? p.name.charAt(0).toUpperCase() : '?';
                const productImg = (p.image_url && !p.image_url.includes('placeholder')) 
                    ? `<img src="${p.image_url}" class="product-img" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(p.name)}&background=random&length=1&bold=true';">`
                    : `<div class="product-img" style="display: flex; align-items: center; justify-content: center; background: var(--primary-orange); color: #000; font-size: 2rem; font-weight: 900; text-transform: uppercase;">${initials}</div>`;
                
                return `
                    <tr class="${p.is_active ? '' : 'deactivated-row'}">
                        <td>
                            <div class="product-info">
                                ${productImg}
                                <div>
                                    <div class="product-name" style="display: flex; align-items: center; gap: 8px;">
                                        ${p.name}
                                        ${p.user_role === 'admin' ? '<span class="badge" style="background: var(--primary-blue); color: white; padding: 3px 6px; font-size: 0.65rem; box-shadow: 2px 2px 0px #000;">ADMIN</span>' : ''}
                                    </div>
                                    <div class="product-meta">ID: ${p.id}</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge badge-info">${p.category_name || 'Lainnya'}</span></td>
                        <td>
                            <div style="font-weight: 900;">${p.stock_quantity} ${p.unit}</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">Min: ${p.min_stock_level}</div>
                        </td>
                        <td>${p.expiry_date ? new Date(p.expiry_date).toLocaleDateString('id-ID') : '-'}</td>
                        <td><span class="badge ${stockBadge}">${stockText}</span></td>
                        <td>
                            <div class="action-group">
                                ${p.user_role === 'admin' ? `
                                    <button class="btn-icon edit" onclick="openEditModal(${p.id}, '${p.name.replace(/'/g, "\\'")}', '${p.category_name}', '${p.unit}', ${p.stock_quantity}, ${p.min_stock_level}, '${p.expiry_date || ''}', ${p.is_active})" title="Edit Produk Admin">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button class="btn-icon delete" onclick="deleteAdminProduct(${p.id})" title="Hapus Produk Admin">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                ` : (p.is_active ? `
                                    <button class="btn-icon delete" onclick="openDeactivateModal('${p.id}', '${p.name.replace(/'/g, "\\'")}')" title="Nonaktifkan">
                                        <i class="fas fa-ban"></i>
                                    </button>
                                ` : `
                                    <button class="btn-icon" onclick="reactivateProduct('${p.id}', '${p.name.replace(/'/g, "\\'")}')" title="Aktifkan" style="color: var(--accent-green); border-color: var(--accent-green);">
                                        <i class="fas fa-check"></i>
                                    </button>
                                `)}
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function renderPagination(pagination) {
            const container = document.getElementById('paginationButtons');
            if (!pagination || pagination.total_pages <= 1) {
                container.innerHTML = '';
                document.getElementById('paginationContainer').style.display = 'none';
                return;
            }

            document.getElementById('paginationContainer').style.display = 'flex';
            let html = '';
            
            html += `<button onclick="loadProducts(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>Prev</button>`;
            
            for (let i = 1; i <= pagination.total_pages; i++) {
                if (i === 1 || i === pagination.total_pages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                    html += `<button class="${i === currentPage ? 'active' : ''}" onclick="loadProducts(${i})">${i}</button>`;
                } else if (i === currentPage - 3 || i === currentPage + 3) {
                    html += `<button disabled>...</button>`;
                }
            }
            
            html += `<button onclick="loadProducts(${currentPage + 1})" ${currentPage === pagination.total_pages ? 'disabled' : ''}>Next</button>`;
            container.innerHTML = html;
        }

        function updatePaginationInfo(p) {
            document.getElementById('showingFrom').textContent = ((currentPage - 1) * currentLimit) + 1;
            document.getElementById('showingTo').textContent = Math.min(currentPage * currentLimit, p.total);
            document.getElementById('totalItems').textContent = p.total;
        }

        function debounceSearch() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => loadProducts(1), 500);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('categoryFilter').value = '';
            document.getElementById('stockStatusFilter').value = '';
            loadProducts(1);
        }

        function refreshData() {
            loadProducts(currentPage);
            loadProductStatistics();
            showToast('Data diperbarui', 'success');
        }

        function openAddModal() {
            document.getElementById('modalTitle').querySelector('span').textContent = 'Tambah Produk Baru';
            document.getElementById('productForm').reset();
            document.getElementById('editProductId').value = '';
            document.getElementById('btnSubmit').innerHTML = 'SIMPAN PRODUK';
            
            // Clear flatpickr input if exists
            const expiryPicker = document.querySelector("#productExpiryDate")._flatpickr;
            if (expiryPicker) {
                expiryPicker.clear();
                expiryPicker.altInput.disabled = false;
                expiryPicker.altInput.style.opacity = '1';
                expiryPicker.altInput.style.cursor = 'pointer';
            }
            
            document.getElementById('productNoExpiry').checked = false;
            
            document.getElementById('productModal').classList.add('active');
        }

        function openEditModal(id, name, category, unit, stock, minStock, expiryDate, isActive) {
            document.getElementById('modalTitle').querySelector('span').textContent = 'Edit Produk Admin';
            document.getElementById('productForm').reset();
            
            document.getElementById('editProductId').value = id;
            document.getElementById('productName').value = name;
            
            // Select dropdown options safely
            const catSelect = document.getElementById('productCategory');
            for(let i=0; i<catSelect.options.length; i++) {
                if(catSelect.options[i].value === category) { catSelect.selectedIndex = i; break; }
            }
            
            const unitSelect = document.getElementById('productUnit');
            for(let i=0; i<unitSelect.options.length; i++) {
                if(unitSelect.options[i].value === unit) { unitSelect.selectedIndex = i; break; }
            }
            
            document.getElementById('productStock').value = stock;
            document.getElementById('productMinStock').value = minStock;
            
            const expiryPicker = document.querySelector("#productExpiryDate")._flatpickr;
            if (expiryPicker && expiryDate) {
                expiryPicker.setDate(new Date(expiryDate));
                document.getElementById('productNoExpiry').checked = false;
                expiryPicker.altInput.disabled = false;
                expiryPicker.altInput.style.opacity = '1';
                expiryPicker.altInput.style.cursor = 'pointer';
            } else if (expiryPicker) {
                expiryPicker.clear();
                document.getElementById('productNoExpiry').checked = true;
                expiryPicker.altInput.disabled = true;
                expiryPicker.altInput.style.opacity = '0.5';
                expiryPicker.altInput.style.cursor = 'not-allowed';
            }
            
            document.getElementById('productIsActive').checked = (isActive === 1 || isActive === true || isActive === '1');
            document.getElementById('btnSubmit').innerHTML = 'UPDATE PRODUK';
            
            document.getElementById('productModal').classList.add('active');
        }

        async function deleteAdminProduct(id) {
            const confirm = await Swal.fire({
                title: 'Hapus Produk?',
                text: 'Produk ini akan dihapus secara permanen dari sistem.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Ya, Hapus!',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#EF4444',
                customClass: { popup: 'nb-popup', confirmButton: 'nb-btn', cancelButton: 'nb-btn' }
            });

            if (confirm.isConfirmed) {
                try {
                    document.getElementById('loadingOverlay').style.display = 'flex';
                    const res = await fetch(`/api/admin/products/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    document.getElementById('loadingOverlay').style.display = 'none';
                    if (data.success) {
                        showToast('Produk admin berhasil dihapus', 'success');
                        loadProducts(currentPage);
                        loadProductStatistics();
                    } else {
                        Swal.fire('Error!', data.message || 'Gagal menghapus produk.', 'error');
                    }
                } catch (err) {
                    console.error(err);
                    document.getElementById('loadingOverlay').style.display = 'none';
                    Swal.fire('Error!', 'Terjadi kesalahan sistem.', 'error');
                }
            }
        }

        function closeModal() {
            document.getElementById('productModal').classList.remove('active');
        }

        function toggleExpiryDate() {
            const noExpiry = document.getElementById('productNoExpiry').checked;
            const fp = document.querySelector("#productExpiryDate")._flatpickr;
            if (fp) {
                if (noExpiry) {
                    fp.clear();
                    fp.altInput.disabled = true;
                    fp.altInput.style.opacity = '0.5';
                    fp.altInput.style.cursor = 'not-allowed';
                } else {
                    fp.altInput.disabled = false;
                    fp.altInput.style.opacity = '1';
                    fp.altInput.style.cursor = 'pointer';
                }
            }
        }

        async function handleFormSubmit() {
            const id = document.getElementById('editProductId').value;
            const formData = {
                name: document.getElementById('productName').value,
                category: document.getElementById('productCategory').value,
                unit: document.getElementById('productUnit').value,
                stock_quantity: parseFloat(document.getElementById('productStock').value),
                min_stock_level: parseFloat(document.getElementById('productMinStock').value),
                expiry_date: document.getElementById('productNoExpiry').checked ? null : document.getElementById('productExpiryDate').value,
                is_active: document.getElementById('productIsActive').checked
            };

            if (!formData.name || isNaN(formData.stock_quantity) || isNaN(formData.min_stock_level)) {
                showToast('Harap isi field yang wajib (*)', 'error');
                return;
            }

            document.getElementById('loadingOverlay').style.display = 'flex';

            try {
                const method = id ? 'PUT' : 'POST';
                const url = id ? `/api/admin/products/${id}` : '/api/admin/products';
                const res = await fetch(url, {
                    method: method,
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                const data = await res.json();
                
                document.getElementById('loadingOverlay').style.display = 'none';

                if (data.success) {
                    Swal.fire({
                        title: id ? 'PRODUK DIPERBARUI!' : 'PRODUK DITAMBAHKAN!',
                        html: `<p style="font-weight:700;">Produk <strong style="color:var(--primary-blue);">${formData.name}</strong> berhasil ${id ? 'diperbarui' : 'ditambahkan ke dalam sistem'}.</p>`,
                        icon: 'success',
                        confirmButtonText: 'MANTAP',
                        confirmButtonColor: 'var(--primary-blue)',
                        customClass: { popup: 'nb-popup', confirmButton: 'nb-btn' }
                    });
                    closeModal();
                    loadProducts(currentPage);
                    loadProductStatistics();
                } else {
                    Swal.fire({
                        title: 'GAGAL!',
                        text: data.message || 'Gagal menyimpan produk',
                        icon: 'error',
                        confirmButtonText: 'TUTUP',
                        confirmButtonColor: 'var(--accent-red)',
                        customClass: { popup: 'nb-popup', confirmButton: 'nb-btn' }
                    });
                }
            } catch (error) {
                console.error('Error save:', error);
                document.getElementById('loadingOverlay').style.display = 'none';
                Swal.fire({
                    title: 'ERROR!',
                    text: 'Terjadi kesalahan pada sistem.',
                    icon: 'error',
                    confirmButtonText: 'TUTUP',
                    confirmButtonColor: 'var(--accent-red)',
                    customClass: { popup: 'nb-popup', confirmButton: 'nb-btn' }
                });
            }
        }

        function openDeactivateModal(id, name) {
            deactivateProductTargetId = id;
            document.getElementById('deactivateProductName').textContent = name;
            document.getElementById('deactivateReason').value = '';
            document.getElementById('deactivateModal').classList.add('active');
        }

        function closeDeactivateModal() {
            document.getElementById('deactivateModal').classList.remove('active');
        }

        async function confirmDeactivate() {
            const reason = document.getElementById('deactivateReason').value.trim();
            if (!reason) {
                showToast('Harap isi alasan', 'error');
                return;
            }

            document.getElementById('loadingOverlay').style.display = 'flex';
            try {
                const res = await fetch(`/api/admin/products/${deactivateProductTargetId}/deactivate`, {
                    method: 'PATCH',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reason })
                });
                const data = await res.json();
                document.getElementById('loadingOverlay').style.display = 'none';
                if (data.success) {
                    showToast('Produk dinonaktifkan', 'success');
                    closeDeactivateModal();
                    loadProducts(currentPage);
                    loadProductStatistics();
                }
            } catch (error) { console.error('Error deactivate:', error); document.getElementById('loadingOverlay').style.display = 'none'; }
        }

        async function reactivateProduct(id, name) {
            const result = await Swal.fire({
                title: 'Aktifkan Kembali?',
                text: `Aktifkan kembali produk ${name}?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#10B981',
                confirmButtonText: 'Ya, Aktifkan'
            });

            if (result.isConfirmed) {
                document.getElementById('loadingOverlay').style.display = 'flex';
                try {
                    const res = await fetch(`/api/admin/products/${id}/reactivate`, {
                        method: 'PATCH',
                        credentials: 'same-origin'
                    });
                    const data = await res.json();
                    document.getElementById('loadingOverlay').style.display = 'none';
                    if (data.success) {
                        showToast('Produk diaktifkan kembali', 'success');
                        loadProducts(currentPage);
                        loadProductStatistics();
                    }
                } catch (error) { console.error('Error reactivate:', error); document.getElementById('loadingOverlay').style.display = 'none'; }
            }
        }
    </script>
</body>
</html>
