<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Pengguna - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-dark: #1D4ED8;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-sidebar-hover: #F3F4F6;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #1E293B;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-color: #000000;
            --sidebar-width: 280px;
            --header-height: 80px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1E293B;
            --bg-sidebar-hover: #334155;
            --bg-body: #0F172A;
            --bg-card: #1E293B;
            --text-main: #F1F5F9;
            --text-muted: #94A3B8;
            --border-color: #F1F5F9;
            --shadow-color: #3B82F6;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Neubrutalism UI Components */
        .nb-card {
            background: var(--bg-card);
            border: 4px solid var(--border-color);
            box-shadow: 8px 8px 0px var(--shadow-color);
            padding: 24px;
            transition: all 0.2s ease;
        }

        .nb-card:hover {
            transform: translate(-2px, -2px);
            box-shadow: 12px 12px 0px var(--shadow-color);
        }

        .nb-btn {
            padding: 12px 24px;
            border: 4px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-main);
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 4px 4px 0px var(--shadow-color);
            transition: all 0.1s ease;
            font-size: 0.9rem;
        }

        .nb-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--shadow-color);
        }

        .nb-btn:active {
            transform: translate(2px, 2px);
            box-shadow: 0px 0px 0px var(--shadow-color);
        }

        .nb-btn-primary { background: var(--primary-blue); color: #fff; }
        .nb-btn-success { background: var(--accent-green); color: #fff; }
        .nb-btn-danger { background: var(--accent-red); color: #fff; }
        .nb-btn-warning { background: var(--primary-orange); color: #fff; }

        /* Sidebar Overlay */
        #sidebarOverlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 998;
            display: none;
        }
        #sidebarOverlay.active { display: block; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 40px;
            max-width: 1600px;
        }

        @media (max-width: 992px) {
            .main-content { margin-left: 0; padding: 24px; }
            .page-title { font-size: 2rem; }
        }

        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        /* Stats Section */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        .stat-card {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .stat-label {
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .stat-value {
            font-size: 2.5rem;
            font-weight: 900;
            line-height: 1;
        }

        /* Table Section */
        .panel-card {
            overflow: hidden;
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 20px;
        }

        .search-box {
            position: relative;
            flex: 1;
            min-width: 300px;
        }

        .nb-input {
            width: 100%;
            padding: 14px 20px;
            border: 4px solid var(--border-color);
            background: #fff;
            color: #000;
            font-weight: 700;
            font-size: 1rem;
            outline: none;
            box-shadow: 4px 4px 0px var(--shadow-color);
        }

        .nb-input:focus {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--shadow-color);
        }

        .table-container {
            width: 100%;
            overflow-x: auto;
            border: 4px solid var(--border-color);
            background: var(--bg-card);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            background: var(--primary-blue);
            color: #fff;
            text-align: left;
            padding: 18px;
            font-weight: 900;
            text-transform: uppercase;
            border-bottom: 4px solid var(--border-color);
            white-space: nowrap;
        }

        td {
            padding: 18px;
            border-bottom: 4px solid var(--border-color);
            font-weight: 600;
        }

        tr:last-child td { border-bottom: none; }
        tr:hover td { background: var(--bg-sidebar-hover); }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .user-avatar {
            width: 48px;
            height: 48px;
            border: 3px solid var(--border-color);
            background: var(--primary-orange);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: 900;
            color: #fff;
            flex-shrink: 0;
            overflow: hidden;
        }

        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.8);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            backdrop-filter: blur(8px);
        }
        .modal-overlay.active { display: flex; }

        .form-input {
            width: 100%;
            padding: 12px 16px;
            border: 3px solid var(--border-color);
            background: var(--bg-body);
            color: var(--text-main);
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Outfit', sans-serif;
            border-radius: 0;
            box-shadow: 4px 4px 0px var(--border-color);
            transition: transform 0.2s, box-shadow 0.2s;
            outline: none;
        }

        .form-input:focus {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--border-color);
            border-color: var(--primary-blue);
        }

        .badge {
            display: inline-block;
            padding: 6px 12px;
            border: 2px solid var(--border-color);
            font-weight: 800;
            font-size: 0.75rem;
            text-transform: uppercase;
        }

        .badge-success { background: var(--accent-green); color: #fff; }
        .badge-danger { background: var(--accent-red); color: #fff; }
        .badge-warning { background: var(--primary-orange); color: #fff; }
        .badge-info { background: var(--primary-blue); color: #fff; }

        /* Modal Styling */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.8);
            z-index: 2000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal.active { display: flex; }

        .modal-content {
            background: var(--bg-card);
            border: 4px solid var(--border-color);
            width: 100%;
            max-width: 600px;
            box-shadow: 16px 16px 0px var(--shadow-color);
            position: relative;
            animation: modalSlide 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes modalSlide {
            from { transform: translateY(50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .modal-header {
            padding: 24px;
            border-bottom: 4px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--primary-blue);
            color: #fff;
        }

        .modal-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; }

        .modal-body { padding: 24px; }
        .modal-footer {
            padding: 24px;
            border-top: 4px solid var(--border-color);
            display: flex;
            justify-content: flex-end;
            gap: 15px;
        }

        .form-group { margin-bottom: 20px; }
        .form-group label {
            display: block;
            font-weight: 800;
            margin-bottom: 8px;
            text-transform: uppercase;
            font-size: 0.85rem;
        }

        /* Toast Container */
        .toast-container {
            position: fixed;
            top: 24px;
            right: 24px;
            z-index: 3000;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .toast {
            background: var(--bg-card);
            border: 4px solid var(--border-color);
            padding: 16px 24px;
            box-shadow: 8px 8px 0px var(--shadow-color);
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: toastIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes toastIn {
            from { transform: translateX(100%); }
            to { transform: translateX(0); }
        }

        .btn-icon {
            width: 40px;
            height: 40px;
            border: 3px solid var(--border-color);
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 3px 3px 0px var(--shadow-color);
            transition: all 0.1s;
            text-decoration: none;
            color: var(--text-main);
        }

        .btn-icon:hover {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0px var(--shadow-color);
        }

        .btn-icon.edit { color: var(--primary-blue); }
        .btn-icon.delete { color: var(--accent-red); }
        .btn-icon.status { color: var(--primary-orange); }

    </style>
</head>
<body>

    <!-- Sidebar -->
    <%- include('./partials/admin-sidebar', { currentPage: 'users', user: typeof user !== 'undefined' ? user : null }) %>

    <!-- Main Content -->
    <main class="main-content">
        <button class="menu-toggle" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <div class="header-section">
            <h1 class="page-title">Manajemen Pengguna</h1>
            <div style="display: flex; gap: 15px;">
                <button class="nb-btn" id="themeToggleBtn" onclick="toggleTheme()">
                    <i class="fas fa-moon"></i> Tema
                </button>
                <button class="nb-btn nb-btn-primary" onclick="openCreateModal()">
                    <i class="fas fa-user-plus"></i> Tambah User
                </button>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="nb-card stat-card" style="border-left: 12px solid var(--primary-blue);">
                <div class="stat-label">Total Pengguna</div>
                <div class="stat-value" id="statTotalUsers">0</div>
            </div>
            <div class="nb-card stat-card" style="border-left: 12px solid var(--accent-green);">
                <div class="stat-label">Pengguna Aktif</div>
                <div class="stat-value" id="statActiveUsers">0</div>
            </div>
            <div class="nb-card stat-card" style="border-left: 12px solid var(--accent-red);">
                <div class="stat-label">Pengguna Non-Aktif</div>
                <div class="stat-value" id="statInactiveUsers">0</div>
            </div>
            <div class="nb-card stat-card" style="border-left: 12px solid var(--primary-orange);">
                <div class="stat-label">Administrator</div>
                <div class="stat-value" id="statAdminUsers">0</div>
            </div>
        </div>

        <!-- Filter & Search -->
        <div class="nb-card panel-card">
            <div class="panel-header">
                <div class="search-box">
                    <input type="text" id="searchInput" class="nb-input" placeholder="Cari nama atau email..." onkeyup="debounceSearch()">
                </div>
                <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                    <select id="roleFilter" class="nb-input" style="width: auto;" onchange="loadUsers(1)">
                        <option value="">Semua Role</option>
                        <option value="admin">Admin</option>
                        <option value="user">User</option>
                    </select>
                    <select id="statusFilter" class="nb-input" style="width: auto;" onchange="loadUsers(1)">
                        <option value="">Semua Status</option>
                        <option value="active">Aktif</option>
                        <option value="inactive">Non-Aktif</option>
                        <option value="suspended">Ditangguhkan</option>
                    </select>
                    <button class="nb-btn" onclick="resetFilters()">
                        <i class="fas fa-sync-alt"></i> Reset
                    </button>
                </div>
            </div>

            <!-- Table -->
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Pengguna</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Bergabung</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="usersTableBody">
                        <!-- Data loaded via JS -->
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div style="margin-top: 30px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px;">
                <div style="font-weight: 800; font-size: 0.9rem; text-transform: uppercase; color: var(--text-muted);">
                    Menampilkan <span id="showingFrom">0</span> - <span id="showingTo">0</span> dari <span id="totalItems">0</span> data
                </div>
                <div id="paginationButtons" style="display: flex; gap: 10px;">
                    <!-- Pagination buttons -->
                </div>
            </div>
        </div>
    </main>

    <!-- Modal User -->
    <div class="modal" id="userModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title" id="modalTitle">Tambah User</h3>
                <button class="nb-btn" style="padding: 8px 12px;" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="editUserId">
                    <div class="form-group">
                        <label>Nama Lengkap</label>
                        <input type="text" id="userName" class="nb-input" placeholder="Masukkan nama lengkap..." required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="userEmail" class="nb-input" placeholder="email@contoh.com..." required>
                    </div>
                    <div class="form-group" id="passwordGroup">
                        <label>Password</label>
                        <input type="password" id="userPassword" class="nb-input" placeholder="Minimal 6 karakter...">
                    </div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="form-group">
                            <label>Role</label>
                            <select id="userRole" class="nb-input">
                                <option value="user">User</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Status</label>
                            <select id="userStatus" class="nb-input">
                                <option value="active">Aktif</option>
                                <option value="inactive">Non-Aktif</option>
                                <option value="suspended">Ditangguhkan</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="nb-btn" onclick="closeModal()">Batal</button>
                <button class="nb-btn nb-btn-primary" onclick="handleFormSubmit()">Simpan User</button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        let currentPage = 1;
        let currentLimit = 10;
        let searchTimer = null;

        function toggleTheme() {
            if (window.toggleAppTheme) window.toggleAppTheme();
        }

        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const btn = document.getElementById('themeToggleBtn');
            btn.innerHTML = isDark ? '<i class="fas fa-sun"></i> Tema' : '<i class="fas fa-moon"></i> Tema';
        });

        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const btn = document.getElementById('themeToggleBtn');
            if (btn) btn.innerHTML = isDark ? '<i class="fas fa-sun"></i> Tema' : '<i class="fas fa-moon"></i> Tema';
            
            loadUsers();
            loadUserStatistics();
        });

        async function loadUserStatistics() {
            try {
                const res = await fetch('/api/users/statistics', { credentials: 'same-origin' });
                const result = await res.json();
                if (result.success) {
                    const stats = result.data;
                    document.getElementById('statTotalUsers').textContent = stats.total_users || 0;
                    document.getElementById('statActiveUsers').textContent = stats.active_users || 0;
                    document.getElementById('statInactiveUsers').textContent = stats.inactive_users || 0;
                    document.getElementById('statAdminUsers').textContent = stats.admin_users || 0;
                }
            } catch (err) { console.error('Error stats:', err); }
        }

        async function loadUsers(page = 1) {
            currentPage = page;
            const search = document.getElementById('searchInput').value;
            const status = document.getElementById('statusFilter').value;
            const role = document.getElementById('roleFilter').value;

            const url = `/api/users?page=${page}&limit=${currentLimit}&search=${encodeURIComponent(search)}&status=${status}&role=${role}`;
            
            try {
                const res = await fetch(url, { credentials: 'same-origin' });
                const result = await res.json();
                if (result.success) {
                    renderUsers(result.data);
                    renderPagination(result.pagination);
                    updatePaginationInfo(result.pagination);
                }
            } catch (err) { console.error('Error users:', err); }
        }

        function renderUsers(users) {
            const tbody = document.getElementById('usersTableBody');
            if (!users || users.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 50px;">Tidak ada data ditemukan</td></tr>';
                return;
            }

            tbody.innerHTML = users.map(u => {
                const initials = u.name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
                const statusBadge = u.account_status === 'active' ? 'badge-success' : (u.account_status === 'inactive' ? 'badge-danger' : 'badge-warning');
                const roleBadge = u.role === 'admin' ? 'badge-info' : 'badge-warning';
                
                return `
                    <tr>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar">${u.profile_image && !u.profile_image.includes('placeholder-product') ? `<img src="${u.profile_image}" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(u.name)}&background=random';" style="width:100%; height:100%; object-fit:cover;">` : initials}</div>
                                <div>
                                    <div style="font-weight: 800;">${u.name}</div>
                                    <div style="font-size: 0.8rem; color: var(--text-muted);">ID: ${u.id}</div>
                                </div>
                            </div>
                        </td>
                        <td>${u.email}</td>
                        <td><span class="badge ${roleBadge}">${u.role}</span></td>
                        <td><span class="badge ${statusBadge}">${u.account_status}</span></td>
                        <td>${new Date(u.created_at).toLocaleDateString('id-ID')}</td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                ${u.role !== 'admin' ? `<button class="btn-icon" onclick="viewUserDetails(${u.id})" title="Detail User" style="background: var(--primary-blue); color: white; border: 2px solid #000;"><i class="fas fa-eye"></i></button>` : ''}
                                <button class="btn-icon status" onclick="toggleStatus(${u.id})" title="Toggle Status"><i class="fas fa-sync"></i></button>
                                ${u.role === 'admin' ? `
                                    <button class="btn-icon" onclick="editAdminUser(${u.id}, '${u.name.replace(/'/g, "\\'")}', '${u.email}', '${u.role}', '${u.account_status}')" title="Edit Admin" style="background: var(--primary-blue); color: white; border: 2px solid #000;"><i class="fas fa-edit"></i></button>
                                    <button class="btn-icon" onclick="deleteAdminUser(${u.id})" title="Hapus Admin" style="background: var(--accent-red); color: white; border: 2px solid #000;"><i class="fas fa-trash"></i></button>
                                ` :
                                    (u.account_status === 'banned' ? 
                                    `<button class="btn-icon" onclick="unbanUser(${u.id})" title="Unban User" style="background: var(--accent-green); color: black; border: 2px solid #000;"><i class="fas fa-user-check"></i></button>` : 
                                    `<button class="btn-icon" onclick="openBanModal(${u.id})" title="Ban User" style="background: var(--primary-orange); color: black; border: 2px solid #000;"><i class="fas fa-ban"></i></button>`)
                                }
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        function renderPagination(p) {
            const container = document.getElementById('paginationButtons');
            if (!p || p.totalPages <= 1) {
                container.innerHTML = '';
                return;
            }

            let html = `<button class="nb-btn" onclick="loadUsers(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''} style="padding: 8px 12px;">Prev</button>`;
            
            for (let i = 1; i <= p.totalPages; i++) {
                if (i === 1 || i === p.totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                    html += `<button class="nb-btn ${i === currentPage ? 'nb-btn-primary' : ''}" onclick="loadUsers(${i})" style="padding: 8px 12px;">${i}</button>`;
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                    html += `<span style="font-weight: 800;">...</span>`;
                }
            }

            html += `<button class="nb-btn" onclick="loadUsers(${currentPage + 1})" ${currentPage === p.totalPages ? 'disabled' : ''} style="padding: 8px 12px;">Next</button>`;
            container.innerHTML = html;
        }

        function updatePaginationInfo(p) {
            document.getElementById('showingFrom').textContent = ((currentPage - 1) * currentLimit) + 1;
            document.getElementById('showingTo').textContent = Math.min(currentPage * currentLimit, p.total);
            document.getElementById('totalItems').textContent = p.total;
        }

        function debounceSearch() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => loadUsers(1), 500);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('roleFilter').value = '';
            document.getElementById('statusFilter').value = '';
            loadUsers(1);
        }

        function openCreateModal() {
            document.getElementById('modalTitle').textContent = 'Tambah User';
            document.getElementById('userForm').reset();
            document.getElementById('editUserId').value = '';
            document.getElementById('passwordGroup').style.display = 'block';
            document.getElementById('userModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('userModal').classList.remove('active');
        }

        async function handleFormSubmit() {
            const id = document.getElementById('editUserId').value;
            const data = {
                name: document.getElementById('userName').value,
                email: document.getElementById('userEmail').value,
                role: document.getElementById('userRole').value,
                account_status: document.getElementById('userStatus').value
            };

            if (!id) {
                data.password = document.getElementById('userPassword').value;
                if (!data.password || data.password.length < 6) {
                    showToast('Password minimal 6 karakter', 'error');
                    return;
                }
            }

            try {
                const method = id ? 'PUT' : 'POST';
                const url = id ? `/api/users/${id}` : '/api/users';
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                    credentials: 'same-origin'
                });
                const result = await res.json();
                if (result.success) {
                    showToast(id ? 'User diperbarui' : 'User ditambahkan', 'success');
                    closeModal();
                    loadUsers(currentPage);
                    loadUserStatistics();
                } else {
                    showToast(result.message || 'Gagal menyimpan user', 'error');
                }
            } catch (err) { showToast('Terjadi kesalahan', 'error'); }
        }

        async function toggleStatus(id) {
            try {
                const res = await fetch(`/api/users/${id}/toggle-status`, { method: 'PATCH', credentials: 'same-origin' });
                const result = await res.json();
                if (result.success) {
                    showToast('Status diperbarui', 'success');
                    loadUsers(currentPage);
                    loadUserStatistics();
                }
            } catch (err) { console.error('Error status:', err); }
        }

        let currentBanUserId = null;
        async function openBanModal(id) {
            const confirm = await Swal.fire({
                title: 'Ban User?',
                text: 'Apakah Anda yakin ingin mem-ban pengguna ini? Anda akan dimintai alasan dan durasi setelah ini.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Ya, Lanjutkan',
                cancelButtonText: 'Batal',
                customClass: { popup: 'nb-popup', confirmButton: 'nb-btn nb-btn-primary', cancelButton: 'nb-btn' }
            });
            
            if (confirm.isConfirmed) {
                currentBanUserId = id;
                document.getElementById('banReason').value = '';
                document.getElementById('banDuration').value = '1';
                document.getElementById('banModal').classList.add('active');
            }
        }

        function closeBanModal() {
            currentBanUserId = null;
            document.getElementById('banModal').classList.remove('active');
        }

        async function submitBan(e) {
            e.preventDefault();
            if (!currentBanUserId) return;
            
            const reason = document.getElementById('banReason').value;
            const durationDays = parseInt(document.getElementById('banDuration').value) || 1;
            
            const banUntil = new Date();
            if (durationDays === 9999) { // 9999 means permanent
                banUntil.setFullYear(banUntil.getFullYear() + 100);
            } else {
                banUntil.setDate(banUntil.getDate() + durationDays);
            }

            try {
                const res = await fetch(`/api/users/${currentBanUserId}/ban`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reason, banUntil: banUntil.toISOString() })
                });
                const data = await res.json();
                
                if (data.success) {
                    Swal.fire({ title: 'Berhasil!', text: 'User berhasil di-ban.', icon: 'success', customClass: { popup: 'nb-popup', confirmButton: 'nb-btn nb-btn-primary' } });
                    closeBanModal();
                    loadUsers(currentPage);
                    loadUserStatistics();
                } else {
                    Swal.fire('Error!', data.message || 'Gagal melakukan ban.', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error!', 'Terjadi kesalahan sistem.', 'error');
            }
        }

        async function unbanUser(id) {
            const confirm = await Swal.fire({
                title: 'Unban User?',
                text: 'User akan dapat login kembali.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Ya, Unban!',
                cancelButtonText: 'Batal',
                customClass: { popup: 'nb-popup', confirmButton: 'nb-btn nb-btn-primary', cancelButton: 'nb-btn' }
            });

            if (confirm.isConfirmed) {
                try {
                    const res = await fetch(`/api/users/${id}/unban`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire({ title: 'Berhasil!', text: 'User berhasil di-unban.', icon: 'success', customClass: { popup: 'nb-popup', confirmButton: 'nb-btn nb-btn-primary' } });
                        loadUsers(currentPage);
                        loadUserStatistics();
                    } else {
                        Swal.fire('Error!', data.message || 'Gagal unban user.', 'error');
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire('Error!', 'Terjadi kesalahan sistem.', 'error');
                }
            }
        }

        async function viewUserDetails(id) {
            try {
                const res = await fetch(`/api/users/${id}`, { credentials: 'same-origin' });
                const result = await res.json();
                
                if (result.success && result.data) {
                    const u = result.data;
                    const joinDate = new Date(u.created_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
                    const initials = u.name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
                    
                    const profileImg = (u.profile_image && !u.profile_image.includes('placeholder-product')) 
                        ? `<img src="${u.profile_photo_url || u.profile_image}" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(u.name)}&background=random';" style="width:90px; height:90px; border-radius:50%; object-fit:cover; border:3px solid #000; position: relative; z-index: 1;">` 
                        : `<div style="width:90px; height:90px; border-radius:50%; border:3px solid #000; background:var(--primary-blue); color:white; display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:900; margin:0 auto; position: relative; z-index: 1;">${initials}</div>`;
                    
                    let banInfo = '';
                    if (u.account_status === 'banned') {
                        const banDate = u.ban_until ? new Date(u.ban_until).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Permanen';
                        banInfo = `
                            <div style="background: var(--accent-red); padding: 15px; margin-top: 20px; border: 3px solid #000; box-shadow: 4px 4px 0px #000; text-align: left; position: relative; overflow: hidden;">
                                <div style="position: absolute; right: -15px; top: -15px; opacity: 0.2; font-size: 5rem; color: #000;"><i class="fas fa-ban"></i></div>
                                <div style="position: relative; z-index: 1;">
                                    <h4 style="margin:0 0 5px 0; font-weight:900; color:#000; text-transform:uppercase; font-size: 1.1rem;"><i class="fas fa-exclamation-triangle"></i> AKUN DIBANNED</h4>
                                    <p style="margin:0; font-size:0.9rem; color:#000; font-weight: 700;">Sampai: ${banDate}</p>
                                    <p style="margin:5px 0 0; font-size:0.95rem; color:#000; font-weight: 800; background: rgba(255,255,255,0.4); padding: 8px; border: 2px solid #000; border-radius: 8px;">Alasan: ${u.ban_reason || 'Pelanggaran ketentuan'}</p>
                                </div>
                            </div>
                        `;
                    }
                    
                    let statusColor = 'var(--accent-green)';
                    if (u.account_status === 'inactive') statusColor = '#9CA3AF';
                    if (u.account_status === 'suspended') statusColor = 'var(--primary-orange)';
                    if (u.account_status === 'banned') statusColor = 'var(--accent-red)';
                    
                    const roleColor = u.role === 'admin' ? 'var(--primary-blue)' : '#FCD34D';

                    Swal.fire({
                        html: `
                            <div style="padding: 5px;">
                                <!-- Header Section -->
                                <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 30px;">
                                    <div style="position: relative; margin-bottom: 15px; display: inline-block;">
                                        <div style="position: absolute; top: 5px; left: 5px; width: 100%; height: 100%; background: var(--primary-orange); border-radius: 50%; border: 3px solid #000; z-index: 0;"></div>
                                        ${profileImg}
                                    </div>
                                    <h3 style="margin: 0; font-weight: 900; font-size: 1.8rem; text-transform: uppercase; letter-spacing: -0.5px; color: var(--text-main);">${u.name}</h3>
                                    <div style="margin: 8px 0 0; color: var(--text-main); font-weight: 700; font-size: 0.95rem; background: var(--bg-body); padding: 6px 16px; border: 2px solid #000; border-radius: 20px; box-shadow: 3px 3px 0px #000; display: inline-block;">${u.email}</div>
                                </div>
                                
                                <!-- Stats/Info Grid -->
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
                                    <!-- Role Box -->
                                    <div style="background: ${roleColor}; padding: 15px; border: 3px solid #000; box-shadow: 4px 4px 0px #000; text-align: center; border-radius: 8px;">
                                        <div style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; margin-bottom: 5px; color: #000; letter-spacing: 1px;">Role</div>
                                        <div style="font-size: 1.2rem; font-weight: 900; color: #000; text-transform: uppercase;">${u.role}</div>
                                    </div>
                                    <!-- Status Box -->
                                    <div style="background: ${statusColor}; padding: 15px; border: 3px solid #000; box-shadow: 4px 4px 0px #000; text-align: center; border-radius: 8px;">
                                        <div style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; margin-bottom: 5px; color: #000; letter-spacing: 1px;">Status</div>
                                        <div style="font-size: 1.2rem; font-weight: 900; color: #000; text-transform: uppercase;">${u.account_status}</div>
                                    </div>
                                </div>
                                
                                <!-- Timeline Info -->
                                <div style="background: var(--bg-card); border: 3px solid #000; padding: 20px; box-shadow: 5px 5px 0px #000; text-align: left; border-radius: 8px;">
                                    <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px; border-bottom: 3px solid #000; padding-bottom: 15px;">
                                        <div style="width: 40px; height: 40px; background: #DBEAFE; border: 2px solid #000; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border-radius: 8px; color: #1D4ED8;">
                                            <i class="fas fa-calendar-alt"></i>
                                        </div>
                                        <div>
                                            <div style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1px;">Bergabung Sejak</div>
                                            <div style="font-size: 1.05rem; font-weight: 800; color: var(--text-main);">${joinDate}</div>
                                        </div>
                                    </div>
                                    <div style="display: flex; align-items: center; gap: 15px;">
                                        <div style="width: 40px; height: 40px; background: #D1FAE5; border: 2px solid #000; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; border-radius: 8px; color: #047857;">
                                            <i class="fas fa-sign-in-alt"></i>
                                        </div>
                                        <div>
                                            <div style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1px;">Terakhir Login</div>
                                            <div style="font-size: 1.05rem; font-weight: 800; color: var(--text-main);">${u.last_login ? new Date(u.last_login).toLocaleDateString('id-ID', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'Belum pernah'}</div>
                                        </div>
                                    </div>
                                </div>
                                
                                ${banInfo}
                            </div>
                        `,
                        showCloseButton: true,
                        showConfirmButton: false,
                        width: '450px',
                        padding: '1.5em',
                        customClass: { popup: 'nb-popup', closeButton: 'nb-close-btn' }
                    });
                } else {
                    Swal.fire('Error', 'Gagal memuat detail user', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Error', 'Terjadi kesalahan jaringan', 'error');
            }
        }

        async function editAdminUser(id, name, email, role, status) {
            const { value: formValues } = await Swal.fire({
                title: 'Edit Admin User',
                html: `
                    <div style="text-align: left;">
                        <label style="font-weight: 800; font-size: 0.9rem; margin-bottom: 5px; display: block; text-transform: uppercase;">Nama Lengkap</label>
                        <input id="swal-name" class="form-input" style="width: 100%; margin-bottom: 15px;" value="${name}">
                        
                        <label style="font-weight: 800; font-size: 0.9rem; margin-bottom: 5px; display: block; text-transform: uppercase;">Email</label>
                        <input id="swal-email" type="email" class="form-input" style="width: 100%; margin-bottom: 15px;" value="${email}">
                        
                        <label style="font-weight: 800; font-size: 0.9rem; margin-bottom: 5px; display: block; text-transform: uppercase;">Role</label>
                        <select id="swal-role" class="form-input" style="width: 100%; margin-bottom: 15px; cursor: pointer;">
                            <option value="admin" ${role === 'admin' ? 'selected' : ''}>Admin</option>
                            <option value="user" ${role === 'user' ? 'selected' : ''}>User</option>
                        </select>
                        
                        <label style="font-weight: 800; font-size: 0.9rem; margin-bottom: 5px; display: block; text-transform: uppercase;">Status</label>
                        <select id="swal-status" class="form-input" style="width: 100%; margin-bottom: 15px; cursor: pointer;">
                            <option value="active" ${status === 'active' ? 'selected' : ''}>Active</option>
                            <option value="inactive" ${status === 'inactive' ? 'selected' : ''}>Inactive</option>
                            <option value="suspended" ${status === 'suspended' ? 'selected' : ''}>Suspended</option>
                            <option value="banned" ${status === 'banned' ? 'selected' : ''}>Banned</option>
                        </select>
                    </div>
                `,
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonText: 'Simpan',
                cancelButtonText: 'Batal',
                customClass: { popup: 'nb-popup', confirmButton: 'nb-btn nb-btn-primary', cancelButton: 'nb-btn' },
                preConfirm: () => {
                    return {
                        name: document.getElementById('swal-name').value,
                        email: document.getElementById('swal-email').value,
                        role: document.getElementById('swal-role').value,
                        account_status: document.getElementById('swal-status').value
                    }
                }
            });

            if (formValues) {
                try {
                    const res = await fetch(`/api/users/${id}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formValues)
                    });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire({ title: 'Berhasil!', text: 'Admin user berhasil diperbarui.', icon: 'success', customClass: { popup: 'nb-popup', confirmButton: 'nb-btn nb-btn-primary' } });
                        loadUsers(currentPage);
                    } else {
                        Swal.fire('Error!', data.message || 'Gagal memperbarui user.', 'error');
                    }
                } catch (err) {
                    Swal.fire('Error!', 'Terjadi kesalahan sistem.', 'error');
                }
            }
        }

        async function deleteAdminUser(id) {
            const confirm = await Swal.fire({
                title: 'Hapus Admin?',
                text: 'Admin ini akan dihapus secara soft-delete (inactive).',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Ya, Hapus!',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#EF4444',
                customClass: { popup: 'nb-popup', confirmButton: 'nb-btn', cancelButton: 'nb-btn' }
            });

            if (confirm.isConfirmed) {
                try {
                    const res = await fetch(`/api/users/${id}`, { method: 'DELETE' });
                    const data = await res.json();
                    if (data.success) {
                        Swal.fire({ title: 'Berhasil!', text: 'Admin berhasil dihapus.', icon: 'success', customClass: { popup: 'nb-popup', confirmButton: 'nb-btn nb-btn-primary' } });
                        loadUsers(currentPage);
                        loadUserStatistics();
                    } else {
                        Swal.fire('Error!', data.message || 'Gagal menghapus admin.', 'error');
                    }
                } catch (err) {
                    console.error(err);
                    Swal.fire('Error!', 'Terjadi kesalahan sistem.', 'error');
                }
            }
        }

        function showToast(msg, type = 'success') {
            const container = document.getElementById('toastContainer');
            const t = document.createElement('div');
            t.className = `toast`;
            t.style.borderLeftColor = type === 'success' ? 'var(--accent-green)' : 'var(--accent-red)';
            t.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}" style="color:${type === 'success' ? 'var(--accent-green)' : 'var(--accent-red)'}"></i> ${msg}`;
            container.appendChild(t);
            setTimeout(() => {
                t.style.opacity = '0';
                t.style.transform = 'translateX(50px)';
                setTimeout(() => t.remove(), 300);
            }, 3000);
        }

        async function handleLogout() {
            await fetch('/auth/logout', { method: 'POST' });
            window.location.href = '/';
        }
    </script>
    
    <!-- Ban Modal -->
    <div class="modal-overlay" id="banModal">
        <div class="nb-card" style="width: 100%; max-width: 400px; margin: 20px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2 style="font-weight: 900; text-transform: uppercase;">Ban User</h2>
                <button class="btn-icon delete" onclick="closeBanModal()"><i class="fas fa-times"></i></button>
            </div>
            <form id="banForm" onsubmit="submitBan(event)">
                <div class="form-group" style="margin-bottom: 20px;">
                    <label class="form-label" style="font-weight: 800; font-size: 0.9rem; margin-bottom: 8px; display: block; text-transform: uppercase;">Alasan Ban</label>
                    <textarea id="banReason" class="form-input" rows="3" required placeholder="Contoh: Melanggar kebijakan spam..."></textarea>
                </div>
                <div class="form-group" style="margin-bottom: 25px;">
                    <label class="form-label" style="font-weight: 800; font-size: 0.9rem; margin-bottom: 8px; display: block; text-transform: uppercase;">Durasi Ban (Hari)</label>
                    <select id="banDuration" class="form-input" style="cursor: pointer;">
                        <option value="1">1 Hari</option>
                        <option value="3">3 Hari</option>
                        <option value="7">7 Hari</option>
                        <option value="30">30 Hari</option>
                        <option value="9999">Permanen</option>
                    </select>
                </div>
                <div style="display: flex; gap: 10px; margin-top: 20px;">
                    <button type="button" class="nb-btn" onclick="closeBanModal()" style="flex: 1;">Batal</button>
                    <button type="submit" class="nb-btn nb-btn-primary" style="flex: 1; background: var(--primary-orange);">Ban User</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
