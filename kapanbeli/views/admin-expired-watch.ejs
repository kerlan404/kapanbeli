<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monitoring Kadaluarsa - Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root {
            --primary-blue: #3B82F6; 
            --primary-dark: #1D4ED8; 
            --primary-orange: #FF9F43;
            --accent-green: #10B981; 
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff; 
            --bg-sidebar-hover: #f1f5f9;
            --bg-sidebar-active: #e2e8f0;
            --text-sidebar: #475569; 
            --text-sidebar-active: #000000;
            --text-sidebar-heading: #000000; 
            --sidebar-border: #000000;
            --bg-body: #F8FAFC; 
            --bg-card: #FFFFFF;
            --text-main: #000000; 
            --text-muted: #64748B;
            --border-color: #000000; 
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
            --radius: 0px;
            --sidebar-width: 260px;
        }
        body.dark-mode-active {
            --bg-sidebar: #1A1D23; 
            --bg-body: #0F1115; 
            --bg-card: #1A1D23;
            --text-main: #FFFFFF; 
            --text-muted: #9CA3AF; 
            --border-color: #FFFFFF;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; min-height: 100vh; transition: background 0.3s; }
        a { text-decoration: none; color: inherit; }

        /* ========== MAIN ========== */
        .main-content { margin-left: var(--sidebar-width); flex: 1; padding: 40px; }
        .top-bar { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; gap: 20px; flex-wrap: wrap; }
        .page-title { font-size: 2rem; font-weight: 800; letter-spacing: -1px; }
        .page-subtitle { font-size: 1rem; color: var(--text-muted); margin-top: 5px; font-weight: 500; }
        .top-actions { display: flex; gap: 15px; align-items: center; flex-wrap: wrap; }
        
        .form-control { 
            padding: 12px 16px; 
            border: 3px solid var(--border-color); 
            border-radius: var(--radius); 
            background: var(--bg-card); 
            color: var(--text-main); 
            font-size: 0.95rem; 
            font-weight: 600;
            outline: none; 
            box-shadow: var(--shadow-brutal-sm);
            transition: all 0.2s;
        }
        .form-control:focus { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        
        .btn { 
            padding: 12px 24px; 
            border-radius: var(--radius); 
            border: 3px solid var(--border-color); 
            cursor: pointer; 
            font-weight: 800; 
            font-size: 0.95rem; 
            display: inline-flex; 
            align-items: center; 
            gap: 10px; 
            transition: all 0.2s; 
            box-shadow: var(--shadow-brutal-sm);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .btn:active { transform: translate(0px, 0px); box-shadow: 2px 2px 0px var(--border-color); }
        
        .btn-primary { background: var(--primary-blue); color: white; }
        .btn-outline { background: var(--bg-card); color: var(--text-main); }
        .theme-toggle { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }

        /* ========== FILTERS ========== */
        .filters-bar { 
            display: flex; 
            gap: 20px; 
            margin-bottom: 30px; 
            flex-wrap: wrap; 
            align-items: center; 
            background: var(--bg-card); 
            padding: 24px; 
            border: 3px solid var(--border-color); 
            box-shadow: var(--shadow-brutal);
        }
        .filters-bar .form-control { min-width: 220px; flex: 1; }
        .filter-label { font-size: 0.9rem; color: var(--text-main); font-weight: 800; display: flex; align-items: center; gap: 8px; text-transform: uppercase; }
        .filter-label i { color: var(--primary-blue); }

        /* ========== STATS ========== */
        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-box { 
            background: var(--bg-card); 
            padding: 24px; 
            border: 3px solid var(--border-color); 
            box-shadow: var(--shadow-brutal);
            transition: all 0.2s;
        }
        .stat-box:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }
        .stat-box .label { color: var(--text-muted); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
        .stat-box h3 { font-size: 2.2rem; font-weight: 900; line-height: 1; }
        .stat-box.red { border-color: var(--accent-red); box-shadow: 8px 8px 0px var(--accent-red); }
        .stat-box.red:hover { box-shadow: 12px 12px 0px var(--accent-red); }
        .stat-box.orange { border-color: var(--primary-orange); box-shadow: 8px 8px 0px var(--primary-orange); }
        .stat-box.orange:hover { box-shadow: 12px 12px 0px var(--primary-orange); }
        .stat-box.blue { border-color: var(--primary-blue); box-shadow: 8px 8px 0px var(--primary-blue); }
        .stat-box.blue:hover { box-shadow: 12px 12px 0px var(--primary-blue); }

        /* ========== PANEL & TABLE ========== */
        .panel-card { 
            background: var(--bg-card); 
            padding: 30px; 
            border: 3px solid var(--border-color); 
            box-shadow: var(--shadow-brutal);
            margin-bottom: 30px; 
        }
        .panel-header { display: flex; align-items: center; gap: 15px; margin-bottom: 25px; padding-bottom: 15px; border-bottom: 3px solid var(--border-color); }
        .panel-title { font-size: 1.25rem; font-weight: 800; text-transform: uppercase; }
        .panel-title i { color: var(--accent-red); }
        
        .table-wrapper { overflow-x: auto; }
        .data-table { width: 100%; border-collapse: collapse; }
        .data-table th { 
            padding: 15px; 
            text-align: left; 
            font-weight: 800; 
            color: var(--text-main); 
            font-size: 0.85rem; 
            text-transform: uppercase; 
            letter-spacing: 1px; 
            border-bottom: 4px solid var(--border-color); 
            background: rgba(0,0,0,0.05);
        }
        body.dark-mode-active .data-table th { background: rgba(255,255,255,0.05); }
        .data-table td { padding: 15px; border-bottom: 2px solid var(--border-color); font-size: 0.95rem; font-weight: 600; }
        .data-table tbody tr:hover { background: rgba(0,0,0,0.02); }
        body.dark-mode-active .data-table tbody tr:hover { background: rgba(255,255,255,0.02); }
        
        .badge { 
            display: inline-block; 
            padding: 6px 12px; 
            border: 2px solid var(--border-color); 
            font-size: 0.75rem; 
            font-weight: 800; 
            text-transform: uppercase;
        }
        .badge-red { background: var(--accent-red); color: white; }
        .badge-orange { background: var(--primary-orange); color: white; }
        .badge-blue { background: var(--primary-blue); color: white; }

        /* ========== PAGINATION ========== */
        .pagination-bar { display: flex; justify-content: space-between; align-items: center; margin-top: 25px; padding-top: 20px; border-top: 3px solid var(--border-color); flex-wrap: wrap; gap: 15px; }
        .pagination-info { font-size: 0.9rem; font-weight: 700; color: var(--text-muted); }
        .pagination { display: flex; gap: 8px; align-items: center; }
        .page-btn { 
            min-width: 40px; 
            height: 40px; 
            border: 2px solid var(--border-color); 
            background: var(--bg-card); 
            color: var(--text-main); 
            cursor: pointer; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 0.95rem; 
            font-weight: 800; 
            transition: all 0.2s; 
            box-shadow: 4px 4px 0px var(--border-color);
        }
        .page-btn:hover:not(:disabled) { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
        .page-btn.active { background: var(--primary-blue); color: white; }

        .loading-state, .empty-state { text-align: center; padding: 60px 20px; }
        .loading-state i { font-size: 3rem; color: var(--primary-blue); margin-bottom: 20px; animation: spin 1s linear infinite; }
        .empty-state i { font-size: 4rem; color: var(--accent-green); margin-bottom: 20px; }
        .empty-state h3 { font-size: 1.5rem; font-weight: 800; margin-bottom: 10px; }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* Toast */
        .toast-container { position: fixed; top: 30px; right: 30px; z-index: 3000; display: flex; flex-direction: column; gap: 15px; }
        .toast { 
            background: var(--bg-card); 
            padding: 16px 24px; 
            border: 3px solid var(--border-color); 
            box-shadow: 8px 8px 0px var(--border-color);
            display: flex; 
            align-items: center; 
            gap: 15px; 
            min-width: 320px; 
            animation: slideIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            font-weight: 800;
        }
        .toast.success { border-left-width: 10px; border-left-color: var(--accent-green); }
        .toast.error { border-left-width: 10px; border-left-color: var(--accent-red); }
        .toast.warning { border-left-width: 10px; border-left-color: var(--primary-orange); }

        @keyframes slideIn { from { transform: translateX(120%); } to { transform: translateX(0); } }

        @media (max-width: 992px) { 
            .main-content { margin-left: 0; padding: 25px; } 
            .filters-bar { flex-direction: column; align-items: stretch; } 
            .filters-bar .form-control { width: 100%; }
        }
    </style>
</head>
<body>
    <%- include('./partials/admin-sidebar', { currentPage: 'expired-watch', user: typeof user !== 'undefined' ? user : null }) %>

    <main class="main-content">
        <div class="top-bar">
            <div>
                <h1 class="page-title">🍎 Monitoring Kadaluarsa</h1>
                <p class="page-subtitle">Pantau bahan makanan yang sudah expired dari seluruh user</p>
            </div>
            <div class="top-actions">
                <button class="btn btn-outline theme-toggle" onclick="toggleTheme()" id="themeToggleBtn">
                    <i class="fas fa-moon"></i>
                </button>
                <button class="btn btn-primary" onclick="loadExpired(1, true)"><i class="fas fa-sync-alt"></i> Refresh Data</button>
            </div>
        </div>

        <div class="stats-row">
            <div class="stat-box red"><div class="label">Total Item Expired</div><h3 id="totalExpired">0</h3></div>
            <div class="stat-box orange"><div class="label">User Terkena</div><h3 id="affectedUsers">0</h3></div>
            <div class="stat-box blue"><div class="label">Rata-rata Umur Simpan</div><h3 id="avgShelfLife">0 hari</h3></div>
        </div>

        <!-- Filters -->
        <div class="filters-bar">
            <span class="filter-label"><i class="fas fa-filter"></i> Filter:</span>
            <input type="text" id="searchInput" class="form-control" placeholder="Cari bahan/user...">
            <select id="categoryFilter" class="form-control">
                <option value="">Semua Kategori</option>
                <option value="Bumbu Dapur">Bumbu Dapur</option>
                <option value="Sayuran">Sayuran</option>
                <option value="Buah-buahan">Buah-buahan</option>
                <option value="Protein">Protein</option>
                <option value="Bahan Kering">Bahan Kering</option>
                <option value="Lainnya">Lainnya</option>
            </select>
            <button class="btn btn-primary" onclick="applyFilters()" style="margin-left:auto;"><i class="fas fa-search"></i> Filter</button>
            <button class="btn" style="background:var(--border-color);color:var(--text-muted);" onclick="resetFilters()"><i class="fas fa-sync-alt"></i> Refresh</button>
        </div>

        <!-- Table -->
        <div class="panel-card">
            <div class="panel-header"><h3 class="panel-title"><i class="fas fa-exclamation-triangle"></i> Daftar Bahan Kadaluarsa</h3></div>
            <div id="loadingState" class="loading-state"><i class="fas fa-circle-notch"></i><p>Memuat data...</p></div>
            <div class="table-wrapper" id="tableWrapper" style="display:none;">
                <table class="data-table">
                    <thead><tr><th>#</th><th>Bahan</th><th>Pemilik</th><th>Email</th><th>Kategori</th><th>Stok</th><th>Tgl Expired</th><th>Lama Expired</th><th>Status</th></tr></thead>
                    <tbody id="expiredTableBody"></tbody>
                </table>
                <!-- Pagination -->
                <div class="pagination-bar">
                    <div class="pagination-info" id="paginationInfo">Menampilkan 0 dari 0 data</div>
                    <div class="pagination" id="paginationBtns"></div>
                </div>
            </div>
            <div id="emptyState" class="empty-state" style="display:none;">
                <i class="fas fa-check-circle"></i>
                <h3>Semua Bahan Aman!</h3>
                <p>Tidak ada item yang expired</p>
            </div>
        </div>
    </main>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        let allData = [], currentPage = 1, totalPages = 1, totalItems = 0;
        let filterSearch = '', filterCategory = '';

        // Toast notification function - consistent with other pages
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i>
                <span>${esc(message)}</span>
            `;
            document.getElementById('toastContainer').appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Theme Toggle Bridge
        function toggleTheme() {
            if (window.toggleAppTheme) {
                window.toggleAppTheme();
            }
        }

        // Listen for global theme changes to update UI
        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
        });

        document.addEventListener('DOMContentLoaded', () => { 
            // Initialize icon based on current state
            const isDark = document.body.classList.contains('dark-mode-active');
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) {
                icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            }
            loadExpired(); 
        });

        async function loadExpired(page = 1, showNotification = false) {
            currentPage = page;
            document.getElementById('loadingState').style.display = 'flex';
            document.getElementById('tableWrapper').style.display = 'none';
            document.getElementById('emptyState').style.display = 'none';
            try {
                const q = new URLSearchParams({ page, limit: 20, search: filterSearch, category: filterCategory });
                const res = await fetch(`/admin/api/expired-items?${q}`, { credentials: 'same-origin' });

                // Handle auth error - redirect to login
                if (res.status === 401 || res.status === 403) {
                    window.location.href = '/auth';
                    return;
                }

                const result = await res.json();
                if (!result.success) { console.error('API Error:', result); return; }

                allData = result.data || [];
                totalItems = result.pagination?.total || 0;
                totalPages = result.pagination?.totalPages || 1;

                // Update stats
                document.getElementById('totalExpired').textContent = totalItems;
                const uniqueUsers = new Set(allData.map(i => i.user_id)).size;
                document.getElementById('affectedUsers').textContent = uniqueUsers;
                if (allData.length > 0) {
                    const avg = allData.reduce((s, i) => s + (i.shelf_life_days || 0), 0) / allData.length;
                    document.getElementById('avgShelfLife').textContent = Math.round(avg) + ' hari';
                }

                renderTable();
                renderPagination();
                
                if (showNotification) {
                    showToast('Data berhasil disegarkan', 'success');
                }
            } catch (e) { console.error('Fetch error:', e); }
        }

        function renderTable() {
            const tbody = document.getElementById('expiredTableBody');
            document.getElementById('loadingState').style.display = 'none';
            if (!allData.length) {
                document.getElementById('emptyState').style.display = 'flex';
                document.getElementById('tableWrapper').style.display = 'none';
                return;
            }
            document.getElementById('tableWrapper').style.display = 'block';
            document.getElementById('emptyState').style.display = 'none';

            const start = (currentPage - 1) * 20 + 1;
            document.getElementById('paginationInfo').textContent = `Menampilkan ${start}-${Math.min(start + 20 - 1, totalItems)} dari ${totalItems} data`;

            tbody.innerHTML = allData.map((item, i) => `
                <tr>
                    <td>${start + i}</td>
                    <td><strong>${esc(item.name)}</strong></td>
                    <td>${esc(item.user_name)}</td>
                    <td>${esc(item.user_email)}</td>
                    <td><span class="badge badge-blue">${esc(item.category_name || '-')}</span></td>
                    <td>${parseFloat(item.stock_quantity || 0).toLocaleString()} ${item.unit || ''}</td>
                    <td>${formatDate(item.expiry_date)}</td>
                    <td><span class="badge badge-red">${item.days_expired || 0} hari lalu</span></td>
                    <td><span class="badge ${item.status === 'Aktif' ? 'badge-orange' : 'badge-red'}">${item.status || 'Aktif'}</span></td>
                </tr>
            `).join('');
        }

        function renderPagination() {
            const container = document.getElementById('paginationBtns');
            if (totalPages <= 1) { container.innerHTML = ''; return; }
            let html = `<button class="page-btn" onclick="loadExpired(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}><i class="fas fa-chevron-left"></i></button>`;
            const maxShow = 5;
            let startPage = Math.max(1, currentPage - Math.floor(maxShow / 2));
            let endPage = Math.min(totalPages, startPage + maxShow - 1);
            if (endPage - startPage < maxShow - 1) startPage = Math.max(1, endPage - maxShow + 1);
            for (let p = startPage; p <= endPage; p++) {
                html += `<button class="page-btn ${p === currentPage ? 'active' : ''}" onclick="loadExpired(${p})">${p}</button>`;
            }
            html += `<button class="page-btn" onclick="loadExpired(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}><i class="fas fa-chevron-right"></i></button>`;
            container.innerHTML = html;
        }

        function applyFilters() {
            filterSearch = document.getElementById('searchInput').value.trim();
            filterCategory = document.getElementById('categoryFilter').value;
            loadExpired(1, false);
        }
        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('categoryFilter').value = '';
            filterSearch = ''; filterCategory = '';
            loadExpired(1, true);
            showToast('Filter berhasil direset', 'success');
        }

        // Enter key for search
        document.getElementById('searchInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') applyFilters(); });

        function formatDate(d) { if (!d) return '-'; return new Date(d).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }); }
        function esc(t) { if (!t) return ''; const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
    </script>
</body>
</html>
