<!--
  Admin Sidebar Component - Premium Neubrutalism Edition
-->

<div id="sidebarOverlay" onclick="toggleSidebar()"></div>

<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <a href="/admin" class="logo">
            <i class="fas fa-box-open"></i>
            <span>KAPANBELI</span>
        </a>
    </div>

    <div class="sidebar-menu">
        <div class="menu-label">Navigasi Utama</div>
        <a href="/admin" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'active' : '' %>">
            <i class="fas fa-th-large"></i>
            <span>Dashboard</span>
        </a>
        <a href="/admin/users" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'users' ? 'active' : '' %>">
            <i class="fas fa-users"></i>
            <span>Manajemen Pengguna</span>
        </a>
        <a href="/admin/products" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'products' ? 'active' : '' %>">
            <i class="fas fa-boxes"></i>
            <span>Semua Produk</span>
        </a>
        <a href="/admin/expired-watch" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'expired-watch' ? 'active' : '' %>">
            <i class="fas fa-hourglass-end"></i>
            <span>Monitoring Kadaluarsa</span>
        </a>
        <a href="/admin/shopping-suggestions" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'shopping-suggestions' ? 'active' : '' %>">
            <i class="fas fa-shopping-basket"></i>
            <span>Saran Pembelian</span>
        </a>

        <div class="menu-label">Komunikasi & Log</div>
        <a href="/admin/broadcast" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'broadcast' ? 'active' : '' %>">
            <i class="fas fa-bullhorn"></i>
            <span>Broadcast</span>
        </a>
        <a href="/admin/notes" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'notes' ? 'active' : '' %>">
            <i class="fas fa-sticky-note"></i>
            <span>Catatan User</span>
        </a>
        <a href="/admin/activity-logs" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'activity-logs' ? 'active' : '' %>">
            <i class="fas fa-history"></i>
            <span>Log Aktivitas</span>
        </a>

        <div class="menu-label">Sistem</div>
        <a href="/admin/settings" class="nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'settings' ? 'active' : '' %>">
            <i class="fas fa-cog"></i>
            <span>Pengaturan</span>
        </a>
    </div>

    <div class="sidebar-footer">
        <div class="user-mini-profile">
            <div class="user-avatar-container">
                <% if (typeof user !== 'undefined' && user && (user.profile_image || user.profile_photo)) { %>
                    <img src="<%= user.profile_image || user.profile_photo %>" alt="<%= user.name %>" class="user-avatar-img">
                <% } else { %>
                    <div class="user-avatar-placeholder">
                        <%= typeof user !== 'undefined' && user && user.name ? user.name[0].toUpperCase() : 'A' %>
                    </div>
                <% } %>
            </div>
            <div class="user-details-mini">
                <div class="user-name-mini"><%= typeof user !== 'undefined' && user && user.name ? user.name : 'Admin' %></div>
                <div class="user-role-mini">Administrator</div>
            </div>
            <button class="logout-btn-nb" onclick="confirmLogout()" title="Keluar">
                <i class="fas fa-power-off"></i>
            </button>
        </div>
    </div>
</aside>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        if (sidebar) sidebar.classList.toggle('active');
        if (overlay) overlay.classList.toggle('active');
    }

    function confirmLogout() {
        if (confirm('Yakin ingin keluar dari panel admin?')) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/auth/logout';
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>

<style>
    /* ========== NEUBRUTALISM SIDEBAR STYLES ========== */
    :root {
        --sb-bg: #FFFFFF;
        --sb-text: #000000;
        --sb-border: #000000;
        --sb-accent: #3B82F6;
        --sb-shadow: #000000;
    }

    body.dark-mode-active {
        --sb-bg: #1E293B;
        --sb-text: #F1F5F9;
        --sb-border: #F1F5F9;
        --sb-accent: #3B82F6;
        --sb-shadow: #3B82F6;
    }

    .sidebar {
        width: 280px;
        background: var(--sb-bg);
        border-right: 4px solid var(--sb-border);
        height: 100vh;
        position: fixed;
        left: 0; top: 0;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Outfit', sans-serif;
    }

    .sidebar-header {
        height: 80px;
        display: flex;
        align-items: center;
        padding: 0 24px;
        border-bottom: 4px solid var(--sb-border);
    }

    .sidebar-header .logo {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--sb-text);
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        letter-spacing: -0.5px;
    }

    .sidebar-header .logo i {
        color: var(--sb-accent);
        font-size: 1.8rem;
    }

    .sidebar-menu {
        flex: 1;
        padding: 24px 12px;
        overflow-y: auto;
    }

    .sidebar-menu::-webkit-scrollbar { width: 6px; }
    .sidebar-menu::-webkit-scrollbar-thumb { background: var(--sb-border); border-radius: 10px; }

    .menu-label {
        padding: 0 16px 12px;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: var(--sb-text);
        font-weight: 900;
        letter-spacing: 1px;
        margin-top: 24px;
        opacity: 0.6;
    }

    .menu-label:first-child { margin-top: 0; }

    .nav-item {
        display: flex;
        align-items: center;
        padding: 14px 16px;
        color: var(--sb-text);
        text-decoration: none;
        font-weight: 800;
        border: 4px solid transparent;
        transition: all 0.2s;
        gap: 14px;
        margin-bottom: 8px;
    }

    .nav-item i {
        width: 24px;
        font-size: 1.2rem;
        text-align: center;
    }

    .nav-item:hover {
        background: var(--sb-accent);
        color: #fff;
        border: 4px solid var(--sb-border);
        box-shadow: 4px 4px 0px var(--sb-shadow);
        transform: translate(-2px, -2px);
    }

    .nav-item.active {
        background: var(--sb-accent);
        color: #fff;
        border: 4px solid var(--sb-border);
        box-shadow: 4px 4px 0px var(--sb-shadow);
    }

    .sidebar-footer {
        padding: 20px;
        border-top: 4px solid var(--sb-border);
        background: var(--sb-bg);
    }

    .user-mini-profile {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar-container {
        width: 48px;
        height: 48px;
        border: 3px solid var(--sb-border);
        flex-shrink: 0;
        overflow: hidden;
        background: var(--primary-orange);
    }

    .user-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .user-avatar-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        color: #fff;
        font-size: 1.2rem;
    }

    .user-details-mini {
        flex: 1;
        min-width: 0;
    }

    .user-name-mini {
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--sb-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-role-mini {
        font-size: 0.75rem;
        color: var(--sb-text);
        opacity: 0.7;
        font-weight: 600;
    }

    .logout-btn-nb {
        width: 40px;
        height: 40px;
        border: 3px solid var(--sb-border);
        background: var(--accent-red);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        box-shadow: 3px 3px 0px var(--sb-shadow);
        transition: all 0.1s;
    }

    .logout-btn-nb:hover {
        transform: translate(-2px, -2px);
        box-shadow: 5px 5px 0px var(--sb-shadow);
    }

    /* Sidebar Overlay for Mobile */
    #sidebarOverlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.8);
        z-index: 999;
        display: none;
    }
    #sidebarOverlay.active { display: block; }

    @media (max-width: 992px) {
        .sidebar {
            transform: translateX(-100%);
        }
        .sidebar.active {
            transform: translateX(0);
        }
    }

    /* Menu Toggle Button for Mobile */
    .menu-toggle {
        display: none;
        width: 50px;
        height: 50px;
        border: 4px solid var(--sb-border);
        background: var(--sb-bg);
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        cursor: pointer;
        box-shadow: 4px 4px 0px var(--sb-shadow);
        color: var(--sb-text);
        margin-bottom: 20px;
        transition: all 0.1s;
    }

    .menu-toggle:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0px var(--sb-shadow);
    }

    @media (max-width: 992px) {
        .menu-toggle {
            display: flex;
            position: fixed;
            top: 15px;
            left: 15px;
            z-index: 1001;
            margin-bottom: 0;
        }
    }
</style>
