<script>
    // GLOBAL THEME ENGINE: Apply and Toggle handles
    (function () {
        const applyTheme = (isDark) => {
            if (!document.body) return;
            if (isDark) document.body.classList.add('dark-mode-active');
            else document.body.classList.remove('dark-mode-active');
        };

        const initTheme = () => {
            try {
                const savedTheme = localStorage.getItem('darkMode');
                const userTheme = '<%= typeof user !== "undefined" && user ? user.theme : "" %>';

                if (userTheme === 'dark' || savedTheme === 'true') {
                    applyTheme(true);
                } else if (userTheme === 'light') {
                    applyTheme(false);
                } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    applyTheme(true);
                }
            } catch (e) {
                console.error('Theme Guard error:', e);
            }
        };

        if (document.body) {
            initTheme();
        } else {
            document.addEventListener('DOMContentLoaded', initTheme);
        }

        // Global Toggle Helper
        window.toggleAppTheme = async function () {
            const isDark = document.body.classList.toggle('dark-mode-active');
            localStorage.setItem('darkMode', isDark);

            // UI Sync (for custom icons)
            const icons = document.querySelectorAll('#themeToggle i, #darkModeIcon');
            icons.forEach(icon => {
                if (isDark) {
                    icon.classList.replace('fa-moon', 'fa-sun');
                } else {
                    icon.classList.replace('fa-sun', 'fa-moon');
                }
            });

            // Database Sync
            try {
                await fetch('/api/settings/theme', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ theme: isDark ? 'dark' : 'light' })
                });
            } catch (e) { console.error('Theme sync failed', e); }
        };
    })();
</script>