<script>
    // GLOBAL THEME ENGINE: Apply and Toggle handles
    (function () {
        const applyTheme = (isDark) => {
            if (!document.body) return;
            if (isDark) document.body.classList.add('dark-mode-active');
            else document.body.classList.remove('dark-mode-active');
        };
 
        const initTheme = () => {
            try {
                const savedTheme = localStorage.getItem('theme');
                const userTheme = '<%= typeof user !== "undefined" && user ? user.theme : "" %>';
 
                if (savedTheme === 'dark' || (savedTheme === null && userTheme === 'dark')) {
                    applyTheme(true);
                } else if (savedTheme === 'light') {
                    applyTheme(false);
                } else if (savedTheme === null && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    applyTheme(true);
                }
            } catch (e) {
                console.error('Theme Guard error:', e);
            }
        };
 
        if (document.body) {
            initTheme();
        } else {
            document.addEventListener('DOMContentLoaded', initTheme);
        }
 
        // Global Toggle Helper
        window.toggleAppTheme = async function () {
            const isDark = document.body.classList.toggle('dark-mode-active');
            const theme = isDark ? 'dark' : 'light';
            localStorage.setItem('theme', theme);
 
            // UI Sync (for custom icons)
            const icons = document.querySelectorAll('#themeToggle i, #darkModeIcon, .top-actions .btn-outline i');
            icons.forEach(icon => {
                if (isDark) {
                    if (icon.classList.contains('fa-moon')) icon.classList.replace('fa-moon', 'fa-sun');
                } else {
                    if (icon.classList.contains('fa-sun')) icon.classList.replace('fa-sun', 'fa-moon');
                }
            });
 
            // Database Sync
            try {
                await fetch('/api/settings/theme', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ theme }),
                    credentials: 'same-origin'
                });
            } catch (e) { console.error('Theme sync failed', e); }

            // Custom event for pages that need to react to theme change (like charts)
            window.dispatchEvent(new CustomEvent('themeChanged', { detail: { theme, isDark } }));
        };
    })();
</script>