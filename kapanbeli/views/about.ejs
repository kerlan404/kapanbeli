    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📓</text></svg>" type="image/x-icon">

    <style>
        /* --- ULTRA-PREMIUM GLASSMORPHISM SYSTEM --- */
        :root {
            --primary: #3B82F6;
            --accent: #FF9F43;
            --accent-red: #FF6B6B;
            --text-main: #1E293B;
            --text-muted: #64748B;
            --glass-bg: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(255, 255, 255, 0.4);
            --glass-card: rgba(255, 255, 255, 0.6);
            --overlay: linear-gradient(135deg, rgba(248, 250, 252, 0.85), rgba(248, 250, 252, 0.5));
            --shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
            --shadow-hover: 0 30px 60px rgba(59, 130, 246, 0.15);
            --radius-xl: 32px;
            --radius-lg: 24px;
            --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        body.dark-mode-active {
            --text-main: #FFFFFF;
            --text-muted: #94A3B8;
            --glass-bg: rgba(15, 23, 42, 0.6);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-card: rgba(255, 255, 255, 0.03);
            --overlay: linear-gradient(135deg, rgba(2, 6, 23, 0.9), rgba(2, 6, 23, 0.7));
            --shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            --shadow-hover: 0 30px 60px rgba(59, 130, 246, 0.3);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; outline: none; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
            background: url('/images/bahan%20dapur.jpg') no-repeat center center fixed;
            background-size: cover;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: var(--overlay);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            z-index: -1;
            transition: var(--transition);
        }

        h1, h2, h3, h4, h5, h6 { font-family: 'Outfit', sans-serif; }

        /* ANIMATIONS */
        .animate-on-scroll { opacity: 0; transform: translateY(40px); transition: var(--transition); }
        .animate-on-scroll.visible { opacity: 1; transform: translateY(0); }
        .delay-1 { transition-delay: 0.1s; } .delay-2 { transition-delay: 0.2s; } .delay-3 { transition-delay: 0.3s; }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }

        /* HERO SECTION */
        .hero-section {
            min-height: 70vh;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            text-align: center; padding: 120px 24px 60px; position: relative;
        }

        .hero-glow {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 50vw; height: 50vw; max-width: 600px; max-height: 600px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.2) 0%, transparent 70%);
            filter: blur(60px); z-index: -1; animation: float 8s ease-in-out infinite;
        }

        .badge-premium {
            background: var(--glass-card); backdrop-filter: blur(10px); border: 1px solid var(--glass-border);
            padding: 10px 24px; border-radius: 100px; font-weight: 700; color: var(--accent);
            margin-bottom: 24px; display: inline-flex; align-items: center; gap: 10px; box-shadow: var(--shadow);
        }

        .hero-section h1 { font-size: clamp(3rem, 8vw, 5rem); font-weight: 800; line-height: 1.1; letter-spacing: -2px; margin-bottom: 24px; }
        .hero-section h1 span { background: linear-gradient(135deg, var(--primary), var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero-section p { font-size: clamp(1.1rem, 4vw, 1.25rem); color: var(--text-muted); max-width: 800px; }

        /* SECTIONS & CARDS */
        .content-container { max-width: 1200px; margin: 0 auto; padding: 0 24px 80px; }

        .glass-card {
            background: var(--glass-bg); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border); border-radius: var(--radius-xl);
            padding: 60px; margin-bottom: 40px; box-shadow: var(--shadow); transition: var(--transition);
        }
        .glass-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-hover); border-color: rgba(59, 130, 246, 0.3); }

        .card-icon {
            width: 80px; height: 80px; border-radius: 24px; display: flex; align-items: center; justify-content: center;
            font-size: 2rem; color: white; margin-bottom: 32px; background: linear-gradient(135deg, var(--primary), #2563EB);
            box-shadow: 0 15px 30px rgba(59, 130, 246, 0.3);
        }

        .card-title { font-size: 2.2rem; font-weight: 800; margin-bottom: 24px; letter-spacing: -1px; }
        .card-text { font-size: 1.1rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 24px; }

        /* FEATURE BOXES */
        .modern-features { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin-top: 48px; }
        .feature-box { background: var(--glass-card); padding: 32px; border-radius: var(--radius-lg); border: 1px solid var(--glass-border); transition: var(--transition); }
        .feature-box:hover { transform: translateY(-5px) scale(1.02); border-color: var(--primary); background: rgba(59, 130, 246, 0.05); }
        .feature-box i { font-size: 1.8rem; color: var(--accent); margin-bottom: 20px; filter: drop-shadow(0 5px 10px rgba(255, 159, 67, 0.3)); }
        .feature-box h4 { font-size: 1.3rem; font-weight: 700; margin-bottom: 12px; }
        .feature-box p { color: var(--text-muted); }

        /* TEAM SECTION */
        .team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 32px; }
        .team-card {
            background: var(--glass-bg); backdrop-filter: blur(24px); border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl); padding: 50px 30px; text-align: center; transition: var(--transition);
            position: relative; overflow: hidden; box-shadow: var(--shadow);
        }
        .team-card::before {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 60%);
            opacity: 0; transition: var(--transition); z-index: 0;
        }
        .team-card:hover::before { opacity: 1; transform: rotate(45deg); }
        .team-card:hover { transform: translateY(-10px); box-shadow: var(--shadow-hover); border-color: var(--primary); }

        .avatar-circle {
            width: 130px; height: 130px; border-radius: 50%; margin: 0 auto 24px; position: relative; z-index: 1;
            display: flex; align-items: center; justify-content: center; font-size: 3.5rem; color: white;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            box-shadow: 0 15px 30px rgba(59, 130, 246, 0.3); transition: var(--transition);
        }
        .team-card:hover .avatar-circle { transform: scale(1.1) rotate(5deg); }
        .team-card.manager .avatar-circle { background: linear-gradient(135deg, var(--accent-red), var(--accent)); box-shadow: 0 15px 30px rgba(255, 107, 107, 0.3); }

        .role-badge { display: inline-block; padding: 8px 24px; border-radius: 100px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; position: relative; z-index: 1; }
        .role-badge.manager { background: rgba(255, 107, 107, 0.15); color: #FF6B6B; border: 1px solid rgba(255, 107, 107, 0.3); }
        .role-badge.member { background: rgba(59, 130, 246, 0.15); color: var(--primary); border: 1px solid rgba(59, 130, 246, 0.3); }

        .team-name { font-size: 1.8rem; font-weight: 800; margin-bottom: 12px; position: relative; z-index: 1; }
        .team-desc { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 24px; position: relative; z-index: 1; }

        .team-social { display: flex; justify-content: center; gap: 16px; position: relative; z-index: 1; }
        .team-social-link {
            width: 44px; height: 44px; border-radius: 50%; background: var(--glass-card); border: 1px solid var(--glass-border);
            display: flex; align-items: center; justify-content: center; color: var(--text-main); font-size: 1.1rem;
            transition: var(--transition); text-decoration: none;
        }
        .team-social-link:hover { background: var(--primary); color: white; border-color: var(--primary); transform: translateY(-5px); box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3); }

        /* GALLERY */
        .gallery-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 32px; margin-top: 40px; }
        .gallery-card {
            background: var(--glass-card); border: 1px solid var(--glass-border); border-radius: var(--radius-xl);
            padding: 16px; transition: var(--transition); text-align: center; overflow: hidden;
        }
        .gallery-card img { width: 100%; border-radius: 20px; margin-bottom: 16px; box-shadow: var(--shadow); transition: 0.5s ease; }
        .gallery-card:hover img { transform: scale(1.05); }
        .gallery-title { font-weight: 700; font-family: 'Outfit', sans-serif; font-size: 1.2rem; margin-bottom: 10px; }

        /* STATS */
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px; margin: 80px 0; }
        .stat-item { text-align: center; padding: 40px; background: var(--glass-bg); border-radius: var(--radius-xl); border: 1px solid var(--glass-border); box-shadow: var(--shadow); transition: var(--transition); }
        .stat-item:hover { transform: translateY(-10px); border-color: var(--primary); }
        .stat-val { font-size: 4rem; font-family: 'Outfit', sans-serif; font-weight: 800; background: linear-gradient(135deg, var(--primary), var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 8px; line-height: 1; }
        .stat-label { font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; font-size: 0.9rem; }

        @media (max-width: 768px) {
            .hero-section { padding: 100px 20px 40px; }
            .hero-section h1 { font-size: 2.5rem; }
            .glass-card { padding: 40px 24px; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
            .stat-val { font-size: 3rem; }
        }
    </style>
</head>
