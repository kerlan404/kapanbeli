<% if (typeof user === 'undefined') { var user = null; } %>
<% if (user && user.theme === 'dark') { var bodyClass = 'dark-mode-active'; } else { var bodyClass = ''; } %>
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('title_about') %> - Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📓</text></svg>" type="image/x-icon">

    <style>
        /* --- BRAND DESIGN SYSTEM & PALET KONSEP --- */
        :root {
            --primary: #4F46E5; /* Royal Indigo */
            --primary-light: #818CF8;
            --primary-glow: rgba(79, 70, 229, 0.12);
            --accent: #FF9F43; /* Amber Gold */
            --accent-glow: rgba(255, 159, 67, 0.12);
            --accent-red: #FF6B6B; /* Coral Red */
            --accent-red-glow: rgba(255, 107, 107, 0.12);
            --accent-teal: #10B981; /* Emerald Teal */
            --accent-teal-glow: rgba(16, 185, 129, 0.12);
            
            --bg-base: #F8FAFC;
            --text-main: #0F172A;
            --text-muted: #475569;
            --text-sub: #64748B;
            
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.6);
            --glass-card: rgba(255, 255, 255, 0.45);
            --border-highlight: rgba(79, 70, 229, 0.08);
            
            --shadow-sm: 0 4px 6px -1px rgba(15, 23, 42, 0.03), 0 2px 4px -2px rgba(15, 23, 42, 0.03);
            --shadow-md: 0 10px 20px -3px rgba(15, 23, 42, 0.04), 0 4px 10px -4px rgba(15, 23, 42, 0.04);
            --shadow-lg: 0 20px 30px -5px rgba(15, 23, 42, 0.05), 0 10px 15px -5px rgba(15, 23, 42, 0.05);
            --shadow-xl: 0 30px 60px -15px rgba(15, 23, 42, 0.08);
            --shadow-hover: 0 35px 70px -15px rgba(79, 70, 229, 0.18);
            
            --radius-md: 18px;
            --radius-lg: 28px;
            --radius-xl: 40px;
            
            --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            --transition-spring: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
            
            --overlay: linear-gradient(135deg, rgba(248, 250, 252, 0.75), rgba(241, 245, 249, 0.55));
        }

        body.dark-mode-active {
            --bg-base: #020617;
            --text-main: #F8FAFC;
            --text-muted: #E2E8F0;
            --text-sub: #94A3B8;
            
            --glass-bg: rgba(15, 23, 42, 0.45);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-card: rgba(255, 255, 255, 0.02);
            --border-highlight: rgba(129, 140, 248, 0.12);
            
            --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.4);
            --shadow-md: 0 10px 20px -3px rgba(0, 0, 0, 0.5);
            --shadow-lg: 0 20px 30px -5px rgba(0, 0, 0, 0.6);
            --shadow-xl: 0 30px 60px -15px rgba(0, 0, 0, 0.7);
            --shadow-hover: 0 35px 70px -15px rgba(99, 102, 241, 0.45);
            
            --overlay: linear-gradient(135deg, rgba(2, 6, 23, 0.93), rgba(11, 17, 33, 0.83));
        }

        * { margin: 0; padding: 0; box-sizing: border-box; outline: none; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-base);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
            min-height: 100vh;
        }

        /* --- DECORATIVE FLOATING BLOBS --- */
        .blob-container {
            position: fixed;
            inset: 0;
            z-index: -2;
            overflow: hidden;
            pointer-events: none;
        }
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            opacity: 0.18;
            transition: var(--transition);
        }
        body.dark-mode-active .blob {
            opacity: 0.28;
        }
        .blob-1 {
            top: -10%;
            left: -10%;
            width: 45vw;
            height: 45vw;
            background: radial-gradient(circle, var(--primary) 0%, transparent 80%);
            animation: float-blob-1 25s infinite alternate ease-in-out;
        }
        .blob-2 {
            bottom: -10%;
            right: -10%;
            width: 50vw;
            height: 50vw;
            background: radial-gradient(circle, var(--accent) 0%, transparent 80%);
            animation: float-blob-2 30s infinite alternate ease-in-out;
        }
        .blob-3 {
            top: 40%;
            left: 50%;
            width: 35vw;
            height: 35vw;
            background: radial-gradient(circle, var(--accent-red) 0%, transparent 80%);
            animation: float-blob-3 35s infinite alternate ease-in-out;
        }
        @keyframes float-blob-1 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(12%, 18%) scale(1.15); }
        }
        @keyframes float-blob-2 {
            0% { transform: translate(0, 0) scale(1.1); }
            100% { transform: translate(-18%, -12%) scale(0.9); }
        }
        @keyframes float-blob-3 {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-30%, -30%) rotate(360deg); }
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: var(--overlay);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            z-index: -1;
            transition: var(--transition);
        }

        h1, h2, h3, h4, h5, h6 { font-family: 'Outfit', sans-serif; letter-spacing: -0.5px; }

        /* --- SMOOTH SPRING SCROLL ANIMATIONS --- */
        .animate-on-scroll { 
            opacity: 0; 
            transform: translateY(35px) scale(0.98); 
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); 
        }
        .animate-on-scroll.visible { 
            opacity: 1; 
            transform: translateY(0) scale(1); 
        }
        .delay-1 { transition-delay: 0.1s; } 
        .delay-2 { transition-delay: 0.2s; } 
        .delay-3 { transition-delay: 0.3s; }
        .delay-4 { transition-delay: 0.4s; }

        /* --- HERO SECTION --- */
        .hero-section {
            min-height: 55vh;
            display: flex; 
            flex-direction: column; 
            justify-content: center; 
            align-items: center;
            text-align: center; 
            padding: 130px 24px 50px; 
            position: relative;
        }

        .badge-premium {
            background: var(--glass-card); 
            backdrop-filter: blur(12px); 
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            padding: 8px 20px; 
            border-radius: 100px; 
            font-weight: 700; 
            font-size: 0.85rem;
            color: var(--accent);
            margin-bottom: 24px; 
            display: inline-flex; 
            align-items: center; 
            gap: 10px; 
            box-shadow: var(--shadow-sm);
        }

        .hero-section h1 { 
            font-size: clamp(2.5rem, 7vw, 4.5rem); 
            font-weight: 800; 
            line-height: 1.1; 
            letter-spacing: -2.5px; 
            margin-bottom: 24px; 
        }
        .hero-section h1 span { 
            background: linear-gradient(135deg, var(--primary), var(--accent)); 
            -webkit-background-clip: text; 
            -webkit-text-fill-color: transparent; 
        }
        .hero-section p { 
            font-size: clamp(1rem, 3vw, 1.2rem); 
            color: var(--text-sub); 
            max-width: 750px; 
            font-weight: 500;
            line-height: 1.6;
        }

        /* --- BENTO GRID SYSTEM --- */
        .content-container { 
            max-width: 1200px; 
            margin: 0 auto; 
            padding: 0 24px 80px; 
        }

        .bento-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 28px;
            margin-bottom: 50px;
        }

        .bento-card {
            background: var(--glass-bg); 
            backdrop-filter: blur(30px); 
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border); 
            border-radius: var(--radius-lg);
            padding: 40px; 
            box-shadow: var(--shadow-md); 
            transition: var(--transition-spring);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .bento-card:hover { 
            transform: translateY(-8px); 
            box-shadow: var(--shadow-hover); 
            border-color: var(--primary-light); 
        }

        /* Bento Grid Span Configurations */
        .span-1 { grid-column: span 1; }
        .span-2 { grid-column: span 2; }
        .span-3 { grid-column: span 3; }

        .card-icon {
            width: 60px; 
            height: 60px; 
            border-radius: 18px; 
            display: flex; 
            align-items: center; 
            justify-content: center;
            font-size: 1.6rem; 
            color: white; 
            margin-bottom: 28px; 
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            box-shadow: 0 10px 20px var(--primary-glow);
            transition: var(--transition);
        }
        .bento-card:hover .card-icon {
            transform: rotate(-5deg) scale(1.05);
        }

        .card-title { 
            font-size: 1.8rem; 
            font-weight: 800; 
            margin-bottom: 16px; 
            letter-spacing: -0.8px; 
            color: var(--text-main);
        }
        .card-text { 
            font-size: 1.02rem; 
            color: var(--text-muted); 
            line-height: 1.7; 
            font-weight: 500;
        }

        /* --- MULTI-ACCENT HOVER EFFCTS --- */
        .card-orange .card-icon {
            background: linear-gradient(135deg, var(--accent), #FFB775);
            box-shadow: 0 10px 20px var(--accent-glow);
        }
        .card-orange:hover {
            border-color: var(--accent);
        }

        .card-red .card-icon {
            background: linear-gradient(135deg, var(--accent-red), #FF8E8E);
            box-shadow: 0 10px 20px var(--accent-red-glow);
        }
        .card-red:hover {
            border-color: var(--accent-red);
        }

        /* --- FEATURE CORES INSIDE BENTO --- */
        .bento-features { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 20px; 
            margin-top: 32px; 
            width: 100%;
        }
        .bento-feature-box { 
            background: var(--glass-card); 
            padding: 24px; 
            border-radius: var(--radius-md); 
            border: 1px solid var(--glass-border); 
            transition: var(--transition); 
        }
        .bento-feature-box:hover { 
            transform: scale(1.03); 
            border-color: var(--primary); 
            background: var(--primary-glow); 
        }
        .bento-feature-box i { 
            font-size: 1.4rem; 
            color: var(--accent); 
            margin-bottom: 14px; 
            display: inline-block;
        }
        .bento-feature-box h4 { 
            font-size: 1.1rem; 
            font-weight: 700; 
            margin-bottom: 8px; 
            color: var(--text-main);
        }
        .bento-feature-box p { 
            font-size: 0.88rem;
            color: var(--text-sub); 
            line-height: 1.5;
        }

        /* --- TECH GRID IN BENTO --- */
        .tech-bento-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            width: 100%;
            margin-top: 28px;
        }
        .tech-box {
            background: var(--glass-card);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-md);
            padding: 24px 16px;
            text-align: center;
            transition: var(--transition-spring);
        }
        .tech-box:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
            box-shadow: var(--shadow-md);
            background: var(--primary-glow);
        }
        .tech-icon {
            font-size: 2.2rem;
            margin-bottom: 12px;
            display: inline-block;
        }
        .tech-name {
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--text-main);
        }

        /* --- TEAM DECK GRID --- */
        .section-header {
            text-align: center; 
            margin: 90px 0 50px;
        }
        .section-header h2 { 
            font-size: 2.8rem; 
            font-weight: 800; 
            letter-spacing: -1px;
            margin-bottom: 16px;
        }
        .section-header p { 
            color: var(--text-sub); 
            font-size: 1.1rem;
            max-width: 600px;
            margin: 0 auto;
        }

        .team-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); 
            gap: 28px; 
        }
        .team-card {
            background: var(--glass-bg); 
            backdrop-filter: blur(30px); 
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg); 
            padding: 40px 24px; 
            text-align: center; 
            transition: var(--transition-spring);
            position: relative; 
            overflow: hidden; 
            box-shadow: var(--shadow-md);
        }
        .team-card::before {
            content: ''; 
            position: absolute; 
            top: -50%; 
            left: -50%; 
            width: 200%; 
            height: 200%;
            background: radial-gradient(circle, var(--primary-glow) 0%, transparent 60%);
            opacity: 0; 
            transition: var(--transition); 
            z-index: 0;
            pointer-events: none;
        }
        .team-card:hover::before { opacity: 1; transform: rotate(45deg); }
        .team-card:hover { 
            transform: translateY(-8px); 
            box-shadow: var(--shadow-hover); 
            border-color: var(--primary); 
        }

        .avatar-circle {
            width: 110px; 
            height: 110px; 
            border-radius: 50%; 
            margin: 0 auto 20px; 
            position: relative; 
            z-index: 1;
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 2.8rem; 
            color: white;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            box-shadow: 0 10px 20px var(--primary-glow); 
            transition: var(--transition-spring);
        }
        .team-card:hover .avatar-circle { 
            transform: scale(1.1) rotate(6deg); 
        }
        .team-card.manager .avatar-circle { 
            background: linear-gradient(135deg, var(--accent-red), var(--accent)); 
            box-shadow: 0 10px 20px var(--accent-red-glow); 
        }

        .role-badge { 
            display: inline-block; 
            padding: 6px 18px; 
            border-radius: 100px; 
            font-size: 0.78rem; 
            font-weight: 800; 
            text-transform: uppercase; 
            letter-spacing: 0.8px; 
            margin-bottom: 16px; 
            position: relative; 
            z-index: 1; 
        }
        .role-badge.manager { 
            background: rgba(255, 107, 107, 0.12); 
            color: #FF6B6B; 
            border: 1px solid rgba(255, 107, 107, 0.25); 
        }
        .role-badge.member { 
            background: var(--primary-glow); 
            color: var(--primary); 
            border: 1px solid rgba(79, 70, 229, 0.25); 
        }

        .team-name { 
            font-size: 1.5rem; 
            font-weight: 800; 
            margin-bottom: 10px; 
            position: relative; 
            z-index: 1; 
            color: var(--text-main);
        }
        .team-desc { 
            color: var(--text-sub); 
            font-size: 0.92rem; 
            margin-bottom: 22px; 
            line-height: 1.5;
            position: relative; 
            z-index: 1; 
        }

        .team-social { 
            display: flex; 
            justify-content: center; 
            gap: 12px; 
            position: relative; 
            z-index: 1; 
        }
        .team-social-link {
            width: 38px; 
            height: 38px; 
            border-radius: 50%; 
            background: var(--glass-card); 
            border: 1px solid var(--glass-border);
            display: flex; 
            align-items: center; 
            justify-content: center; 
            color: var(--text-main); 
            font-size: 0.95rem;
            transition: var(--transition); 
            text-decoration: none;
        }
        .team-social-link:hover { 
            background: var(--primary); 
            color: white; 
            border-color: var(--primary); 
            transform: translateY(-4px); 
            box-shadow: 0 8px 16px var(--primary-glow); 
        }

        /* --- MOMENT GALLERY --- */
        .gallery-grid { 
            display: grid; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 28px; 
            margin-top: 30px; 
        }
        .gallery-card {
            background: var(--glass-card); 
            border: 1px solid var(--glass-border); 
            border-radius: var(--radius-lg);
            padding: 16px; 
            transition: var(--transition-spring); 
            text-align: center; 
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }
        .gallery-card img { 
            width: 100%; 
            height: 200px;
            object-fit: cover;
            border-radius: 20px; 
            margin-bottom: 14px; 
            box-shadow: var(--shadow-sm); 
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .gallery-card:hover img { 
            transform: scale(1.05); 
        }
        .gallery-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary-light);
            box-shadow: var(--shadow-md);
        }
        .gallery-title { 
            font-weight: 800; 
            font-family: 'Outfit', sans-serif; 
            font-size: 1.1rem; 
        }

        /* --- STATS COUNTER SYSTEM --- */
        .stats-grid { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); 
            gap: 24px; 
            margin: 80px 0 20px; 
        }
        .stat-item { 
            text-align: center; 
            padding: 32px 20px; 
            background: var(--glass-bg); 
            border-radius: var(--radius-lg); 
            border: 1px solid var(--glass-border); 
            box-shadow: var(--shadow-md); 
            transition: var(--transition-spring); 
        }
        .stat-item:hover { 
            transform: translateY(-8px); 
            border-color: var(--primary); 
            box-shadow: var(--shadow-hover);
        }
        .stat-val { 
            font-size: 3.5rem; 
            font-family: 'Outfit', sans-serif; 
            font-weight: 800; 
            background: linear-gradient(135deg, var(--primary), var(--accent)); 
            -webkit-background-clip: text; 
            -webkit-text-fill-color: transparent; 
            margin-bottom: 6px; 
            line-height: 1; 
            filter: drop-shadow(0 4px 8px rgba(79, 70, 229, 0.15));
        }
        body.dark-mode-active .stat-val {
            filter: drop-shadow(0 4px 10px rgba(129, 140, 248, 0.3));
        }
        .stat-label { 
            font-weight: 800; 
            color: var(--text-sub); 
            text-transform: uppercase; 
            letter-spacing: 2px; 
            font-size: 0.82rem; 
        }

        /* --- RESPONSIVENESS --- */
        @media (max-width: 1024px) {
            .bento-grid { grid-template-columns: repeat(2, 1fr); }
            .span-2 { grid-column: span 2; }
            .span-1 { grid-column: span 1; }
            .tech-bento-grid { grid-template-columns: repeat(2, 1fr); }
            .gallery-grid { grid-template-columns: repeat(2, 1fr); }
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .hero-section { padding: 110px 20px 30px; }
            .hero-section h1 { font-size: 2.2rem; }
            .bento-grid { grid-template-columns: 1fr; }
            .span-2 { grid-column: span 1; }
            .bento-card { padding: 30px 20px; }
            .bento-features { grid-template-columns: 1fr; }
            .tech-bento-grid { grid-template-columns: repeat(2, 1fr); }
            .gallery-grid { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
            .stat-val { font-size: 2.5rem; }
        }
    </style>
</head>
<body class="<%= bodyClass %>">

    <!-- NAV BAR -->
    <%- include('./partials/navbar', { currentPage: 'about' }) %>

    <!-- BACKGROUND EFFECTS -->
    <div class="blob-container">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>

    <!-- HERO SECTION -->
    <section class="hero-section">
        <div class="badge-premium animate-on-scroll">
            <i class="fas fa-sparkles"></i>
            <span><%= __('about_hero_badge') %></span>
        </div>
        <h1 class="animate-on-scroll delay-1">
            <%= __('about_hero_title') %>
        </h1>
        <p class="animate-on-scroll delay-2">
            <%= __('about_hero_desc') %>
        </p>
    </section>

    <!-- BENTO GRID SYSTEM -->
    <div class="content-container">
        
        <div class="bento-grid">
            
            <!-- Bento Box 1: What is Kapan Beli (Large) -->
            <section class="bento-card span-2 animate-on-scroll">
                <div>
                    <div class="card-icon"><i class="fas fa-lightbulb"></i></div>
                    <h2 class="card-title"><%= __('about_what_is') %></h2>
                    <p class="card-text" style="margin-bottom: 18px;"><%= __('about_what_is_desc1') %></p>
                    <p class="card-text"><%= __('about_what_is_desc2') %></p>
                </div>
            </section>

            <!-- Bento Box 2: Vision (Small Accent Card) -->
            <section class="bento-card span-1 card-orange animate-on-scroll delay-1">
                <div>
                    <div class="card-icon"><i class="fas fa-bullseye"></i></div>
                    <h2 class="card-title" style="color: var(--accent);"><%= __('about_vision') %></h2>
                    <p class="card-text" style="font-size: 0.98rem; line-height: 1.6;"><%= __('about_vision_desc') %></p>
                </div>
            </section>

            <!-- Bento Box 3: Mission (Small Primary Card) -->
            <section class="bento-card span-1 animate-on-scroll">
                <div>
                    <div class="card-icon"><i class="fas fa-paper-plane"></i></div>
                    <h2 class="card-title" style="color: var(--primary);"><%= __('about_mission') %></h2>
                    <ul style="list-style: none; display: flex; flex-direction: column; gap: 14px;">
                        <li style="display: flex; align-items: flex-start; gap: 10px; font-size: 0.92rem; color: var(--text-muted);">
                            <i class="fas fa-circle-check" style="color: var(--primary); margin-top: 3px; font-size: 1rem;"></i>
                            <span><%= __('about_mission_li1') %></span>
