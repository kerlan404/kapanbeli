<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #1E293B;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-color: #000000;
            --sidebar-width: 280px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1E293B;
            --bg-body: #0F172A;
            --bg-card: #1E293B;
            --text-main: #F1F5F9;
            --text-muted: #94A3B8;
            --border-color: #F1F5F9;
            --shadow-color: #3B82F6;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Neubrutalism UI Components */
        .nb-card {
            background: var(--bg-card);
            border: 4px solid var(--border-color);
            box-shadow: 8px 8px 0px var(--shadow-color);
            padding: 24px;
            transition: all 0.2s ease;
        }

        .nb-card:hover {
            transform: translate(-2px, -2px);
            box-shadow: 12px 12px 0px var(--shadow-color);
        }

        .nb-btn {
            padding: 12px 24px;
            border: 4px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-main);
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 4px 4px 0px var(--shadow-color);
            transition: all 0.1s ease;
            font-size: 0.9rem;
            text-decoration: none;
        }

        .nb-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--shadow-color);
        }

        .nb-btn-primary { background: var(--primary-blue); color: #fff; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 40px;
            max-width: 1600px;
        }

        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        .stat-card {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .stat-icon {
            width: 64px;
            height: 64px;
            border: 4px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            box-shadow: 4px 4px 0px var(--shadow-color);
        }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 900;
            line-height: 1.2;
        }

        .stat-label {
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        /* Charts Section */
        .charts-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
            margin-bottom: 40px;
        }

        @media (max-width: 1200px) {
            .charts-grid { grid-template-columns: 1fr; }
        }

        /* Recent Activity & Previews */
        .previews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 24px;
        }

        @media (max-width: 600px) {
            .previews-grid { grid-template-columns: 1fr; }
        }

        .preview-list { list-style: none; }
        .preview-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px 0;
            border-bottom: 3px solid var(--border-color);
        }
        .preview-item:last-child { border-bottom: none; }

        .activity-icon {
            width: 40px;
            height: 40px;
            border: 3px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .activity-info { flex: 1; }
        .activity-title { font-weight: 800; font-size: 0.95rem; }
        .activity-time { font-size: 0.8rem; color: var(--text-muted); font-weight: 600; }

        /* Mobile Adjustments */
        .menu-toggle {
            display: none;
            width: 50px; height: 50px;
            border: 4px solid var(--border-color);
            background: var(--bg-card);
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 4px 4px 0px var(--shadow-color);
            margin-bottom: 20px;
        }

        @media (max-width: 992px) {
            .main-content { margin-left: 0; padding: 24px; }
            .menu-toggle { display: flex; }
            .page-title { font-size: 2rem; }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <%- include('./partials/admin-sidebar', { currentPage: 'dashboard', user: typeof user !== 'undefined' ? user : null }) %>

    <!-- Main Content -->
    <main class="main-content">
        <button class="menu-toggle" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <div class="header-section">
            <h1 class="page-title">Dashboard Overview</h1>
            <button class="nb-btn" id="themeToggleBtn" onclick="toggleTheme()">
                <i class="fas fa-moon"></i> Tema
            </button>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--primary-blue); color: #fff;">
                    <i class="fas fa-users"></i>
                </div>
                <div>
                    <div class="stat-value" id="statTotalUsers">0</div>
                    <div class="stat-label">Total Pengguna</div>
                </div>
            </div>
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--accent-green); color: #fff;">
                    <i class="fas fa-user-check"></i>
                </div>
                <div>
                    <div class="stat-value" id="statActiveUsers">0</div>
                    <div class="stat-label">Pengguna Aktif</div>
                </div>
            </div>
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--primary-orange); color: #fff;">
                    <i class="fas fa-boxes"></i>
                </div>
                <div>
                    <div class="stat-value" id="statTotalProducts">0</div>
                    <div class="stat-label">Total Produk</div>
                </div>
            </div>
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--accent-red); color: #fff;">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div>
                    <div class="stat-value" id="statLowStock">0</div>
                    <div class="stat-label">Stok Menipis</div>
                </div>
            </div>
        </div>

        <!-- Charts Grid -->
        <div class="charts-grid">
            <div class="nb-card">
                <h3 style="font-weight: 900; text-transform: uppercase; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-chart-line" style="color: var(--primary-blue);"></i>
                    Pertumbuhan Pengguna & Produk
                </h3>
                <div style="height: 350px;">
                    <canvas id="growthChart"></canvas>
                </div>
            </div>
            <div class="nb-card">
                <h3 style="font-weight: 900; text-transform: uppercase; margin-bottom: 20px;">
                    Distribusi Role
                </h3>
                <div style="height: 350px; display: flex; align-items: center; justify-content: center;">
                    <canvas id="roleChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Previews Grid -->
        <div class="previews-grid">
            <!-- Recent Activity -->
            <div class="nb-card">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="font-weight: 900; text-transform: uppercase;">Aktivitas Terakhir</h3>
                    <a href="/admin/activity-logs" class="nb-btn" style="padding: 6px 12px; font-size: 0.75rem;">Semua</a>
                </div>
                <div id="activityLoading" style="text-align: center; padding: 20px;">
                    <i class="fas fa-circle-notch fa-spin"></i>
                </div>
                <ul class="preview-list" id="activityList">
                    <!-- Activities will be loaded here -->
                </ul>
            </div>

            <!-- Urgent Products -->
            <div class="nb-card">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="font-weight: 900; text-transform: uppercase;">Stok Kritis</h3>
                    <a href="/admin/shopping-suggestions" class="nb-btn" style="padding: 6px 12px; font-size: 0.75rem;">Cek Semua</a>
                </div>
                <div id="productsLoading" style="text-align: center; padding: 20px;">
                    <i class="fas fa-circle-notch fa-spin"></i>
                </div>
                <ul class="preview-list" id="productsList">
                    <!-- Products will be loaded here -->
                </ul>
            </div>
        </div>
    </main>

    <script>
        function toggleTheme() {
            if (window.toggleAppTheme) window.toggleAppTheme();
        }

        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const btn = document.getElementById('themeToggleBtn');
            btn.innerHTML = isDark ? '<i class="fas fa-sun"></i> Tema' : '<i class="fas fa-moon"></i> Tema';
            updateChartsTheme(isDark);
        });

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const btn = document.getElementById('themeToggleBtn');
            if (btn) btn.innerHTML = isDark ? '<i class="fas fa-sun"></i> Tema' : '<i class="fas fa-moon"></i> Tema';
            
            loadStats();
            loadActivities();
            loadUrgentProducts();
            initGrowthChart();
            initRoleChart();
        });

        async function loadStats() {
            try {
                const res = await fetch('/api/admin/stats', { credentials: 'same-origin' });
                const result = await res.json();
                if (result.success) {
                    const stats = result.stats;
                    document.getElementById('statTotalUsers').textContent = stats.totalUsers || 0;
                    document.getElementById('statActiveUsers').textContent = stats.activeUsers || 0;
                    document.getElementById('statTotalProducts').textContent = stats.totalProducts || 0;
                    document.getElementById('statLowStock').textContent = stats.lowStockItems || 0;
                }
            } catch (err) { console.error('Error stats:', err); }
        }

        async function loadActivities() {
            try {
                const res = await fetch('/api/activity-logs?limit=5', { credentials: 'same-origin' });
                const result = await res.json();
                document.getElementById('activityLoading').style.display = 'none';
                if (result.success && result.data) {
                    const list = document.getElementById('activityList');
                    list.innerHTML = result.data.map(log => {
                        let color = '#3B82F6';
                        if (log.activity_type === 'DELETE') color = '#EF4444';
                        if (log.activity_type === 'CREATE') color = '#10B981';
                        if (log.activity_type === 'LOGIN') color = '#FF9F43';

                        return `
                            <li class="preview-item">
                                <div class="activity-icon" style="background: ${color}20; border-color: ${color}; color: ${color};">
                                    <i class="fas ${getActivityIcon(log.activity_type)}"></i>
                                </div>
                                <div class="activity-info">
                                    <div class="activity-title"><strong>${log.user_name}</strong> ${log.description}</div>
                                    <div class="activity-time">${new Date(log.created_at).toLocaleString('id-ID')}</div>
                                </div>
                            </li>
                        `;
                    }).join('');
                }
            } catch (err) { console.error('Error activity:', err); }
        }

        function getActivityIcon(type) {
            const icons = {
                'LOGIN': 'fa-sign-in-alt',
                'LOGOUT': 'fa-sign-out-alt',
                'CREATE': 'fa-plus',
                'UPDATE': 'fa-edit',
                'DELETE': 'fa-trash',
                'VIEW': 'fa-eye'
            };
            return icons[type] || 'fa-circle';
        }

        async function loadUrgentProducts() {
            try {
                const res = await fetch('/api/admin/shopping-suggestions?limit=5', { credentials: 'same-origin' });
                const result = await res.json();
                document.getElementById('productsLoading').style.display = 'none';
                if (result.success && result.data) {
                    const list = document.getElementById('productsList');
                    list.innerHTML = result.data.map(p => `
                        <li class="preview-item">
                            <div class="activity-icon" style="background: #EF444420; border-color: #EF4444; color: #EF4444;">
                                <i class="fas fa-exclamation-triangle"></i>
                            </div>
                            <div class="activity-info">
                                <div class="activity-title"><strong>${p.name}</strong> - Stok: ${p.stock_quantity} ${p.unit}</div>
                                <div class="activity-time">Pemilik: ${p.user_name}</div>
                            </div>
                            <div style="font-weight: 900; color: #EF4444; font-size: 0.7rem; text-transform: uppercase;">
                                ${p.stock_quantity <= 0 ? 'Habis' : 'Kritis'}
                            </div>
                        </li>
                    `).join('');
                }
            } catch (err) { console.error('Error products:', err); }
        }

        let growthChart, roleChart;

        async function initGrowthChart() {
            const ctx = document.getElementById('growthChart').getContext('2d');
            
            // Ambil data analitik jika ada endpoint-nya, atau gunakan dummy untuk demo visual
            // Karena analitik biasanya butuh data agregat per hari
            const labels = ['Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu', 'Minggu'];
            const userData = [5, 12, 8, 25, 18, 30, 45];
            const productData = [10, 20, 15, 35, 25, 45, 60];

            growthChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'User Baru',
                            data: userData,
                            borderColor: '#3B82F6',
                            borderWidth: 4,
                            backgroundColor: 'rgba(59, 130, 246, 0.1)',
                            fill: true,
                            tension: 0.4
                        },
                        {
                            label: 'Produk Baru',
                            data: productData,
                            borderColor: '#FF9F43',
                            borderWidth: 4,
                            backgroundColor: 'rgba(255, 159, 67, 0.1)',
                            fill: true,
                            tension: 0.4
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { labels: { font: { weight: 'bold', family: 'Outfit' } } }
                    },
                    scales: {
                        y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }

        async function initRoleChart() {
            const ctx = document.getElementById('roleChart').getContext('2d');
            
            // Get data from stats
            const res = await fetch('/api/users/statistics', { credentials: 'same-origin' });
            const result = await res.json();
            
            let adminCount = 1, userCount = 10; // Defaults
            if (result.success) {
                adminCount = result.data.admin_users;
                userCount = result.data.total_users - adminCount;
            }

            roleChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Admin', 'User'],
                    datasets: [{
                        data: [adminCount, userCount],
                        backgroundColor: ['#3B82F6', '#FF9F43'],
                        borderWidth: 4,
                        borderColor: '#000'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { weight: 'bold', family: 'Outfit' } } }
                    }
                }
            });
        }

        function updateChartsTheme(isDark) {
            const color = isDark ? '#F1F5F9' : '#1E293B';
            const gridColor = isDark ? 'rgba(241, 245, 249, 0.1)' : 'rgba(30, 41, 59, 0.1)';
            
            if (growthChart) {
                growthChart.options.scales.x.ticks.color = color;
                growthChart.options.scales.y.ticks.color = color;
                growthChart.options.scales.y.grid.color = gridColor;
                growthChart.options.plugins.legend.labels.color = color;
                growthChart.update();
            }
            if (roleChart) {
                roleChart.options.plugins.legend.labels.color = color;
                roleChart.data.datasets[0].borderColor = isDark ? '#1E293B' : '#000';
                roleChart.update();
            }
        }
    </script>
</body>
</html>