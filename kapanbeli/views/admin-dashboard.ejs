<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #1E293B;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-color: #000000;
            --sidebar-width: 280px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1E293B;
            --bg-body: #0F172A;
            --bg-card: #1E293B;
            --text-main: #F1F5F9;
            --text-muted: #94A3B8;
            --border-color: #F1F5F9;
            --shadow-color: #3B82F6;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; }

        /* Glowing Live pulse-dot */
        .pulse-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent-green);
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            animation: pulse-green 2s infinite;
            margin-right: 4px;
            vertical-align: middle;
        }

        @keyframes pulse-green {
            0% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            }
            70% {
                transform: scale(1);
                box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
            }
            100% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
            }
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Neubrutalism UI Components */
        .nb-card {
            background: var(--bg-card);
            border: 4px solid var(--border-color);
            box-shadow: 8px 8px 0px var(--shadow-color);
            padding: 24px;
            transition: all 0.2s ease;
        }

        .nb-card:hover {
            transform: translate(-2px, -2px);
            box-shadow: 12px 12px 0px var(--shadow-color);
        }

        .nb-btn {
            padding: 12px 24px;
            border: 4px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-main);
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 4px 4px 0px var(--shadow-color);
            transition: all 0.1s ease;
            font-size: 0.9rem;
            text-decoration: none;
        }

        .nb-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--shadow-color);
        }

        .nb-btn-primary { background: var(--primary-blue); color: #fff; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            padding: 40px;
            max-width: 1600px;
        }

        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 24px;
            margin-bottom: 40px;
        }

        .stat-card {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .stat-card:hover .stat-icon {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px var(--shadow-color);
        }

        .stat-icon {
            width: 64px;
            height: 64px;
            border: 4px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            box-shadow: 4px 4px 0px var(--shadow-color);
            transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .stat-value {
            font-size: 2.2rem;
            font-weight: 900;
            line-height: 1.2;
        }

        .stat-label {
            font-weight: 800;
            text-transform: uppercase;
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        /* Charts Section */
        .charts-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 24px;
            margin-bottom: 40px;
        }

        @media (max-width: 1400px) {
            .charts-grid { grid-template-columns: 1fr 1fr; }
        }

        @media (max-width: 992px) {
            .charts-grid { grid-template-columns: 1fr; }
        }

        /* Recent Activity & Previews */
        .previews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
        }

        .previews-grid .nb-card {
            min-height: 420px;
            max-height: 420px;
            display: flex;
            flex-direction: column;
        }

        .preview-list {
            list-style: none;
            flex: 1;
            overflow-y: auto;
            padding-right: 5px;
        }
        
        /* Custom Scrollbar for Preview List */
        .preview-list::-webkit-scrollbar { width: 8px; }
        .preview-list::-webkit-scrollbar-track { background: transparent; }
        .preview-list::-webkit-scrollbar-thumb { 
            background: var(--border-color); 
            border: 2px solid var(--bg-card);
        }
        
        .preview-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 14px 8px;
            border-bottom: 3px solid var(--border-color);
            transition: all 0.2s ease;
        }
        .preview-item:hover {
            background: rgba(59, 130, 246, 0.03);
            transform: translateX(3px);
        }
        body.dark-mode-active .preview-item:hover {
            background: rgba(59, 130, 246, 0.08);
        }
        .preview-item:last-child { border-bottom: none; }

        .activity-icon {
            width: 40px;
            height: 40px;
            border: 3px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
            box-shadow: 2px 2px 0px var(--border-color);
            transition: all 0.2s ease;
        }
        .preview-item:hover .activity-icon {
            transform: translate(-1px, -1px);
            box-shadow: 3px 3px 0px var(--border-color);
        }

        .activity-info { flex: 1; min-width: 0; }
        .activity-title { font-weight: 800; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .activity-desc { font-size: 0.85rem; color: var(--text-muted); font-weight: 600; margin-top: 2px; }
        .activity-time { font-size: 0.75rem; color: var(--text-muted); font-weight: 700; margin-top: 4px; display: block; }
        .activity-user { font-size: 0.75rem; font-weight: 800; color: var(--primary-blue); margin-bottom: 2px; display: block; text-transform: uppercase; }

        /* Status Badges for Lists */
        .status-badge {
            font-size: 0.7rem; padding: 2px 8px; border: 2px solid var(--border-color);
            font-weight: 900; text-transform: uppercase;
        }
        .status-pending { background: var(--primary-orange); color: white; }
        .status-unfinished { background: var(--accent-red); color: white; }
        .status-suggestion { background: var(--primary-blue); color: white; }

        /* Empty State */
        .empty-state {
            text-align: center; padding: 40px 20px; color: var(--text-muted);
            font-weight: 800; text-transform: uppercase; font-size: 0.85rem;
        }

        /* Premium Table Styles */
        .nb-table-container {
            overflow-x: auto;
            border: 4px solid var(--border-color);
            background: var(--bg-card);
            box-shadow: 6px 6px 0px var(--shadow-color);
            margin-top: 15px;
            transition: all 0.2s ease;
        }
        .nb-table-container:hover {
            transform: translate(-1px, -1px);
            box-shadow: 8px 8px 0px var(--shadow-color);
        }
        .nb-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 800px;
        }
        .nb-table th {
            background: var(--primary-blue);
            color: #fff;
            padding: 16px 20px;
            font-weight: 900;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
            border-bottom: 4px solid var(--border-color);
            border-right: 3px solid var(--border-color);
            text-align: left;
        }
        .nb-table th:last-child {
            border-right: none;
            text-align: center;
        }
        .nb-table td {
            padding: 16px 20px;
            font-weight: 700;
            font-size: 0.9rem;
            border-bottom: 3px solid var(--border-color);
            border-right: 3px solid var(--border-color);
            color: var(--text-main);
            transition: background 0.1s ease;
        }
        .nb-table td:last-child {
            border-right: none;
        }
        .nb-table tr:last-child td {
            border-bottom: none;
        }
        .nb-table tr:hover td {
            background: rgba(59, 130, 246, 0.04);
        }
        body.dark-mode-active .nb-table tr:hover td {
            background: rgba(59, 130, 246, 0.12);
        }

        /* Custom Dropdown select override styling */
        select.nb-btn {
            appearance: none;
            -webkit-appearance: none;
            padding-right: 36px !important;
            background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='black' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpolyline points='6 9 12 15 18 9'%3E%3C/polyline%3E%3C/svg%3E");
            background-repeat: no-repeat;
            background-position: right 12px center;
            background-size: 14px;
        }
        
        body.dark-mode-active select.nb-btn {
            background-image: url("data:image/svg+xml;charset=UTF-8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'%3E%3Cpolyline points='6 9 12 15 18 9'%3E%3C/polyline%3E%3C/svg%3E");
        }

        @media (max-width: 992px) {
            .main-content { margin-left: 0; padding: 24px; }
            .page-title { font-size: 2rem; }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <%- include('./partials/admin-sidebar', { currentPage: 'dashboard', user: typeof user !== 'undefined' ? user : null }) %>

    <!-- Main Content -->
    <main class="main-content">
        <button class="menu-toggle" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <div class="header-section">
            <div>
                <h1 class="page-title">Dashboard Overview</h1>
                <p style="color: var(--text-muted); font-weight: 700;">Selamat datang kembali, Admin!</p>
            </div>
            <div style="display: flex; gap: 15px; align-items: center;">
                <select id="analyticsRange" class="nb-btn" style="padding: 10px 15px; font-weight: 800; cursor: pointer; outline: none;" onchange="handleRangeChange()">
                    <option value="today">Hari Ini</option>
                    <option value="7days" selected>7 Hari Terakhir</option>
                    <option value="7weeks">7 Minggu Terakhir</option>
                    <option value="month">Bulan Ini</option>
                </select>
                <button class="nb-btn" id="themeToggleBtn" onclick="toggleTheme()">
                    <i class="fas fa-moon"></i> Tema
                </button>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--primary-blue); color: #fff;">
                    <i class="fas fa-users"></i>
                </div>
                <div>
                    <div class="stat-value" id="statTotalUsers">0</div>
                    <div class="stat-label">Total Pengguna</div>
                </div>
            </div>
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--accent-green); color: #fff;">
                    <i class="fas fa-user-check"></i>
                </div>
                <div>
                    <div class="stat-value" id="statActiveUsers">0</div>
                    <div class="stat-label">Pengguna Aktif</div>
                </div>
            </div>
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--primary-orange); color: #fff;">
                    <i class="fas fa-boxes"></i>
                </div>
                <div>
                    <div class="stat-value" id="statTotalProducts">0</div>
                    <div class="stat-label">Total Produk</div>
                </div>
            </div>
            <div class="nb-card stat-card">
                <div class="stat-icon" style="background: var(--accent-red); color: #fff;">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div>
                    <div class="stat-value" id="statLowStock">0</div>
                    <div class="stat-label">Stok Menipis</div>
                </div>
            </div>
        </div>

        <!-- Charts Grid -->
        <div class="charts-grid">
            <div class="nb-card" style="display: flex; flex-direction: column;">
                <div style="padding-bottom: 15px; border-bottom: 4px solid var(--border-color); margin-bottom: 20px;">
                    <h3 style="font-weight: 900; text-transform: uppercase; display: flex; align-items: center; gap: 10px; font-size: 1.1rem;">
                        <i class="fas fa-chart-line" style="color: var(--primary-blue);"></i>
                        Pertumbuhan <span id="currentRangeLabel" style="color: var(--primary-blue);">7 Hari Terakhir</span>
                    </h3>
                </div>
                <div style="height: 350px; flex: 1;">
                    <canvas id="growthChart"></canvas>
                </div>
            </div>
            <div class="nb-card" style="display: flex; flex-direction: column;">
                <div style="padding-bottom: 15px; border-bottom: 4px solid var(--border-color); margin-bottom: 20px;">
                    <h3 style="font-weight: 900; text-transform: uppercase; display: flex; align-items: center; gap: 10px; font-size: 1.1rem;">
                        <i class="fas fa-user-shield" style="color: var(--primary-orange);"></i>
                        Distribusi Role
                    </h3>
                </div>
                <div style="height: 350px; flex: 1; display: flex; align-items: center; justify-content: center;">
                    <canvas id="roleChart"></canvas>
                </div>
            </div>
            <div class="nb-card" style="display: flex; flex-direction: column;">
                <div style="padding-bottom: 15px; border-bottom: 4px solid var(--border-color); margin-bottom: 20px;">
                    <h3 style="font-weight: 900; text-transform: uppercase; display: flex; align-items: center; gap: 10px; font-size: 1.1rem;">
                        <i class="fas fa-tags" style="color: var(--accent-green);"></i>
                        Kategori Produk
                    </h3>
                </div>
                <div style="height: 350px; flex: 1; display: flex; align-items: center; justify-content: center;">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
        <!-- Monitoring Grid -->
        <div class="previews-grid" style="margin-bottom: 40px;">
            <!-- Global Activity Log -->
            <div class="nb-card" style="border-top: 8px solid var(--primary-blue);">
                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 4px solid var(--border-color); margin-bottom: 15px;">
                    <h3 style="font-weight: 900; text-transform: uppercase; font-size: 1.05rem; display: flex; align-items: center; gap: 8px;">
                        <i class="fas fa-history" style="color: var(--primary-blue);"></i>
                        Aktivitas Global
                    </h3>
                    <a href="/admin/activity-logs" class="nb-btn" style="padding: 6px 12px; font-size: 0.7rem; box-shadow: 2px 2px 0px var(--border-color);">Lihat</a>
                </div>
                <div id="activityLoading" style="text-align: center; padding: 20px;">
                    <i class="fas fa-circle-notch fa-spin" style="color: var(--primary-blue);"></i>
                </div>
                <div id="activityList" class="preview-list"></div>
            </div>

            <!-- Notes Monitor -->
            <div class="nb-card" style="border-top: 8px solid var(--primary-orange);">
                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 4px solid var(--border-color); margin-bottom: 15px;">
                    <h3 style="font-weight: 900; text-transform: uppercase; font-size: 1.05rem; display: flex; align-items: center; gap: 8px;">
                        <i class="fas fa-sticky-note" style="color: var(--primary-orange);"></i>
                        Catatan Monitor
                    </h3>
                    <a href="/admin/notes" class="nb-btn" style="padding: 6px 12px; font-size: 0.7rem; box-shadow: 2px 2px 0px var(--border-color);">Kelola</a>
                </div>
                <div id="notesLoading" style="text-align: center; padding: 20px;">
                    <i class="fas fa-circle-notch fa-spin" style="color: var(--primary-orange);"></i>
                </div>
                <div id="notesMonitorList" class="preview-list"></div>
            </div>

            <!-- Shopping Suggestions -->
            <div class="nb-card" style="border-top: 8px solid var(--accent-green);">
                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 4px solid var(--border-color); margin-bottom: 15px;">
                    <h3 style="font-weight: 900; text-transform: uppercase; font-size: 1.05rem; display: flex; align-items: center; gap: 8px;">
                        <i class="fas fa-shopping-basket" style="color: var(--accent-green);"></i>
                        Saran Pembelian
                    </h3>
                    <a href="/admin/shopping-suggestions" class="nb-btn" style="padding: 6px 12px; font-size: 0.7rem; box-shadow: 2px 2px 0px var(--border-color);">Cek</a>
                </div>
                <div id="suggestionsLoading" style="text-align: center; padding: 20px;">
                    <i class="fas fa-circle-notch fa-spin" style="color: var(--accent-green);"></i>
                </div>
                <div id="suggestionList" class="preview-list"></div>
            </div>

            <!-- Kontributor Teraktif -->
            <div class="nb-card" style="border-top: 8px solid #A855F7;">
                <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 12px; border-bottom: 4px solid var(--border-color); margin-bottom: 15px;">
                    <h3 style="font-weight: 900; text-transform: uppercase; font-size: 1.05rem; display: flex; align-items: center; gap: 8px;">
                        <i class="fas fa-trophy" style="color: #A855F7;"></i>
                        Kontributor Teraktif
                    </h3>
                </div>
                <div id="topUsersLoading" style="text-align: center; padding: 20px; flex: 1; display: flex; align-items: center; justify-content: center;">
                    <i class="fas fa-circle-notch fa-spin" style="color: #A855F7; font-size: 1.5rem;"></i>
                </div>
                <div id="topUsersList" class="preview-list" style="display: none; flex: 1; overflow-y: auto;">
                    <!-- User ranks list items -->
                </div>
            </div>
        </div>

        <!-- Product Management Section -->
        <div class="nb-card" style="margin-bottom: 40px; border-top: 8px solid var(--primary-blue);">
            <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 15px; border-bottom: 4px solid var(--border-color); margin-bottom: 25px;">
                <h3 style="font-weight: 900; text-transform: uppercase; font-size: 1.25rem; display: flex; align-items: center; gap: 15px;">
                    <div style="width: 44px; height: 44px; background: var(--primary-blue); color: white; display: flex; align-items: center; justify-content: center; border: 3px solid var(--border-color); box-shadow: 3px 3px 0 var(--border-color); transition: all 0.2s ease;">
                        <i class="fas fa-boxes"></i>
                    </div>
                    Manajemen Produk Terbaru
                </h3>
                <a href="/admin/products" class="nb-btn" style="padding: 10px 20px; font-size: 0.85rem;">
                    <i class="fas fa-external-link-alt" style="margin-right: 8px;"></i> Ke Halaman Produk
                </a>
            </div>
            
            <div class="nb-table-container">
                <table class="nb-table">
                    <thead>
                        <tr>
                            <th>Produk</th>
                            <th>Kategori</th>
                            <th>Stok</th>
                            <th>Pemilik</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="latestProductsTable">
                        <tr>
                            <td colspan="5" style="padding: 40px; text-align: center; font-weight: 800; color: var(--text-muted);">
                                <i class="fas fa-circle-notch fa-spin" style="margin-right: 10px;"></i> Memuat produk...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        function toggleTheme() {
            if (window.toggleAppTheme) window.toggleAppTheme();
        }

        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const btn = document.getElementById('themeToggleBtn');
            btn.innerHTML = isDark ? '<i class="fas fa-sun"></i> Tema' : '<i class="fas fa-moon"></i> Tema';
            updateChartsTheme(isDark);
        });

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const btn = document.getElementById('themeToggleBtn');
            if (btn) btn.innerHTML = isDark ? '<i class="fas fa-sun"></i> Tema' : '<i class="fas fa-moon"></i> Tema';
            
            const savedRange = localStorage.getItem('dashboard_range') || '7days';
            document.getElementById('analyticsRange').value = savedRange;
            
            loadStats();
            loadActivities();
            loadNotesMonitor();
            loadSuggestions();
            loadLatestProducts();
            loadTopUsers();
            initCharts(savedRange);
        });

        function handleRangeChange() {
            const range = document.getElementById('analyticsRange').value;
            localStorage.setItem('dashboard_range', range);
            initCharts(range);
            loadStats(); // Reload stats as some might be range-dependent
        }

        async function initCharts(range = '7days') {
            initGrowthChart(range);
            initRoleChart();
            initCategoryChart();
        }

        async function loadStats() {
            try {
                const res = await fetch('/api/admin/stats', { credentials: 'same-origin' });
                const result = await res.json();
                if (result.success) {
                    const stats = result.stats;
                    document.getElementById('statTotalUsers').textContent = stats.totalUsers || 0;
                    document.getElementById('statActiveUsers').textContent = stats.activeUsers || 0;
                    document.getElementById('statTotalProducts').textContent = stats.totalProducts || 0;
                    document.getElementById('statLowStock').textContent = stats.lowStockItems || 0;
                }
            } catch (err) { console.error('Error stats:', err); }
        }

        async function loadActivities() {
            try {
                const res = await fetch('/api/activity-logs?limit=8', { credentials: 'same-origin' });
                const result = await res.json();
                document.getElementById('activityLoading').style.display = 'none';
                if (result.success && result.data) {
                    const list = document.getElementById('activityList');
                    list.innerHTML = result.data.map(log => {
                        let color = 'var(--primary-blue)';
                        if (log.activity_type === 'DELETE') color = 'var(--accent-red)';
                        if (log.activity_type === 'CREATE') color = 'var(--accent-green)';
                        if (log.activity_type === 'LOGIN') color = 'var(--primary-orange)';
                        
                        return `
                            <div class="preview-item">
                                <div class="activity-icon" style="background: ${color}10; border-color: ${color}; color: ${color}; width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fas ${getActivityIcon(log.activity_type)}"></i>
                                </div>
                                <div class="activity-info">
                                    <div class="activity-user" style="font-size: 0.7rem; font-weight: 900; color: ${color}; margin-bottom: 2px;">${log.user_name} • ${log.activity_type}</div>
                                    <div class="activity-title" style="font-size: 0.85rem; font-weight: 700;">${log.description}</div>
                                    <div class="activity-time" style="font-size: 0.7rem;">${formatTimeAgo(log.created_at)}</div>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
            } catch (err) { console.error('Error activity:', err); }
        }



        async function loadNotesMonitor() {
            try {
                const res = await fetch('/api/admin/notes?limit=8', { credentials: 'same-origin' });
                const result = await res.json();
                document.getElementById('notesLoading').style.display = 'none';
                const notes = (result.data || []).filter(n => n.status !== 'Selesai').slice(0, 8);
                
                const list = document.getElementById('notesMonitorList');
                if (notes.length === 0) {
                    list.innerHTML = '<div class="empty-state">Semua catatan selesai</div>';
                    return;
                }

                list.innerHTML = notes.map(n => `
                    <div class="preview-item">
                        <div class="activity-icon" style="background: ${n.status === 'Pending' ? 'var(--primary-orange)' : 'var(--accent-red)'}10; border-color: ${n.status === 'Pending' ? 'var(--primary-orange)' : 'var(--accent-red)'}; color: ${n.status === 'Pending' ? 'var(--primary-orange)' : 'var(--accent-red)'}; width: 36px; height: 36px; font-size: 0.9rem;">
                            <i class="fas fa-sticky-note"></i>
                        </div>
                        <div class="activity-info">
                            <div class="activity-user" style="font-size: 0.7rem; font-weight: 900; color: var(--text-muted); margin-bottom: 2px;">${n.user_name} • <span class="status-badge ${n.status === 'Pending' ? 'status-pending' : 'status-unfinished'}" style="font-size: 0.6rem; padding: 1px 4px;">${n.status}</span></div>
                            <div class="activity-title" style="font-size: 0.85rem; font-weight: 700;">${n.title}</div>
                            <div class="activity-time" style="font-size: 0.7rem;">${formatTimeAgo(n.created_at)}</div>
                        </div>
                    </div>
                `).join('');
            } catch (err) { console.error('Error notes:', err); }
        }

        async function loadSuggestions() {
            try {
                const res = await fetch('/api/admin/shopping-suggestions?limit=8', { credentials: 'same-origin' });
                const result = await res.json();
                document.getElementById('suggestionsLoading').style.display = 'none';
                const suggestions = result.data || [];
                
                const list = document.getElementById('suggestionList');
                if (suggestions.length === 0) {
                    list.innerHTML = '<div class="empty-state">Stok aman semua</div>';
                    return;
                }

                list.innerHTML = suggestions.map(s => `
                    <div class="preview-item">
                        <div class="activity-icon" style="background: var(--accent-green)10; border-color: var(--accent-green); color: var(--accent-green); width: 36px; height: 36px; font-size: 0.9rem;">
                            <i class="fas fa-shopping-basket"></i>
                        </div>
                        <div class="activity-info">
                            <div class="activity-user" style="font-size: 0.7rem; font-weight: 900; color: var(--text-muted); margin-bottom: 2px;">${s.user_name} • Stok: ${s.stock_quantity}</div>
                            <div class="activity-title" style="font-size: 0.85rem; font-weight: 700;">${s.name}</div>
                            <div class="activity-time" style="font-size: 0.7rem;">Disarankan beli di ${s.category_name || 'Pasar/Toko'}</div>
                        </div>
                    </div>
                `).join('');
            } catch (err) { console.error('Error suggestions:', err); }
        }

        async function loadTopUsers() {
            try {
                const res = await fetch('/api/admin/analytics/top-users', { credentials: 'same-origin' });
                const result = await res.json();
                
                const listContainer = document.getElementById('topUsersList');
                const loadingElement = document.getElementById('topUsersLoading');
                
                if (result.success && result.users) {
                    const users = result.users;
                    loadingElement.style.display = 'none';
                    listContainer.style.display = 'block';
                    
                    if (users.length === 0) {
                        listContainer.innerHTML = '<div class="empty-state">Belum ada aktivitas pengguna</div>';
                        return;
                    }
                    
                    const medals = ['🥇', '🥈', '🥉'];
                    
                    listContainer.innerHTML = users.map((user, idx) => {
                        const isTop3 = idx < 3;
                        const rankBadge = isTop3 
                            ? `<span style="font-size: 1.25rem; margin-right: 8px;">${medals[idx]}</span>`
                            : `<span style="font-weight: 900; font-size: 0.85rem; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; border: 2px solid var(--border-color); background: var(--bg-body); border-radius: 50%; margin-right: 8px;">${idx + 1}</span>`;
                        
                        return `
                            <div class="preview-item">
                                <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0;">
                                    ${rankBadge}
                                    <div style="flex: 1; min-width: 0;">
                                        <div style="font-weight: 800; font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: flex; align-items: center; gap: 6px;">
                                            ${user.name}
                                            ${idx === 0 ? '<span class="status-badge" style="background: #FEF3C7; color: #D97706; border-color: #F59E0B; font-size: 0.55rem; padding: 1px 6px;">MVP</span>' : ''}
                                        </div>
                                        <div style="font-size: 0.75rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${user.email}</div>
                                    </div>
                                </div>
                                <div style="text-align: right; flex-shrink: 0;">
                                    <div style="font-weight: 900; font-size: 0.95rem; color: var(--primary-blue);">${user.total_products} Produk</div>
                                    <div style="font-size: 0.7rem; color: var(--text-muted); font-weight: 700;">${user.total_stock} Stok</div>
                                </div>
                            </div>
                        `;
                    }).join('');
                } else {
                    loadingElement.innerHTML = '<span style="color: var(--accent-red); font-weight: 800;">Gagal memuat data</span>';
                }
            } catch (err) {
                console.error('Error loadTopUsers:', err);
                document.getElementById('topUsersLoading').innerHTML = '<span style="color: var(--accent-red); font-weight: 800;">Kesalahan Server</span>';
            }
        }



        function formatTimeAgo(dateString) {
            const now = new Date();
            const date = new Date(dateString);
            const seconds = Math.floor((now - date) / 1000);
            
            if (seconds < 60) return 'Baru saja';
            const minutes = Math.floor(seconds / 60);
            if (minutes < 60) return `${minutes} menit lalu`;
            const hours = Math.floor(minutes / 60);
            if (hours < 24) return `${hours} jam lalu`;
            const days = Math.floor(hours / 24);
            if (days < 7) return `${days} hari lalu`;
            return date.toLocaleDateString('id-ID');
        }

        let growthChart, roleChart, categoryChart;

        async function loadLatestProducts() {
            try {
                const res = await fetch('/api/admin/products?limit=10', { credentials: 'same-origin' });
                const result = await res.json();
                const tbody = document.getElementById('latestProductsTable');
                
                if (result.success && result.data) {
                    const products = result.data;
                    if (products.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" style="padding: 40px; text-align: center; font-weight: 800;">Belum ada produk</td></tr>';
                        return;
                    }

                    tbody.innerHTML = products.map(p => {
                        let stockColor = 'var(--text-main)';
                        let stockLabel = 'Aman';
                        if (p.stock_quantity <= 0) { 
                            stockColor = 'var(--accent-red)'; 
                            stockLabel = 'Habis'; 
                        } else if (p.stock_quantity <= p.min_stock_level) { 
                            stockColor = 'var(--primary-orange)'; 
                            stockLabel = 'Menipis'; 
                        } else {
                            stockColor = 'var(--accent-green)';
                        }

                        return `
                            <tr>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <div style="width: 36px; height: 36px; border: 2px solid var(--border-color); background: ${p.image_url ? `url(${p.image_url})` : 'var(--primary-blue)'}; background-size: cover; background-position: center; box-shadow: 2px 2px 0px var(--border-color); flex-shrink: 0;"></div>
                                        <span style="font-weight: 800;">${p.name}</span>
                                    </div>
                                </td>
                                <td style="color: var(--text-muted); font-weight: 800; text-transform: uppercase; font-size: 0.8rem;">${p.category_name || 'Lainnya'}</td>
                                <td style="font-weight: 900; color: ${stockColor};">${p.stock_quantity} ${p.unit || ''}</td>
                                <td>
                                    <div style="font-weight: 800; font-size: 0.85rem;">${p.user_name || 'System'}</div>
                                    <div style="font-size: 0.7rem; color: var(--text-muted);">${p.user_email || ''}</div>
                                </td>
                                <td style="text-align: center;">
                                    <span class="status-badge" style="background: ${stockColor}15; color: ${stockColor}; border: 2px solid ${stockColor}; padding: 6px 12px; font-size: 0.65rem; font-weight: 900; text-transform: uppercase; box-shadow: 2px 2px 0px ${stockColor}; display: inline-block;">${stockLabel}</span>
                                </td>
                            </tr>
                        `;
                    }).join('');
                } else {
                    tbody.innerHTML = '<tr><td colspan="5" style="padding: 40px; text-align: center; color: var(--accent-red); font-weight: 800;">Gagal memuat data</td></tr>';
                }
            } catch (err) { 
                console.error('Error loading latest products:', err); 
                document.getElementById('latestProductsTable').innerHTML = '<tr><td colspan="5" style="padding: 40px; text-align: center; color: var(--accent-red); font-weight: 800;">Kesalahan Server</td></tr>';
            }
        }

        async function initGrowthChart(range = '7days') {
            const ctx = document.getElementById('growthChart').getContext('2d');
            
            try {
                const res = await fetch(`/api/admin/analytics?range=${range}`, { credentials: 'same-origin' });
                const result = await res.json();
                
                if (result.success) {
                    const data = result.chart;
                    document.getElementById('currentRangeLabel').textContent = result.period;

                    if (growthChart) growthChart.destroy();

                    growthChart = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.labels,
                            datasets: [
                                {
                                    label: 'User Baru',
                                    data: data.users,
                                    borderColor: '#3B82F6',
                                    borderWidth: 4,
                                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                                    fill: true,
                                    tension: 0.4
                                },
                                {
                                    label: 'Produk Baru',
                                    data: data.products,
                                    borderColor: '#FF9F43',
                                    borderWidth: 4,
                                    backgroundColor: 'rgba(255, 159, 67, 0.1)',
                                    fill: true,
                                    tension: 0.4
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { labels: { font: { weight: 'bold', family: 'Outfit' } } }
                            },
                            scales: {
                                y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
                                x: { grid: { display: false } }
                            }
                        }
                    });
                    updateChartsTheme(document.body.classList.contains('dark-mode-active'));
                }
            } catch (err) { console.error('Error growth chart:', err); }
        }

        function getActivityIcon(type) {
            const icons = {
                'LOGIN': 'fa-sign-in-alt',
                'LOGOUT': 'fa-sign-out-alt',
                'CREATE': 'fa-plus',
                'UPDATE': 'fa-edit',
                'DELETE': 'fa-trash',
                'VIEW': 'fa-eye'
            };
            return icons[type] || 'fa-circle';
        }

        async function initRoleChart() {
            const ctx = document.getElementById('roleChart').getContext('2d');
            
            try {
                const res = await fetch('/api/users/statistics', { credentials: 'same-origin' });
                const result = await res.json();
                
                let adminCount = 1, userCount = 10;
                if (result.success) {
                    adminCount = result.data.admin_users;
                    userCount = result.data.total_users - adminCount;
                }

                if (roleChart) roleChart.destroy();

                roleChart = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Admin', 'User'],
                        datasets: [{
                            data: [adminCount, userCount],
                            backgroundColor: ['#3B82F6', '#FF9F43'],
                            borderWidth: 4,
                            borderColor: '#000'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { position: 'bottom', labels: { font: { weight: 'bold', family: 'Outfit' } } }
                        }
                    }
                });
                updateChartsTheme(document.body.classList.contains('dark-mode-active'));
            } catch (err) { console.error('Error role chart:', err); }
        }

        async function initCategoryChart() {
            const ctx = document.getElementById('categoryChart').getContext('2d');
            
            try {
                const res = await fetch('/api/admin/analytics/category-distribution', { credentials: 'same-origin' });
                const result = await res.json();
                
                if (result.success) {
                    const data = result.categories;
                    const labels = data.map(c => c.name);
                    const counts = data.map(c => c.count);
                    const colors = ['#3B82F6', '#FF9F43', '#10B981', '#EF4444', '#F59E0B', '#8B5CF6'];

                    if (categoryChart) categoryChart.destroy();

                    categoryChart = new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: labels,
                            datasets: [{
                                data: counts,
                                backgroundColor: colors,
                                borderWidth: 4,
                                borderColor: '#000'
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom', labels: { font: { weight: 'bold', family: 'Outfit', size: 10 } } }
                            }
                        }
                    });
                    updateChartsTheme(document.body.classList.contains('dark-mode-active'));
                }
            } catch (err) { console.error('Error category chart:', err); }
        }

        function updateChartsTheme(isDark) {
            const color = isDark ? '#F1F5F9' : '#1E293B';
            const gridColor = isDark ? 'rgba(241, 245, 249, 0.1)' : 'rgba(30, 41, 59, 0.1)';
            
            if (growthChart) {
                growthChart.options.scales.x.ticks.color = color;
                growthChart.options.scales.y.ticks.color = color;
                growthChart.options.scales.y.grid.color = gridColor;
                growthChart.options.plugins.legend.labels.color = color;
                growthChart.update();
            }
            if (roleChart) {
                roleChart.options.plugins.legend.labels.color = color;
                roleChart.data.datasets[0].borderColor = isDark ? '#1E293B' : '#000';
                roleChart.update();
            }
            if (categoryChart) {
                categoryChart.options.plugins.legend.labels.color = color;
                categoryChart.data.datasets[0].borderColor = isDark ? '#1E293B' : '#000';
                categoryChart.update();
            }
        }
    </script>
</body>
</html>