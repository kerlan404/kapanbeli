<% if (typeof user === 'undefined') { var user = null; } %>
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Produk - Kapan Beli</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🛒</text></svg>" type="image/x-icon">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <style>
        :root {
            --primary-blue: #2E86DE;
            --primary-orange: #FF9F43;
            --accent-green: #1DD1A1;
            --accent-red: #FF6B6B;
            --bg-light: #F8FAFC;
            --white: #FFFFFF;
            --text-main: #1E293B;
            --text-muted: #64748B;
            --card-shadow: 0 10px 40px rgba(15, 23, 42, 0.08);
            --border-radius: 24px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --danger: #EF4444;
            --success: #10B981;
            --warning: #F59E0B;
        }

        body.dark-mode-active {
            --bg-light: #020617;
            --white: rgba(15, 23, 42, 0.7);
            --text-main: #F8FAFC;
            --text-muted: #94A3B8;
            --card-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
            --border-glass: rgba(255, 255, 255, 0.05);
        }

        * {
            margin: 0; padding: 0; box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
            transition: background 0.3s, color 0.3s, border-color 0.3s, box-shadow 0.3s;
        }

        body {
            background-color: var(--bg-light);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- MODERN NAVBAR --- */
        .navbar {
            background: var(--white);
            backdrop-filter: blur(12px);
            padding: 18px 5%;
            box-shadow: var(--card-shadow);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-glass);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .back-btn {
            text-decoration: none;
            color: var(--text-main);
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 20px;
            background: rgba(46, 134, 222, 0.1);
            color: var(--primary-blue);
            border-radius: 14px;
            transition: var(--transition);
        }

        .back-btn:hover {
            background: var(--primary-blue);
            color: white;
            transform: translateX(-5px);
            box-shadow: 0 5px 15px rgba(46, 134, 222, 0.2);
        }

        /* --- LAYOUT --- */
        .container {
            max-width: 1000px;
            margin: 60px auto;
            padding: 0 24px;
            flex: 1;
            animation: fadeIn 0.6s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .detail-card {
            background: var(--white);
            backdrop-filter: blur(20px);
            border-radius: var(--border-radius);
            padding: 48px;
            box-shadow: var(--card-shadow);
            border: 1px solid var(--border-glass);
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 50px;
            position: relative;
            overflow: hidden;
        }

        /* --- LEFT: IMAGE SECTION --- */
        .detail-image-section {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .detail-image-wrapper {
            width: 100%;
            aspect-ratio: 1;
            background: linear-gradient(135deg, rgba(255, 159, 67, 0.05), rgba(46, 134, 222, 0.05));
            border-radius: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 1px solid var(--border-glass);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.02);
            position: relative;
        }

        .detail-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .detail-image-wrapper:hover img {
            transform: scale(1.05);
        }

        .detail-image-wrapper i {
            font-size: 5rem;
            color: var(--primary-orange);
            opacity: 0.5;
        }

        /* --- RIGHT: CONTENT SECTION --- */
        .detail-info-section {
            display: flex;
            flex-direction: column;
        }

        .detail-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 32px;
        }

        .detail-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--text-main);
            letter-spacing: -1px;
            line-height: 1.1;
        }

        .action-group {
            display: flex;
            gap: 12px;
        }

        .btn-action {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            border: 1px solid var(--border-glass);
            background: var(--bg-light);
            cursor: pointer;
            color: var(--text-main);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            transition: var(--transition);
        }

        .btn-action:hover {
            background: var(--primary-orange);
            color: white;
            transform: translateY(-3px) rotate(8deg);
            box-shadow: 0 8px 20px rgba(255, 159, 67, 0.3);
            border-color: var(--primary-orange);
        }

        .btn-action.delete:hover {
            background: var(--danger);
            color: white;
            border-color: var(--danger);
            box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
        }

        /* --- DATA GRID --- */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            margin-bottom: 40px;
        }

        .info-item {
            padding: 20px;
            background: rgba(46, 134, 222, 0.03);
            border: 1px solid var(--border-glass);
            border-radius: 20px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            transition: var(--transition);
        }

        .info-item:hover {
            background: rgba(46, 134, 222, 0.06);
            transform: translateY(-3px);
        }

        .info-label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .info-label i {
            color: var(--primary-blue);
            font-size: 0.9rem;
        }

        .info-value {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-main);
        }

        /* --- STATUS BADGES --- */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 16px;
            border-radius: 100px;
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .st-ok { background: rgba(16, 185, 129, 0.1); color: #10B981; border: 1px solid rgba(16, 185, 129, 0.2); }
        .st-low { background: rgba(245, 158, 11, 0.1); color: #F59E0B; border: 1px solid rgba(245, 158, 11, 0.2); }
        .st-out { background: rgba(239, 68, 68, 0.1); color: #EF4444; border: 1px solid rgba(239, 68, 68, 0.2); }

        /* --- DESCRIPTION --- */
        .notes-section {
            padding: 24px;
            background: var(--bg-light);
            border-radius: 24px;
            border: 1px solid var(--border-glass);
            position: relative;
        }

        .notes-title {
            font-size: 0.85rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--text-muted);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .notes-content {
            font-size: 1rem;
            line-height: 1.7;
            color: var(--text-main);
            opacity: 0.9;
        }

        /* --- DEACTIVATION OVERLAY --- */
        .deactivation-overlay {
            position: absolute;
            inset: 0;
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(12px);
            z-index: 100;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        .deactivation-card {
            background: var(--white);
            border-radius: 32px;
            padding: 40px;
            max-width: 500px;
            text-align: center;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .deactivation-icon {
            width: 80px;
            height: 80px;
            background: rgba(239, 68, 68, 0.1);
            color: var(--danger);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 24px;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
            70% { box-shadow: 0 0 0 20px rgba(239, 68, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

        .deactivation-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--danger);
            margin-bottom: 16px;
        }

        .deactivation-reason-box {
            background: var(--bg-light);
            padding: 20px;
            border-radius: 20px;
            margin: 24px 0;
            text-align: left;
            border-left: 4px solid var(--danger);
        }

        .deactivation-reason-label {
            font-size: 0.75rem;
            font-weight: 800;
            color: var(--danger);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .deactivation-reason-text {
            font-weight: 500;
            color: var(--text-main);
        }

        .deactivation-footer {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .deactivation-footer i {
            animation: spin 2s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* --- SWEETALERT CUSTOM STYLING --- */
        .swal2-popup {
            background: var(--white) !important;
            backdrop-filter: blur(20px) !important;
            border-radius: 32px !important;
            border: 1px solid var(--border-glass) !important;
            color: var(--text-main) !important;
        }

        .swal2-title {
            color: var(--text-main) !important;
            font-weight: 800 !important;
            letter-spacing: -1px !important;
        }

        .swal2-html-container {
            color: var(--text-muted) !important;
        }

        .swal2-input {
            background: var(--bg-light) !important;
            color: var(--text-main) !important;
            border: 1px solid var(--border-glass) !important;
            border-radius: 12px !important;
            box-shadow: none !important;
        }

        .swal2-input:focus {
            border-color: var(--primary-blue) !important;
            box-shadow: 0 0 0 3px rgba(46, 134, 222, 0.2) !important;
        }

        .swal2-confirm {
            border-radius: 12px !important;
            font-weight: 700 !important;
            padding: 12px 30px !important;
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2) !important;
        }

        .swal2-cancel {
            border-radius: 12px !important;
            font-weight: 700 !important;
            padding: 12px 30px !important;
        }

        .modal-field-group {
            background: rgba(46, 134, 222, 0.05);
            padding: 16px;
            border-radius: 16px;
            margin-bottom: 16px;
            border: 1px solid var(--border-glass);
            transition: var(--transition);
        }

        .modal-field-group:focus-within {
            background: rgba(46, 134, 222, 0.1);
            border-color: var(--primary-blue);
        }

        .modal-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.7rem;
            font-weight: 800;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .modal-label i {
            color: var(--primary-blue);
        }

        .modal-input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .modal-input-wrapper input {
            width: 100% !important;
            background: transparent !important;
            border: none !important;
            padding: 0 !important;
            margin: 0 !important;
            font-size: 1rem !important;
            font-weight: 700 !important;
            color: var(--text-main) !important;
            box-shadow: none !important;
        }

        .modal-input-wrapper input:focus {
            outline: none !important;
        }

        /* --- RESPONSIVE --- */
        @media(max-width: 900px) {
            .detail-card { grid-template-columns: 1fr; padding: 32px; gap: 40px; }
            .detail-title { font-size: 2rem; }
        }

        @media(max-width: 600px) {
            .info-grid { grid-template-columns: 1fr; }
            .container { margin: 30px auto; }
        }
    </style>
</head>
<%- include('./partials/theme-guard') %>
<body class="<%= (typeof user !== 'undefined' && user && user.theme === 'dark') ? 'dark-mode-active' : '' %>">

    <nav class="navbar">
        <a href="/suggestions" class="back-btn"><i class="fas fa-arrow-left"></i> Kembali</a>
        <div style="font-weight: 700; color: var(--primary-orange);">Detail Produk</div>
    </nav>

    <div class="container">
        <div class="detail-card">
            <!-- Left: Image Section -->
            <div class="detail-image-section">
                <div class="detail-image-wrapper" id="prodImage">
                    <i class="fas fa-circle-notch fa-spin"></i>
                </div>
            </div>

            <!-- Right: Content Section -->
            <div class="detail-info-section">
                <div class="detail-header">
                    <h1 class="detail-title" id="prodName">Loading...</h1>
                    <div class="action-group">
                        <button class="btn-action" onclick="approveSuggestion()" title="Isi Stok Sekarang">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-action delete" onclick="delProd()" title="Hapus Produk">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                </div>

                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-cubes"></i> Sisa Stok</div>
                        <div class="info-value" id="prodStock">0</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-tag"></i> Satuan</div>
                        <div class="info-value" id="prodUnit">-</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-level-down-alt"></i> Min. Stok</div>
                        <div class="info-value" id="prodMin">0</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label"><i class="fas fa-layer-group"></i> Kategori</div>
                        <div class="info-value" id="prodCat">-</div>
                    </div>
                    <div class="info-item" style="grid-column: span 2;">
                        <div class="info-label"><i class="fas fa-calendar-alt"></i> Tanggal Kadaluarsa</div>
                        <div class="info-value" id="prodExp">-</div>
                    </div>
                </div>

                <div class="notes-section">
                    <div class="notes-title">
                        <i class="fas fa-sticky-note"></i> Deskripsi / Catatan
                    </div>
                    <div class="notes-content" id="prodDesc">
                        Tidak ada catatan tambahan untuk produk ini.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- LOGIC (Server Connection Preserved) ---
        const id = window.location.pathname.split('/').pop();
        let isDeactivated = false;

        async function loadDetail() {
            try {
                const res = await fetch(`/api/products/${id}`);
                const data = await res.json();
                if(data.success) {
                    const p = data.product;
                    
                    // Check if product is deactivated
                    isDeactivated = p.is_deactivated_by_admin === 1 || p.is_deactivated_by_admin === true;
                    
                    const displayUnit = p.unit === 'bungkus' ? 'pcs' : (p.unit === 'liter' ? 'Liter (Vol)' : (p.unit || ''));
                    document.getElementById('prodName').innerText = p.name;
                    document.getElementById('prodStock').innerText = `${parseFloat(p.stock_quantity).toString()} ${displayUnit}`;
                    document.getElementById('prodUnit').innerText = displayUnit || '-';
                    document.getElementById('prodMin').innerText = parseFloat(p.min_stock_level).toString();
                    // Use category_name from API, fallback to category_id if not available
                    document.getElementById('prodCat').innerText = p.category_name || p.category_id || '-';
                    document.getElementById('prodDesc').innerText = p.description || p.notes || 'Tidak ada catatan.';

                    // Expiry Formatting
                    if(p.expiry_date) {
                        const d = new Date(p.expiry_date);
                        const formattedDate = `${d.getDate().toString().padStart(2, '0')}/${(d.getMonth() + 1).toString().padStart(2, '0')}/${d.getFullYear()}`;
                        document.getElementById('prodExp').innerText = formattedDate;
                    }

                    // Image
                    const imgDiv = document.getElementById('prodImage');
                    if(p.image_url) {
                        imgDiv.innerHTML = `<img src="${p.image_url}" alt="${p.name}">`;
                    } else {
                        imgDiv.innerHTML = `<i class="fas fa-box-open" style="font-size: 5rem; color: var(--text-muted);"></i>`;
                    }

                    // Stock Badge
                    const stockEl = document.getElementById('prodStock');
                    stockEl.className = 'status-badge';
                    if(p.stock_quantity <= 0) { stockEl.classList.add('st-out'); stockEl.innerText += ' (Habis)'; }
                    else if(p.stock_quantity <= p.min_stock_level) { stockEl.classList.add('st-low'); stockEl.innerText += ' (Rendah)'; }
                    else { stockEl.classList.add('st-ok'); stockEl.innerText += ' (Aman)'; }

                    // Show deactivation warning
                    if (isDeactivated) {
                        showDeactivationWarning(p.deactivated_reason || 'Tidak ada alasan yang diberikan');
                    }

                } else {
                    alert('Produk tidak ditemukan'); window.location.href='/products';
                }
            } catch(e) { console.error(e); alert('Gagal memuat data'); }
        }

        function showDeactivationWarning(reason) {
            const card = document.querySelector('.detail-card');
            if (card) {
                const overlay = document.createElement('div');
                overlay.className = 'deactivation-overlay';
                overlay.innerHTML = `
                    <div class="deactivation-card animate__animated animate__zoomIn">
                        <div class="deactivation-icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <h2 class="deactivation-title">Produk Dinonaktifkan</h2>
                        <p style="color: var(--text-muted); font-weight: 500;">
                            Akses modifikasi untuk produk ini telah dikunci sementara oleh Administrator.
                        </p>
                        
                        <div class="deactivation-reason-box">
                            <div class="deactivation-reason-label">Alasan Penonaktifan:</div>
                            <div class="deactivation-reason-text">${reason}</div>
                        </div>

                        <div class="deactivation-footer">
                            <i class="fas fa-circle-notch"></i>
                            <span>Menunggu aktivasi kembali dari Admin</span>
                        </div>
                    </div>
                `;
                card.appendChild(overlay);

                // Disable buttons
                document.querySelectorAll('.btn-action').forEach(btn => {
                    btn.disabled = true;
                    btn.style.opacity = '0.3';
                    btn.style.cursor = 'not-allowed';
                    btn.title = 'Akses Terkunci';
                });
            }
        }

        async function approveSuggestion() {
            if (isDeactivated) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Tidak Dapat Mengedit',
                    text: 'Produk ini telah dinonaktifkan oleh admin. Menunggu konfirmasi admin.',
                    confirmButtonText: 'OK'
                });
                return;
            }

            const name = document.getElementById('prodName').innerText;
            const isDark = document.body.classList.contains('dark-mode-active');
            
            const { value: formValues } = await Swal.fire({
                title: 'Isi Stok Sekarang',
                background: isDark ? '#0f172a' : '#ffffff',
                color: isDark ? '#f8fafc' : '#1e293b',
                html: `
                    <div style="text-align: left; margin-top: 20px;">
                        <div style="margin-bottom: 24px; padding: 15px; background: rgba(59, 130, 246, 0.1); border-radius: 16px; border-left: 4px solid var(--primary-blue);">
                            <div style="font-size: 0.7rem; font-weight: 800; color: var(--primary-blue); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;">Produk Terpilih</div>
                            <div style="font-size: 1.1rem; font-weight: 700;">${name}</div>
                        </div>

                        <div class="modal-field-group">
                            <label class="modal-label"><i class="fas fa-cubes"></i> Jumlah Stok Baru</label>
                            <div class="modal-input-wrapper">
                                <input id="swal-stock" type="number" step="0.01" placeholder="0.00">
                            </div>
                        </div>

                        <div class="modal-field-group">
                            <label class="modal-label"><i class="fas fa-calendar-check"></i> Tanggal Kadaluarsa Baru</label>
                            <div class="modal-input-wrapper">
                                <input id="swal-expiry" placeholder="Pilih tanggal...">
                            </div>
                        </div>
                    </div>
                `,
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonText: 'Konfirmasi',
                cancelButtonText: 'Batal',
                confirmButtonColor: '#10B981',
                cancelButtonColor: isDark ? '#334155' : '#64748b',
                width: '450px',
                padding: '2rem',
                didOpen: () => {
                    flatpickr("#swal-expiry", {
                        dateFormat: "Y-m-d",
                        altInput: true,
                        altFormat: "d/m/Y",
                        minDate: "today",
                        disableMobile: "true",
                        theme: isDark ? "dark" : "light"
                    });
                },
                preConfirm: () => {
                    const stock = document.getElementById('swal-stock').value;
                    const expiry = document.getElementById('swal-expiry').value;
                    if (!stock) {
                        Swal.showValidationMessage('Jumlah stok wajib diisi!');
                        return false;
                    }
                    return { stock, expiry };
                }
            });

            if (formValues) {
                try {
                    // Show loading state
                    Swal.fire({
                        title: 'Memproses...',
                        didOpen: () => { Swal.showLoading(); },
                        allowOutsideClick: false,
                        background: isDark ? '#0f172a' : '#ffffff'
                    });

                    const response = await fetch(`/api/products/${id}/approve-suggestion`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            new_stock: formValues.stock,
                            new_expiry: formValues.expiry
                        })
                    });

                    const result = await response.json();
                    if (result.success) {
                        await Swal.fire({
                            icon: 'success',
                            title: 'Berhasil!',
                            text: 'Stok telah diperbarui. Mengalihkan ke halaman saran...',
                            timer: 2000,
                            showConfirmButton: false,
                            background: isDark ? '#0f172a' : '#ffffff'
                        });
                        window.location.href = '/suggestions';
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Gagal!',
                            text: result.message || 'Terjadi kesalahan.',
                            background: isDark ? '#0f172a' : '#ffffff'
                        });
                    }
                } catch (error) {
                    console.error('Error approving suggestion:', error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'Gagal menghubungkan ke server.',
                        background: isDark ? '#0f172a' : '#ffffff'
                    });
                }
            }
        }

        async function delProd() {
            if (isDeactivated) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Tidak Dapat Menghapus',
                    text: 'Produk ini telah dinonaktifkan oleh admin. Menunggu konfirmasi admin.',
                    confirmButtonText: 'OK'
                });
                return;
            }

            const result = await Swal.fire({
                title: 'Hapus Produk?',
                text: "Produk yang dihapus tidak dapat dikembalikan!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#FF6B6B',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Ya, Hapus!',
                cancelButtonText: 'Batal',
                reverseButtons: true
            });

            if (!result.isConfirmed) return;

            try {
                const res = await fetch(`/api/products/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if(data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Berhasil!',
                        text: 'Produk telah dihapus',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/products';
                    });
                } else {
                    Swal.fire('Gagal!', data.message || 'Gagal menghapus produk', 'error');
                }
            } catch(e) {
                console.error(e);
                Swal.fire('Error!', 'Gagal menghapus produk', 'error');
            }
        }

        document.addEventListener('DOMContentLoaded', loadDetail);
    </script>

    <!-- Footer -->
    <%- include('./partials/footer') %>
</body>
</html>