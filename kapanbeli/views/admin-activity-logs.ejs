<!DOCTYPE html>
<html lang="id">
<%- include('./partials/theme-guard', { user: typeof user !== 'undefined' ? user : null }) %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log Aktivitas - Admin Kapan Beli</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-blue: #3B82F6;
            --primary-dark: #1D4ED8;
            --primary-orange: #FF9F43;
            --accent-green: #10B981;
            --accent-red: #EF4444;
            --bg-sidebar: #ffffff;
            --bg-sidebar-hover: #f1f5f9;
            --bg-sidebar-active: #e2e8f0;
            --text-sidebar: #475569;
            --text-sidebar-active: #000000;
            --text-sidebar-heading: #000000;
            --sidebar-border: #000000;
            --bg-body: #F8FAFC;
            --bg-card: #FFFFFF;
            --text-main: #000000;
            --text-muted: #64748B;
            --border-color: #000000;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
            --radius: 0px;
            --sidebar-width: 260px;
            --header-height: 70px;
            --content-padding: 40px;
        }

        body.dark-mode-active {
            --bg-sidebar: #1A1D23;
            --bg-body: #0F1115;
            --bg-card: #1A1D23;
            --text-main: #FFFFFF;
            --text-muted: #9CA3AF;
            --border-color: #FFFFFF;
            --shadow-brutal: 8px 8px 0px #000;
            --shadow-brutal-sm: 4px 4px 0px #000;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
            transition: background 0.3s;
        }

        /* Sidebar Overlay */
        .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
        .sidebar-overlay.active { display: block; }

        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width); flex: 1; padding: var(--content-padding); transition: margin-left 0.3s ease;
        }

        .top-bar {
            display: flex; justify-content: space-between; align-items: flex-start;
            margin-bottom: 40px; gap: 20px; flex-wrap: wrap;
        }
        .page-title { font-size: 2.2rem; font-weight: 900; letter-spacing: -1.5px; text-transform: uppercase; }
        .page-subtitle { font-size: 1.1rem; color: var(--text-muted); margin-top: 5px; font-weight: 500; }
        
        .top-actions { display: flex; gap: 15px; align-items: center; }

        /* Buttons */
        .btn {
            padding: 14px 28px; border: 4px solid var(--border-color); border-radius: var(--radius);
            font-weight: 800; font-size: 1rem; cursor: pointer;
            display: inline-flex; align-items: center; gap: 12px;
            transition: all 0.2s; font-family: inherit;
            text-transform: uppercase; letter-spacing: 0.5px;
            box-shadow: var(--shadow-brutal-sm);
        }
        .btn:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0px var(--border-color); }
        .btn:active { transform: translate(0, 0); box-shadow: 2px 2px 0px var(--border-color); }

        .btn-primary { background: var(--primary-blue); color: white; }
        .btn-outline { background: var(--bg-card); color: var(--text-main); }
        .btn-success { background: var(--accent-green); color: white; }
        .btn-warning { background: var(--primary-orange); color: white; }
        .btn-danger { background: var(--accent-red); color: white; }
        .btn-sm { padding: 8px 16px; font-size: 0.85rem; border-width: 3px; }
        
        .theme-toggle { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }

        /* Stats Grid */
        .stats-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 25px; margin-bottom: 40px;
        }
        .stat-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 30px; box-shadow: var(--shadow-brutal);
            transition: all 0.2s;
        }
        .stat-card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--border-color); }
        .stat-card h3 { font-size: 2.8rem; font-weight: 900; margin-bottom: 5px; line-height: 1; }
        .stat-card p { font-size: 0.95rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }

        /* Panel Card */
        .panel-card {
            background: var(--bg-card); border: 4px solid var(--border-color);
            padding: 35px; box-shadow: var(--shadow-brutal);
            margin-bottom: 40px;
        }
        .panel-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 4px solid var(--border-color);
            flex-wrap: wrap; gap: 20px;
        }
        .panel-title { font-size: 1.5rem; font-weight: 900; text-transform: uppercase; }

        /* Search & Filters */
        .filters-container {
            display: flex; gap: 20px; width: 100%; flex-wrap: wrap;
        }
        .filter-group { flex: 1; min-width: 200px; }
        .filter-label { display: block; font-weight: 900; margin-bottom: 10px; text-transform: uppercase; font-size: 0.85rem; }
        
        .form-control {
            width: 100%; padding: 15px 20px;
            border: 3px solid var(--border-color); border-radius: var(--radius);
            background: var(--bg-card); color: var(--text-main);
            font-size: 1rem; font-weight: 700; box-shadow: var(--shadow-brutal-sm);
            transition: all 0.2s; outline: none;
        }
        .form-control:focus { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); border-color: var(--primary-blue); }

        /* Table */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }
        th {
            text-align: left; padding: 20px; font-weight: 900;
            color: var(--text-main); font-size: 0.9rem; text-transform: uppercase;
            letter-spacing: 1px; border-bottom: 4px solid var(--border-color);
            background: rgba(0,0,0,0.05);
        }
        body.dark-mode-active th { background: rgba(255,255,255,0.05); }
        td { padding: 20px; border-bottom: 3px solid var(--border-color); font-weight: 700; font-size: 1rem; }
        tr:hover { background: rgba(0,0,0,0.02); }
        body.dark-mode-active tr:hover { background: rgba(255,255,255,0.02); }

        .badge {
            display: inline-block; padding: 6px 14px; border: 3px solid var(--border-color);
            font-size: 0.8rem; font-weight: 900; text-transform: uppercase;
            box-shadow: 3px 3px 0px var(--border-color);
        }
        .badge-login { background: var(--accent-green); color: white; }
        .badge-logout { background: var(--primary-orange); color: white; }
        .badge-online { background: var(--accent-green); color: white; }
        .badge-offline { background: var(--text-muted); color: white; }

        /* Pagination */
        .pagination-container { display: flex; justify-content: space-between; align-items: center; margin-top: 30px; padding-top: 20px; border-top: 4px solid var(--border-color); flex-wrap: wrap; gap: 20px; }
        .pagination-info { font-weight: 800; color: var(--text-muted); font-size: 0.95rem; }
        .pagination { display: flex; gap: 10px; list-style: none; }
        .pagination button {
            min-width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;
            border: 3px solid var(--border-color); background: var(--bg-card); font-weight: 900;
            cursor: pointer; transition: all 0.2s; box-shadow: 4px 4px 0px var(--border-color);
            padding: 0 15px; font-family: inherit; text-transform: uppercase;
        }
        .pagination button:hover:not(:disabled) { transform: translate(-2px, -2px); box-shadow: 6px 6px 0px var(--border-color); }
        .pagination button.active { background: var(--primary-blue); color: white; }
        .pagination button:disabled { opacity: 0.4; cursor: not-allowed; }

        /* Loading */
        .loading-state { text-align: center; padding: 60px; }
        .loading-state i { font-size: 3rem; color: var(--primary-blue); margin-bottom: 20px; }

        /* Responsive */
        .menu-toggle { display: none; font-size: 1.5rem; cursor: pointer; color: var(--text-main); }
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 25px; }
            .menu-toggle { display: block; }
        }

        /* Toast Container */
        .toast-container {
            position: fixed;
            top: 30px;
            right: 30px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .toast {
            padding: 16px 24px;
            border: 4px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 15px;
            box-shadow: var(--shadow-brutal-sm);
            min-width: 320px;
            font-weight: 800;
            animation: slideIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .toast.success {
            border-left: 12px solid var(--accent-green);
        }
        .toast.success i {
            color: var(--accent-green);
            font-size: 1.2rem;
        }
        .toast.error {
            border-left: 12px solid var(--accent-red);
        }
        .toast.error i {
            color: var(--accent-red);
            font-size: 1.2rem;
        }
        .toast.info {
            border-left: 12px solid var(--primary-blue);
        }
        .toast.info i {
            color: var(--primary-blue);
            font-size: 1.2rem;
        }

        @keyframes slideIn {
            from { transform: translateX(120%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    </style>
</head>
<body>
    <%- include('./partials/admin-sidebar', { currentPage: 'activity-logs', user: typeof user !== 'undefined' ? user : null }) %>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <main class="main-content">
        <!-- Top Bar -->
        <div class="top-bar">
            <div style="display: flex; align-items: center; gap: 15px;">
                <div class="menu-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </div>
                <div>
                    <h1 class="page-title">📜 Log Aktivitas</h1>
                    <p class="page-subtitle">Pantau aktivitas login dan logout seluruh pengguna</p>
                </div>
            </div>
            <div class="top-actions">
                <button class="btn btn-outline theme-toggle" onclick="toggleTheme()" id="themeToggleBtn">
                    <i class="fas fa-moon"></i>
                </button>
                <button class="btn btn-primary" onclick="loadActivityLogs(true)">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <h3 id="statTotalUsers">0</h3>
                <p>Total User</p>
            </div>
            <div class="stat-card">
                <h3 id="statOnline" style="color: var(--accent-green);">0</h3>
                <p>Online</p>
            </div>
            <div class="stat-card">
                <h3 id="statOffline" style="color: var(--text-muted);">0</h3>
                <p>Offline</p>
            </div>
            <div class="stat-card">
                <h3 id="statTodayLogins" style="color: var(--primary-blue);">0</h3>
                <p>Login Hari Ini</p>
            </div>
        </div>

        <!-- Panel Card -->
        <div class="panel-card">
            <div class="panel-header">
                <h3 class="panel-title">Riwayat Aktivitas Pengguna</h3>
                <div class="filters-container">
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-search"></i> Cari</label>
                        <input type="text" id="searchInput" class="form-control" placeholder="Cari nama atau email..." onkeyup="handleSearch(event)">
                    </div>
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-sign-in-alt"></i> Tipe</label>
                        <select id="activityTypeFilter" class="form-control" onchange="loadActivityLogs()">
                            <option value="">Semua Tipe</option>
                            <option value="login">Login</option>
                            <option value="logout">Logout</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label class="filter-label"><i class="fas fa-wifi"></i> Status User</label>
                        <select id="userStatusFilter" class="form-control" onchange="loadActivityLogs()">
                            <option value="">Semua Status</option>
                            <option value="online">Online</option>
                            <option value="offline">Offline</option>
                        </select>
                    </div>
                    <div style="display: flex; gap: 10px; align-items: flex-end;">
                        <button class="btn btn-outline" onclick="resetFilters()">
                            <i class="fas fa-redo"></i> Reset
                        </button>
                    </div>
                </div>
            </div>

            <!-- Loading State -->
            <div id="loadingState" class="loading-state">
                <i class="fas fa-circle-notch fa-spin"></i>
                <p style="font-weight: 800; text-transform: uppercase; letter-spacing: 1px;">Memuat log aktivitas...</p>
            </div>

            <!-- Table -->
            <div class="table-responsive">
                <table id="activityTable" style="display: none;">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Aktivitas</th>
                            <th>Waktu</th>
                        </tr>
                    </thead>
                    <tbody id="activityTableBody">
                    </tbody>
                </table>
            </div>

            <!-- Empty State -->
            <div id="emptyState" style="text-align: center; padding: 60px 20px; display: none;">
                <i class="fas fa-history" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 15px;"></i>
                <p style="font-weight: 800;">Belum ada data aktivitas</p>
            </div>

            <!-- Pagination -->
            <div class="pagination-container" id="pagination" style="display: none;">
                <div class="pagination-info" id="paginationInfo"></div>
                <div class="pagination" id="paginationButtons"></div>
            </div>
        </div>
    </main>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        let currentPage = 1;
        let searchTimer = null;

        // Theme Toggle Bridge
        function toggleTheme() {
            if (window.toggleAppTheme) {
                window.toggleAppTheme();
            }
        }

        window.addEventListener('themeChanged', (e) => {
            const { isDark } = e.detail;
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
        });

        function toggleSidebar() {
            document.querySelector('.sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }

        document.addEventListener('DOMContentLoaded', () => {
            const isDark = document.body.classList.contains('dark-mode-active');
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
            
            loadActivityLogs();
            loadActivityStatistics();
        });

        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
            toast.innerHTML = `<i class="fas ${icon}"></i><span style="font-weight: 800; text-transform: uppercase; font-size: 0.9rem;">${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        async function loadActivityStatistics() {
            try {
                const response = await fetch('/api/admin/activity/statistics', { credentials: 'same-origin' });
                const result = await response.json();
                if (result.success) {
                    document.getElementById('statTotalUsers').textContent = result.data.totalUsers || 0;
                    document.getElementById('statOnline').textContent = result.data.online || 0;
                    document.getElementById('statOffline').textContent = result.data.offline || 0;
                    document.getElementById('statTodayLogins').textContent = result.data.todayLogins || 0;
                }
            } catch (error) { console.error('Error stats:', error); }
        }

        async function loadActivityLogs(forceRefresh = false) {
            const loadingState = document.getElementById('loadingState');
            const activityTable = document.getElementById('activityTable');
            const emptyState = document.getElementById('emptyState');
            const pagination = document.getElementById('pagination');

            loadingState.style.display = 'block';
            activityTable.style.display = 'none';
            emptyState.style.display = 'none';
            pagination.style.display = 'none';

            try {
                const search = document.getElementById('searchInput').value;
                const activityType = document.getElementById('activityTypeFilter').value;
                const userStatus = document.getElementById('userStatusFilter').value;
                
                let url = `/api/admin/activity-logs?page=${currentPage}&limit=20`;
                if (search) url += `&search=${encodeURIComponent(search)}`;
                if (activityType) url += `&activity_type=${encodeURIComponent(activityType)}`;
                if (userStatus) url += `&status=${encodeURIComponent(userStatus)}`;

                const response = await fetch(url, { credentials: 'same-origin' });
                const result = await response.json();

                loadingState.style.display = 'none';

                if (result.success) {
                    if (result.data.length === 0) {
                        emptyState.style.display = 'block';
                    } else {
                        activityTable.style.display = 'table';
                        renderActivityLogs(result.data);
                        renderPagination(result.pagination);
                        pagination.style.display = 'flex';
                    }
                    if (forceRefresh) showToast('Data diperbarui', 'success');
                }
            } catch (error) {
                console.error('Error logs:', error);
                loadingState.innerHTML = '<i class="fas fa-exclamation-triangle" style="color: var(--accent-red);"></i><p>Gagal memuat data</p>';
            }
        }

        function renderActivityLogs(logs) {
            const tbody = document.getElementById('activityTableBody');
            tbody.innerHTML = logs.map(log => {
                const isLogin = log.activity_type === 'login';
                return `
                    <tr>
                        <td>
                            <div style="font-weight: 800;">${log.user_name || 'System'}</div>
                            <div style="font-size: 0.8rem; color: var(--text-muted);">${log.user_email || '-'}</div>
                        </td>
                        <td>
                            <span class="badge ${isLogin ? 'badge-login' : 'badge-logout'}">
                                <i class="fas fa-${isLogin ? 'sign-in-alt' : 'sign-out-alt'}"></i>
                                ${isLogin ? 'Login' : 'Logout'}
                            </span>
                        </td>
                        <td style="font-weight: 600;">${new Date(log.login_time || log.created_at).toLocaleString('id-ID')}</td>
                    </tr>
                `;
            }).join('');
        }

        function renderPagination(p) {
            const info = document.getElementById('paginationInfo');
            const buttons = document.getElementById('paginationButtons');

            info.textContent = `Menampilkan ${((p.currentPage - 1) * p.limit) + 1} - ${Math.min(p.currentPage * p.limit, p.totalItems)} dari ${p.totalItems} aktivitas`;

            let html = `<button onclick="goToPage(${p.currentPage - 1})" ${p.currentPage === 1 ? 'disabled' : ''}>Prev</button>`;
            
            for (let i = 1; i <= p.totalPages; i++) {
                if (i === 1 || i === p.totalPages || (i >= p.currentPage - 2 && i <= p.currentPage + 2)) {
                    html += `<button class="${i === p.currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
                } else if (i === p.currentPage - 3 || i === p.currentPage + 3) {
                    html += `<button disabled>...</button>`;
                }
            }

            html += `<button onclick="goToPage(${p.currentPage + 1})" ${p.currentPage === p.totalPages ? 'disabled' : ''}>Next</button>`;
            buttons.innerHTML = html;
        }

        function goToPage(page) {
            currentPage = page;
            loadActivityLogs();
        }

        function handleSearch() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(() => {
                currentPage = 1;
                loadActivityLogs();
            }, 500);
        }

        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('activityTypeFilter').value = '';
            document.getElementById('userStatusFilter').value = '';
            currentPage = 1;
            loadActivityLogs();
        }
    </script>
</body>
</html>
